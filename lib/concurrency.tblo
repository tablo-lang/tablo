    var empty: ConcurrencyArc = concurrencyDefaultArc();
    var cloned = syncArcClone(arc.id);
    if (cloned.1 != nil) {
        return (empty,
                concurrencyWrapError(cloned.1,
                                     "concurrency.arc.clone",
                                     { "arcId": arc.id } as any));
    }

    var out: ConcurrencyArc = { id: cloned.0 as int };
    return (out, nil);
}

func concurrencyArcAcquire(arc: ConcurrencyArc): (ConcurrencyGuard, Error?) {
    var empty: ConcurrencyGuard = concurrencyDefaultGuard();
    var acquired = syncArcGuardAcquire(arc.id);
    if (acquired.1 != nil) {
        return (empty,
                concurrencyWrapError(acquired.1,
                                     "concurrency.arc.acquire",
                                     { "arcId": arc.id } as any));
    }

    var guard: ConcurrencyGuard = { id: acquired.0 as int };
    return (guard, nil);
}

