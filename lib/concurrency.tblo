func concurrencyMailboxOpen(capacity: int): (ConcurrencyMailbox, Error?) {
    var empty: ConcurrencyMailbox = concurrencyDefaultMailbox();
    var inbox_r = concurrencyChannelOpen(capacity);
    if (inbox_r.1 != nil) {
        return (empty, inbox_r.1);
    }

    var outbox_r = concurrencyChannelOpen(capacity);
    if (outbox_r.1 != nil) {
        concurrencyChannelClose(inbox_r.0);
        return (empty, outbox_r.1);
    }

    var mailbox: ConcurrencyMailbox = {
        inboxChannelId: inbox_r.0.id,
        outboxChannelId: outbox_r.0.id
    };
    return (mailbox, nil);
}

func concurrencyMailboxClose(mailbox: ConcurrencyMailbox): Error? {
    var inbox_close = syncChannelClose(mailbox.inboxChannelId);
    if (inbox_close.1 != nil) {
        return concurrencyWrapError(inbox_close.1,
                                    "concurrency.mailbox.closeInbox",
                                    { "channelId": mailbox.inboxChannelId } as any);
    }

    var outbox_close = syncChannelClose(mailbox.outboxChannelId);
    if (outbox_close.1 != nil) {
        return concurrencyWrapError(outbox_close.1,
                                    "concurrency.mailbox.closeOutbox",
                                    { "channelId": mailbox.outboxChannelId } as any);
    }

    return nil;
}

func concurrencyChannelSendWithContext(channel: ConcurrencyChannel, value: any, ctx: Context): Error? {
    while (true) {
        var timeout_r = concurrencyContextSliceTimeoutMs(ctx, 200);
        if (timeout_r.1 != nil) {
            return timeout_r.1;
        }

        var send_err = concurrencyChannelSend(channel, value, timeout_r.0);
        if (send_err == nil) {
            return nil;
        }
        if (send_err.code == ERR_LIMIT) {
            continue;
        }
        return send_err;
    }
}

func concurrencyChannelRecvWithContext(channel: ConcurrencyChannel, ctx: Context): (any, Error?) {
    while (true) {
        var timeout_r = concurrencyContextSliceTimeoutMs(ctx, 200);
        if (timeout_r.1 != nil) {
            return (nil, timeout_r.1);
        }

        var recv_r = concurrencyChannelRecv(channel, timeout_r.0);
        if (recv_r.1 == nil) {
            return recv_r;
        }
        if (recv_r.1.code == ERR_LIMIT) {
            continue;
        }
        return recv_r;
    }
}

func concurrencyThreadJoinDoneWithContext(thread: ConcurrencyThread, ctx: Context): (bool, Error?) {
    while (true) {
        var timeout_r = concurrencyContextSliceTimeoutMs(ctx, 200);
        if (timeout_r.1 != nil) {
            return (false, timeout_r.1);
        }

        var join_r = concurrencyThreadJoinDone(thread, timeout_r.0);
        if (join_r.1 == nil) {
            return join_r;
        }
        if (join_r.1.code == ERR_LIMIT) {
            continue;
        }
        return join_r;
    }
}

func concurrencyThreadJoinValueWithContext(thread: ConcurrencyThread, ctx: Context): (any, Error?) {
    while (true) {
        var timeout_r = concurrencyContextSliceTimeoutMs(ctx, 200);
        if (timeout_r.1 != nil) {
            return (nil, timeout_r.1);
        }

        var join_r = concurrencyThreadJoinValue(thread, timeout_r.0);
        if (join_r.1 == nil) {
            return join_r;
        }
        if (join_r.1.code == ERR_LIMIT) {
            continue;
        }
        return join_r;
    }
}
