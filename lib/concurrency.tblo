    }
    return (read_r.0, nil);
}

func concurrencyArcWrite(guard: ConcurrencyGuard, value: any): (bool, Error?) {
    var write_r = syncArcGuardWrite(guard.id, value);
    if (write_r.1 != nil) {
        return (false,
                concurrencyWrapError(write_r.1,
