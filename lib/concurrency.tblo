    }
    return (write_r.0 as bool, nil);
}

func concurrencyArcRelease(guard: ConcurrencyGuard): (bool, Error?) {
    var release_r = syncArcGuardRelease(guard.id);
    if (release_r.1 != nil) {
        return (false,
                concurrencyWrapError(release_r.1,
                                     "concurrency.arc.release",
                                     { "guardId": guard.id } as any));
    }
    return (release_r.0 as bool, nil);
