// Ergonomic wrappers for TabloLang concurrency runtime primitives.
// Focuses on typed message passing, explicit shared state, and arc guards.

import "context.tblo";

record ConcurrencyChannel {
    id: int,
    schema: any
};

record ConcurrencyShared {
    id: int,
    schema: any
};

record ConcurrencyThread {
    id: int,
    resultSchema: any
};

record ConcurrencyArc {
    id: int
};

record ConcurrencyGuard {
    id: int
};

record ConcurrencyMailbox {
    inboxChannelId: int,
    outboxChannelId: int
};

func concurrencyStdError(code: int, message: string, data: any): Error {
    var err: Error = { code: code, message: message, data: data };
    return err;
}

func concurrencyError(code: int, message: string, context: string, detail: any): Error {
    var data: map<string, any> = {
        "context": context,
        "detail": detail
    };
    return concurrencyStdError(code, message, data);
}

func concurrencyWrapError(err_any: any, context: string, detail: any): Error {
    var err: Error = err_any as Error;
    var data: map<string, any> = {
        "context": context,
        "detail": detail,
        "causeCode": err.code,
        "causeMessage": err.message,
        "causeData": err.data
    };
    return concurrencyStdError(err.code, err.message, data);
}

func concurrencyDefaultChannel(): ConcurrencyChannel {
    var channel: ConcurrencyChannel = {
        id: -1,
        schema: nil
    };
    return channel;
}

func concurrencyDefaultShared(): ConcurrencyShared {
    var shared: ConcurrencyShared = {
        id: -1,
        schema: nil
    };
    return shared;
}

func concurrencyDefaultThread(): ConcurrencyThread {
    var thread: ConcurrencyThread = {
        id: -1,
        resultSchema: nil
    };
    return thread;
}

func concurrencyDefaultArc(): ConcurrencyArc {
    var arc: ConcurrencyArc = { id: -1 };
    return arc;
}

func concurrencyDefaultGuard(): ConcurrencyGuard {
    var guard: ConcurrencyGuard = { id: -1 };
    return guard;
}

func concurrencyDefaultMailbox(): ConcurrencyMailbox {
    var mailbox: ConcurrencyMailbox = {
        inboxChannelId: -1,
        outboxChannelId: -1
    };
    return mailbox;
}

func concurrencyValidateTimeout(timeout_ms: int, context: string): Error? {
    if (timeout_ms < 0) {
        return concurrencyError(ERR_INVALID_ARGUMENT,
                                "timeout must be >= 0",
                                context,
                                { "timeoutMs": timeout_ms } as any);
    }
    return nil;
}

func concurrencyContextSliceTimeoutMs(ctx: Context, fallback_ms: int): (int, Error?) {
    var slice_ms: int = contextTimeoutSliceMs(ctx, fallback_ms);
    if (slice_ms > 0) {
        return (slice_ms, nil);
    }

    var ctx_err = contextErr(ctx);
    if (ctx_err != nil) {
        return (0, ctx_err);
    }
    return (1, nil);
}

func concurrencyChannelOpen(capacity: int): (ConcurrencyChannel, Error?) {
    var empty: ConcurrencyChannel = concurrencyDefaultChannel();
    if (capacity < 1 || capacity > 65536) {
        return (empty,
                concurrencyError(ERR_INVALID_ARGUMENT,
                                 "channel capacity must be between 1 and 65536",
                                 "concurrency.channel.open",
                                 { "capacity": capacity } as any));
    }

    var created = syncChannelCreate(capacity);
    if (created.1 != nil) {
        return (empty,
                concurrencyWrapError(created.1,
                                     "concurrency.channel.open",
                                     { "capacity": capacity } as any));
    }

    var channel: ConcurrencyChannel = {
        id: created.0 as int,
        schema: nil
    };
    return (channel, nil);
}

func concurrencyChannelOpenTyped(capacity: int, schema: any): (ConcurrencyChannel, Error?) {
    var opened = concurrencyChannelOpen(capacity);
    if (opened.1 != nil) {
        return (opened.0, opened.1);
    }

    var raw: ConcurrencyChannel = opened.0;
    var channel: ConcurrencyChannel = {
        id: raw.id,
        schema: schema
    };
    return (channel, nil);
}

func concurrencyChannelSend(channel: ConcurrencyChannel, value: any, timeout_ms: int): Error? {
    var timeout_err = concurrencyValidateTimeout(timeout_ms, "concurrency.channel.send");
    if (timeout_err != nil) {
        return timeout_err;
    }

    if (channel.schema == nil) {
        var sent = syncChannelSend(channel.id, value, timeout_ms);
        if (sent.1 != nil) {
            return concurrencyWrapError(sent.1,
                                        "concurrency.channel.send",
                                        {
                                            "channelId": channel.id,
                                            "timeoutMs": timeout_ms
                                        } as any);
        }
        return nil;
    }

    var sent_typed = syncChannelSendTyped(channel.id, value, channel.schema, timeout_ms);
    if (sent_typed.1 != nil) {
        return concurrencyWrapError(sent_typed.1,
                                    "concurrency.channel.sendTyped",
                                    {
                                        "channelId": channel.id,
                                        "timeoutMs": timeout_ms
                                    } as any);
    }
    return nil;
}

func concurrencyChannelRecv(channel: ConcurrencyChannel, timeout_ms: int): (any, Error?) {
    var timeout_err = concurrencyValidateTimeout(timeout_ms, "concurrency.channel.recv");
    if (timeout_err != nil) {
        return (nil, timeout_err);
    }

    if (channel.schema == nil) {
        var recv = syncChannelRecv(channel.id, timeout_ms);
        if (recv.1 != nil) {
            return (nil,
                    concurrencyWrapError(recv.1,
                                         "concurrency.channel.recv",
                                         {
                                             "channelId": channel.id,
                                             "timeoutMs": timeout_ms
                                         } as any));
        }
        return (recv.0, nil);
    }

    var recv_typed = syncChannelRecvTyped(channel.id, channel.schema, timeout_ms);
    if (recv_typed.1 != nil) {
        return (nil,
                concurrencyWrapError(recv_typed.1,
                                     "concurrency.channel.recvTyped",
                                     {
                                         "channelId": channel.id,
                                         "timeoutMs": timeout_ms
                                     } as any));
    }
    return (recv_typed.0, nil);
}

func concurrencyChannelClose(channel: ConcurrencyChannel): (bool, Error?) {
    var closed = syncChannelClose(channel.id);
    if (closed.1 != nil) {
        return (false,
                concurrencyWrapError(closed.1,
                                     "concurrency.channel.close",
                                     { "channelId": channel.id } as any));
    }
    return (closed.0 as bool, nil);
}

func concurrencySharedCreate(initial: any): (ConcurrencyShared, Error?) {
    var empty: ConcurrencyShared = concurrencyDefaultShared();
    var created = syncSharedCreate(initial);
    if (created.1 != nil) {
        return (empty,
                concurrencyWrapError(created.1,
                                     "concurrency.shared.create",
                                     nil));
    }

    var shared: ConcurrencyShared = {
        id: created.0 as int,
        schema: nil
    };
    return (shared, nil);
}

func concurrencySharedCreateTyped(initial: any, schema: any): (ConcurrencyShared, Error?) {
    var empty: ConcurrencyShared = concurrencyDefaultShared();
    var created = syncSharedCreateTyped(initial, schema);
    if (created.1 != nil) {
        return (empty,
                concurrencyWrapError(created.1,
                                     "concurrency.shared.createTyped",
                                     nil));
    }

    var shared: ConcurrencyShared = {
        id: created.0 as int,
        schema: schema
    };
    return (shared, nil);
}

func concurrencySharedGet(shared: ConcurrencyShared): (any, Error?) {
    if (shared.schema == nil) {
        var got = syncSharedGet(shared.id);
        if (got.1 != nil) {
            return (nil,
                    concurrencyWrapError(got.1,
                                         "concurrency.shared.get",
                                         { "sharedId": shared.id } as any));
        }
        return (got.0, nil);
    }

    var got_typed = syncSharedGetTyped(shared.id, shared.schema);
    if (got_typed.1 != nil) {
        return (nil,
                concurrencyWrapError(got_typed.1,
                                     "concurrency.shared.getTyped",
                                     { "sharedId": shared.id } as any));
    }
    return (got_typed.0, nil);
}

func concurrencySharedSet(shared: ConcurrencyShared, value: any): (bool, Error?) {
    if (shared.schema == nil) {
        var set_r = syncSharedSet(shared.id, value);
        if (set_r.1 != nil) {
            return (false,
                    concurrencyWrapError(set_r.1,
                                         "concurrency.shared.set",
                                         { "sharedId": shared.id } as any));
        }
        return (set_r.0 as bool, nil);
    }

    var set_typed = syncSharedSetTyped(shared.id, value, shared.schema);
    if (set_typed.1 != nil) {
        return (false,
                concurrencyWrapError(set_typed.1,
                                     "concurrency.shared.setTyped",
                                     { "sharedId": shared.id } as any));
    }
    return (set_typed.0 as bool, nil);
}

func concurrencyThreadSpawn(function_name: string,
                            inbox_channel_id: int,
                            outbox_channel_id: int): (ConcurrencyThread, Error?) {
    var empty: ConcurrencyThread = concurrencyDefaultThread();
    var spawned = syncThreadSpawn(function_name, inbox_channel_id, outbox_channel_id);
    if (spawned.1 != nil) {
        return (empty,
                concurrencyWrapError(spawned.1,
                                     "concurrency.thread.spawn",
                                     {
                                         "functionName": function_name,
                                         "inboxChannelId": inbox_channel_id,
                                         "outboxChannelId": outbox_channel_id
                                     } as any));
    }

    var thread: ConcurrencyThread = {
        id: spawned.0 as int,
        resultSchema: nil
    };
    return (thread, nil);
}

func concurrencyThreadSpawnDetached(function_name: string): (ConcurrencyThread, Error?) {
    return concurrencyThreadSpawn(function_name, -1, -1);
}

func concurrencyThreadSpawnTyped(function_name: string,
                                 arg: any,
                                 arg_schema: any,
                                 inbox_channel_id: int,
                                 outbox_channel_id: int,
                                 result_schema: any): (ConcurrencyThread, Error?) {
    var empty: ConcurrencyThread = concurrencyDefaultThread();
    if (result_schema == nil) {
        return (empty,
                concurrencyError(ERR_INVALID_ARGUMENT,
                                 "typed thread requires a result schema",
                                 "concurrency.thread.spawnTyped",
                                 { "functionName": function_name } as any));
    }

    var spawned = syncThreadSpawnTyped(function_name,
                                       arg,
                                       arg_schema,
                                       inbox_channel_id,
                                       outbox_channel_id);
    if (spawned.1 != nil) {
        return (empty,
                concurrencyWrapError(spawned.1,
                                     "concurrency.thread.spawnTyped",
                                     {
                                         "functionName": function_name,
                                         "inboxChannelId": inbox_channel_id,
                                         "outboxChannelId": outbox_channel_id
                                     } as any));
    }

    var thread: ConcurrencyThread = {
        id: spawned.0 as int,
        resultSchema: result_schema
    };
    return (thread, nil);
}

func concurrencyThreadJoinDone(thread: ConcurrencyThread, timeout_ms: int): (bool, Error?) {
    if (thread.resultSchema != nil) {
        return (false,
                concurrencyError(ERR_INVALID_ARGUMENT,
                                 "typed thread requires concurrencyThreadJoinValue",
                                 "concurrency.thread.joinDone",
                                 { "threadId": thread.id } as any));
    }

    var timeout_err = concurrencyValidateTimeout(timeout_ms, "concurrency.thread.joinDone");
    if (timeout_err != nil) {
        return (false, timeout_err);
    }

    var joined = syncThreadJoin(thread.id, timeout_ms);
    if (joined.1 != nil) {
        return (false,
                concurrencyWrapError(joined.1,
                                     "concurrency.thread.joinDone",
                                     {
                                         "threadId": thread.id,
                                         "timeoutMs": timeout_ms
                                     } as any));
    }
    return (joined.0 as bool, nil);
}

func concurrencyThreadJoinValue(thread: ConcurrencyThread, timeout_ms: int): (any, Error?) {
    var timeout_err = concurrencyValidateTimeout(timeout_ms, "concurrency.thread.joinValue");
    if (timeout_err != nil) {
        return (nil, timeout_err);
    }

    if (thread.resultSchema == nil) {
        var joined_untyped = syncThreadJoin(thread.id, timeout_ms);
        if (joined_untyped.1 != nil) {
            return (nil,
                    concurrencyWrapError(joined_untyped.1,
                                         "concurrency.thread.joinValue",
                                         {
                                             "threadId": thread.id,
                                             "timeoutMs": timeout_ms
                                         } as any));
        }
        return (joined_untyped.0 as any, nil);
    }

    var joined_typed = syncThreadJoinTyped(thread.id, thread.resultSchema, timeout_ms);
    if (joined_typed.1 != nil) {
        return (nil,
                concurrencyWrapError(joined_typed.1,
                                     "concurrency.thread.joinValueTyped",
                                     {
                                         "threadId": thread.id,
                                         "timeoutMs": timeout_ms
                                     } as any));
    }
    return (joined_typed.0, nil);
}

func concurrencyThreadInboxId(): int {
    return syncThreadInbox();
}

func concurrencyThreadOutboxId(): int {
    return syncThreadOutbox();
}

func concurrencyArcCreate(initial: any): (ConcurrencyArc, Error?) {
    var empty: ConcurrencyArc = concurrencyDefaultArc();
    var created = syncArcCreate(initial);
    if (created.1 != nil) {
        return (empty,
                concurrencyWrapError(created.1,
                                     "concurrency.arc.create",
                                     nil));
    }

    var arc: ConcurrencyArc = { id: created.0 as int };
    return (arc, nil);
}

