// Log stdlib micro-benchmark.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_log_stdlib.tblo
//   ./build/Release/tablo run tests/benchmark_log_stdlib.tblo 2

import "native_integration_tests/fixtures/log.tblo";

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchLogNormalizeLevel(iters: int): void {
    var sink: int = 0;
    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var r_w = logNormalizeLevel("INFO");
        if (r_w.1 != nil) panic("logNormalizeLevel warmup failed: " + r_w.1.message);
        sink = sink + len(r_w.0);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var r = logNormalizeLevel("WARN");
        if (r.1 != nil) panic("logNormalizeLevel failed: " + r.1.message);
        sink = sink + len(r.0);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf logNormalizeLevel", iters, start, end);
    if (sink == -1) {
        println("error");
    }
}

func benchLogWouldEmit(iters: int): void {
    var created = logNew("info");
    if (created.1 != nil) {
        println("perf logWouldEmit: setup failed");
        return;
    }
    var logger: Logger = created.0;
    var sink: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var warn_r = logWouldEmit(logger, "warn");
        if (warn_r.1 != nil) panic("logWouldEmit warmup failed: " + warn_r.1.message);
        if (warn_r.0) {
            sink = sink + 1;
        }
        var debug_r = logWouldEmit(logger, "debug");
        if (debug_r.1 != nil) panic("logWouldEmit warmup failed: " + debug_r.1.message);
        if (!debug_r.0) {
            sink = sink + 1;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var info_r = logWouldEmit(logger, "info");
        if (info_r.1 != nil) panic("logWouldEmit failed: " + info_r.1.message);
        if (info_r.0) {
            sink = sink + 1;
        }
        var error_r = logWouldEmit(logger, "error");
        if (error_r.1 != nil) panic("logWouldEmit failed: " + error_r.1.message);
        if (error_r.0) {
            sink = sink + 1;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf logWouldEmit", iters * 2, start, end);
    if (sink == -1) {
        println("error");
    }
}

func benchLogWithFields(iters: int): void {
    var created = logNew("debug");
    if (created.1 != nil) {
        println("perf logWithFields: setup failed");
        return;
    }
    var base: Logger = created.0;
    var with_service = logWithField(base, "service", "billing");
    if (with_service.1 != nil) {
        println("perf logWithFields: setup field failed");
        return;
    }
    base = with_service.0;

    var sink: int = 0;
    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var next_w: Logger = logWithFields(base, {
            "route": "/orders/" + str(w % 100),
            "attempt": w % 7,
            "user": "u" + str(w % 1000)
        });
        sink = sink + mapCount(next_w.fields);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var next: Logger = logWithFields(base, {
            "route": "/checkout/" + str(i % 100),
            "attempt": i % 5,
            "region": "us-west",
            "trace": "tr-" + str(i % 2000)
        });
        sink = sink + mapCount(next.fields);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf logWithFields", iters, start, end);
    if (sink == -1) {
        println("error");
    }
}

func main(): void {
    println("=== TabloLang Log Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchLogNormalizeLevel(190000 * scale);
    benchLogWouldEmit(140000 * scale);
    benchLogWithFields(100000 * scale);

    println("Log stdlib benchmark complete!");
}
