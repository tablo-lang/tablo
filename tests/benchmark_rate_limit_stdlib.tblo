// Rate-limit stdlib micro-benchmark.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_rate_limit_stdlib.tblo
//   ./build/Release/tablo run tests/benchmark_rate_limit_stdlib.tblo 2

import "native_integration_tests/fixtures/rate_limit.tblo";

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchRateLimitTokenBucketTryConsume(iters: int): void {
    var created = rateLimitTokenBucketNewAt(1000, 1000, 1000, 0);
    if (created.1 != nil) {
        println("perf rateLimitTokenBucketTryConsume: setup failed");
        return;
    }
    var bucket: RateLimitTokenBucket = created.0;
    var sink: int = 0;
    var now_ms: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var r_w = rateLimitTokenBucketTryConsumeAt(bucket, 1, now_ms);
        bucket = r_w.0;
        if (r_w.1) {
            sink = sink + 1;
        } else {
            sink = sink + r_w.2;
        }
        now_ms = now_ms + 1;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var r_i = rateLimitTokenBucketTryConsumeAt(bucket, 1, now_ms);
        bucket = r_i.0;
        if (r_i.1) {
            sink = sink + 1;
        } else {
            sink = sink + r_i.2;
        }
        now_ms = now_ms + 1;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf rateLimitTokenBucketTryConsume", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func benchRateLimitTokenBucketRefill(iters: int): void {
    var created = rateLimitTokenBucketNewAt(100000, 20000, 0, 0);
    if (created.1 != nil) {
        println("perf rateLimitTokenBucketRefill: setup failed");
        return;
    }
    var bucket: RateLimitTokenBucket = created.0;
    var sink: int = 0;
    var now_ms: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var a_w = rateLimitTokenBucketAvailableAt(bucket, now_ms);
        bucket = a_w.0;
        sink = sink + (a_w.1 % 97);
        now_ms = now_ms + 7;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var a_i = rateLimitTokenBucketAvailableAt(bucket, now_ms);
        bucket = a_i.0;
        sink = sink + (a_i.1 % 97);
        now_ms = now_ms + 7;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf rateLimitTokenBucketRefill", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func benchRateLimitFixedWindowTryConsume(iters: int): void {
    var created = rateLimitFixedWindowNewAt(1000, 1000, 0);
    if (created.1 != nil) {
        println("perf rateLimitFixedWindowTryConsume: setup failed");
        return;
    }
    var window: RateLimitFixedWindow = created.0;
    var sink: int = 0;
    var now_ms: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var r_w = rateLimitFixedWindowTryConsumeAt(window, 1, now_ms);
        window = r_w.0;
        if (r_w.1) {
            sink = sink + 1;
        } else {
            sink = sink + r_w.2;
        }
        now_ms = now_ms + 1;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var r_i = rateLimitFixedWindowTryConsumeAt(window, 1, now_ms);
        window = r_i.0;
        if (r_i.1) {
            sink = sink + 1;
        } else {
            sink = sink + r_i.2;
        }
        now_ms = now_ms + 1;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf rateLimitFixedWindowTryConsume", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func main(): void {
    println("=== TabloLang Rate-limit Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchRateLimitTokenBucketTryConsume(250000 * scale);
    benchRateLimitTokenBucketRefill(220000 * scale);
    benchRateLimitFixedWindowTryConsume(250000 * scale);

    println("Rate-limit stdlib benchmark complete!");
}
