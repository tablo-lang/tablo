func benchHttpServerThreadPoolDeadline(iters: int): void {
    var warm: int = warmup(iters);
    var total_requests: int = iters + warm + 1;

    var server_r = startHttpServerBench("threadpool_deadline",
                                        19591,
                                        16,
                                        total_requests,
                                        2,
                                        8,
                                        5000,
                                        4096,
                                        1000);
    if (server_r.3 != nil) {
        panic("failed to start deadline benchmark server: " + server_r.3.message);
    }

    var thread_id: int = server_r.0;
    var outbox_id: int = server_r.1;
    var port: int = server_r.2;
    var ready_err = waitForHttpServerReady(port);
    if (ready_err != nil) {
        var join_ready = syncThreadJoinTyped(thread_id, "int", 100);
        var close_ready = syncChannelClose(outbox_id);
        var ready_diag: string = "";
        if (join_ready.1 == nil) {
            ready_diag = "serverReturned=" + str(join_ready.0 as int);
        } else {
            ready_diag = "serverJoinErr=" + join_ready.1.message;
        }
        if (close_ready.1 != nil) {
            ready_diag = ready_diag + ", outboxCloseErr=" + close_ready.1.message;
        }
        panic("http benchmark readiness probe failed: " + ready_err.message + " (" + str(ready_err.code) + ", " + ready_diag + ")");
    }

    var w: int = 0;
    while (w < warm) {
        var req_w = httpBenchRawRequestWithRetry(port, 40, 64);
        if (req_w != nil) {
            var dbg_msg_w = formatBenchServerDiag(thread_id, outbox_id);
            panic("raw request warmup failed at i=" + str(w) + ": " + req_w.message + " (" + dbg_msg_w + ")");
        }
        w = w + 1;
    }

    var consumed_bytes: int = 0;
    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var req = httpBenchRawRequestWithRetry(port, 40, 64);
        if (req != nil) {
            var dbg_msg = formatBenchServerDiag(thread_id, outbox_id);
            panic("raw request failed at i=" + str(i) + ": " + req.message + " (" + dbg_msg + ")");
        }
        consumed_bytes = consumed_bytes + 4;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();

    report("perf httpServerServeThreadPoolWithDeadline+rawTcp", iters, start, end);
    reportBytes("perf httpServerServeThreadPoolWithDeadline+rawTcp body", consumed_bytes, start, end);

    var stop_err = stopHttpServerBench(thread_id, outbox_id, total_requests);
    if (stop_err != nil) {
        panic("failed to stop deadline benchmark server: " + stop_err.message);
    }
}

func benchHttpServerManyQueryHelpers(iters: int): void {
    var warm: int = warmup(iters);
    var total_requests: int = iters + warm + 1;

    var server_r = startHttpServerBench("many",
                                        19621,
                                        16,
                                        total_requests,
                                        1,
                                        1,
                                        5000,
                                        4096,
                                        0);
    if (server_r.3 != nil) {
        panic("failed to start query-helper benchmark server: " + server_r.3.message);
    }

    var thread_id: int = server_r.0;
    var outbox_id: int = server_r.1;
    var port: int = server_r.2;
    var ready_err = waitForHttpServerReady(port);
    if (ready_err != nil) {
        var join_ready = syncThreadJoinTyped(thread_id, "int", 100);
        var close_ready = syncChannelClose(outbox_id);
        var ready_diag: string = "";
        if (join_ready.1 == nil) {
            ready_diag = "serverReturned=" + str(join_ready.0 as int);
        } else {
            ready_diag = "serverJoinErr=" + join_ready.1.message;
        }
        if (close_ready.1 != nil) {
            ready_diag = ready_diag + ", outboxCloseErr=" + close_ready.1.message;
        }
        panic("http query benchmark readiness probe failed: " + ready_err.message + " (" + str(ready_err.code) + ", " + ready_diag + ")");
    }

    var w: int = 0;
    while (w < warm) {
        var req_w = httpBenchRawQueryRequestWithRetry(port, 40, 64);
        if (req_w != nil) {
            var dbg_msg_w = formatBenchServerDiag(thread_id, outbox_id);
            panic("query request warmup failed at i=" + str(w) + ": " + req_w.message + " (" + dbg_msg_w + ")");
        }
        w = w + 1;
    }

    var consumed_bytes: int = 0;
    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var req = httpBenchRawQueryRequestWithRetry(port, 40, 64);
        if (req != nil) {
            var dbg_msg = formatBenchServerDiag(thread_id, outbox_id);
            panic("query request failed at i=" + str(i) + ": " + req.message + " (" + dbg_msg + ")");
        }
        consumed_bytes = consumed_bytes + 41;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();

    report("perf httpServerServeMany+queryHelpers", iters, start, end);
    reportBytes("perf httpServerServeMany+queryHelpers body", consumed_bytes, start, end);

    var stop_err = stopHttpServerBench(thread_id, outbox_id, total_requests);
    if (stop_err != nil) {
        panic("failed to stop query-helper benchmark server: " + stop_err.message);
    }
}

func main(): void {
    println("=== TabloLang HTTP Server Micro-Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchHttpServerMany(200 * scale);
    benchHttpServerThreadPool(200 * scale);
    benchHttpServerThreadPoolDeadline(200 * scale);
    benchHttpServerManyQueryHelpers(200 * scale);

    println("HTTP server benchmark complete!");
}
