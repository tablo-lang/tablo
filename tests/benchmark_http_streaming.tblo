func main(): void {
    println("=== TabloLang HTTP Streaming Micro-Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    var timeout_ms: int = 5000;
    var body_bytes: int = 65536;

    benchHttpClientGetHeaders(600 * scale, body_bytes, timeout_ms);
    benchHttpRequestBuffered(800 * scale, body_bytes, timeout_ms);
    benchHttpRequestHeadStream(800 * scale, body_bytes, 1024, timeout_ms);
    benchHttpClientStreamWrapper(800 * scale, body_bytes, 1024, timeout_ms);
    benchHttpClientStreamWrapperBytes(800 * scale, body_bytes, 1024, timeout_ms);
    benchHttpClientStreamWrapperBytesLarge(80 * scale, 1048576, 4096, 10000);

    println("HTTP streaming benchmark complete!");
}
