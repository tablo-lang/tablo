        var req = httpClientRequestStream("GET", url, nil, nil, timeout_ms);
        if (req.1 != nil) {
            panic("httpClientRequestStream failed: " + req.1.message);
        }
        var read = httpClientStreamReadAllBytes(req.0, chunk_bytes);
        if (read.2 != nil) {
            panic("httpClientStreamReadAllBytes failed: " + read.2.message);
