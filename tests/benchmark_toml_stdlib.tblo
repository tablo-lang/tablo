// TOML stdlib micro-benchmark.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_toml_stdlib.tblo
//   ./build/Release/tablo run tests/benchmark_toml_stdlib.tblo 2

import "native_integration_tests/fixtures/toml.tblo";

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchTomlParse(iters: int): void {
    var text: string = "name = \"tablo\"\n" +
                       "port = 8080\n" +
                       "enabled = true\n" +
                       "tags = [\"lang\", \"vm\", \"fast\"]\n" +
                       "[server]\n" +
                       "host = \"127.0.0.1\"\n" +
                       "workers = 8\n" +
                       "[server.tls]\n" +
                       "enabled = false\n";

    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var p_w = tomlParse(text);
        if (p_w.1 != nil) {
            panic("benchTomlParse warmup failed: " + p_w.1.message);
        }

        var port_w = tomlGetInt(p_w.0, "port");
        if (port_w.1 == nil && port_w.0 != nil) {
            sink = sink + (port_w.0 as int);
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var p = tomlParse(text);
        if (p.1 != nil) {
            panic("benchTomlParse failed: " + p.1.message);
        }

        var workers = tomlGetInt(p.0, "server.workers");
        if (workers.1 == nil && workers.0 != nil) {
            sink = sink + (workers.0 as int);
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf tomlParse", iters, start, end);
    if (sink == 0) {
        println("error");
    }
}

func benchTomlStringify(iters: int): void {
    var text: string = "name = \"tablo\"\n" +
                       "port = 8080\n" +
                       "enabled = true\n" +
                       "tags = [\"lang\", \"vm\", \"fast\"]\n" +
                       "[server]\n" +
                       "host = \"127.0.0.1\"\n" +
                       "workers = 8\n" +
                       "[server.tls]\n" +
                       "enabled = false\n";

    var parsed = tomlParse(text);
    if (parsed.1 != nil) {
        panic("benchTomlStringify fixture parse failed: " + parsed.1.message);
    }

    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var s_w = tomlStringify(parsed.0);
        if (s_w.1 != nil) {
            panic("benchTomlStringify warmup failed: " + s_w.1.message);
        }
        sink = sink + len(s_w.0);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var s = tomlStringify(parsed.0);
        if (s.1 != nil) {
            panic("benchTomlStringify failed: " + s.1.message);
        }
        sink = sink + len(s.0);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf tomlStringify", iters, start, end);
    if (sink == 0) {
        println("error");
    }
}

func main(): void {
    println("=== TabloLang TOML Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchTomlParse(80000 * scale);
    benchTomlStringify(110000 * scale);

    println("TOML stdlib benchmark complete!");
}
