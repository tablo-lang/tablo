func benchProcessRunWithInput(iters: int): void {
    var cmd = shellReadEchoCommand();
    var input: string = "bench_process_input\n";
    var expected: string = "stdin:bench_process_input";

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        if (!runWithInputOnce(cmd.0, cmd.1, input, expected)) {
            println("perf processRunWithInput: warmup failed");
            return;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        if (!runWithInputOnce(cmd.0, cmd.1, input, expected)) {
            println("perf processRunWithInput: iteration failed");
            return;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();

    report("perf processRunWithInput", iters, start, end);
}

func benchProcessReadStdoutChunk(iters: int): void {
    var cmd = shellEchoCommand("bench_chunk_stream_message");
    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        if (!runReadStdoutChunkOnce(cmd.0, cmd.1, "bench_chunk_stream_message", 5)) {
            println("perf processReadStdoutChunk: warmup failed");
            return;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        if (!runReadStdoutChunkOnce(cmd.0, cmd.1, "bench_chunk_stream_message", 5)) {
            println("perf processReadStdoutChunk: iteration failed");
            return;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();

    report("perf processReadStdoutChunk", iters, start, end);
}

func main(): void {
    println("=== TabloLang Process Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchProcessStartWait(40 * scale);
    benchProcessRunPipeline(20 * scale);
    benchProcessRunPipelineStream(20 * scale);
    benchProcessRunWithInput(20 * scale);
    benchProcessReadStdoutChunk(20 * scale);
}
