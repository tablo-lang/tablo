// n-body benchmark (ported from the classic C version / benchmarksgame nbody).
//
// Run:
//   ./build/Release/tablo run tests/benchmark_nbody.tblo 5000000
//
// Input:
//   N is read from argv[0]. If no argument is provided, defaults to 0.
//
// Output:
//   Two lines with the system energy, formatted with 9 decimals:
//     - before advancing
//     - after advancing N steps with dt=0.01

record Planet {
    x: double;
    y: double;
    z: double;
    vx: double;
    vy: double;
    vz: double;
    mass: double
}

var PI: double = 3.141592653589793;
var SOLAR_MASS: double = 4.0 * PI * PI;
var DAYS_PER_YEAR: double = 365.24;

var bodies: array<Planet> = [
    // sun
    { x: 0.0, y: 0.0, z: 0.0, vx: 0.0, vy: 0.0, vz: 0.0, mass: SOLAR_MASS },
    // jupiter
    {
        x: 4.84143144246472090,
        y: -1.16032004402742839,
        z: -0.103622044471123109,
        vx: 0.00166007664274403694 * DAYS_PER_YEAR,
        vy: 0.00769901118419740425 * DAYS_PER_YEAR,
        vz: -0.0000690460016972063023 * DAYS_PER_YEAR,
        mass: 0.000954791938424326609 * SOLAR_MASS
    },
    // saturn
    {
        x: 8.34336671824457987,
        y: 4.12479856412430479,
        z: -0.403523417114321381,
        vx: -0.00276742510726862411 * DAYS_PER_YEAR,
        vy: 0.00499852801234917238 * DAYS_PER_YEAR,
        vz: 0.0000230417297573763929 * DAYS_PER_YEAR,
        mass: 0.000285885980666130812 * SOLAR_MASS
    },
    // uranus
    {
        x: 12.8943695621391310,
        y: -15.1111514016986312,
        z: -0.223307578892655734,
        vx: 0.00296460137564761618 * DAYS_PER_YEAR,
        vy: 0.00237847173959480950 * DAYS_PER_YEAR,
        vz: -0.0000296589568540237556 * DAYS_PER_YEAR,
        mass: 0.0000436624404335156298 * SOLAR_MASS
    },
    // neptune
    {
        x: 15.3796971148509165,
        y: -25.9193146099879641,
        z: 0.179258772950371181,
        vx: 0.00268067772490389322 * DAYS_PER_YEAR,
        vy: 0.00162824170038242295 * DAYS_PER_YEAR,
        vz: -0.0000951592254519715870 * DAYS_PER_YEAR,
        mass: 0.0000515138902046611451 * SOLAR_MASS
    }
];

func offsetMomentum(b: array<Planet>): void {
    var px: double = 0.0;
    var py: double = 0.0;
    var pz: double = 0.0;

    var i: int = 0;
    var n: int = len(b);
    while (i < n) {
        px = px + (b[i].vx * b[i].mass);
        py = py + (b[i].vy * b[i].mass);
        pz = pz + (b[i].vz * b[i].mass);
        i = i + 1;
    }

    b[0].vx = -px / SOLAR_MASS;
    b[0].vy = -py / SOLAR_MASS;
    b[0].vz = -pz / SOLAR_MASS;
}

func energy(b: array<Planet>): double {
    var e: double = 0.0;
    var n: int = len(b);

    var i: int = 0;
    while (i < n) {
        var mass_i: double = b[i].mass;
        var vxi: double = b[i].vx;
        var vyi: double = b[i].vy;
        var vzi: double = b[i].vz;
        e = e + (0.5 * mass_i * ((vxi * vxi) + (vyi * vyi) + (vzi * vzi)));

        var j: int = i + 1;
        while (j < n) {
            var dx: double = b[i].x - b[j].x;
            var dy: double = b[i].y - b[j].y;
            var dz: double = b[i].z - b[j].z;
            var distance: double = sqrt((dx * dx) + (dy * dy) + (dz * dz));
            e = e - ((mass_i * b[j].mass) / distance);
            j = j + 1;
        }

        i = i + 1;
    }

    return e;
}

func advance(b: array<Planet>, dt: double): void {
    var n: int = len(b);

    var i: int = 0;
    while (i < n) {
        var mass_i: double = b[i].mass;
        var j: int = i + 1;
        while (j < n) {
            var dx: double = b[i].x - b[j].x;
            var dy: double = b[i].y - b[j].y;
            var dz: double = b[i].z - b[j].z;

            var distanced: double = (dx * dx) + (dy * dy) + (dz * dz);
            var distance: double = sqrt(distanced);
            var mag: double = dt / (distanced * distance);

            var mass_j: double = b[j].mass;

            b[i].vx = b[i].vx - (dx * mass_j * mag);
            b[i].vy = b[i].vy - (dy * mass_j * mag);
            b[i].vz = b[i].vz - (dz * mass_j * mag);

            b[j].vx = b[j].vx + (dx * mass_i * mag);
            b[j].vy = b[j].vy + (dy * mass_i * mag);
            b[j].vz = b[j].vz + (dz * mass_i * mag);

            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < n) {
        b[i].x = b[i].x + (dt * b[i].vx);
        b[i].y = b[i].y + (dt * b[i].vy);
        b[i].z = b[i].z + (dt * b[i].vz);
        i = i + 1;
    }
}

func main(): void {
    var n: int = 0;
    if (len(argv) > 0) {
        n = toInt(argv[0]);
    }
    if (n < 0) {
        n = 0;
    }

    offsetMomentum(bodies);
    println(formatDouble(energy(bodies), 9));

    var i: int = 0;
    while (i < n) {
        advance(bodies, 0.01);
        i = i + 1;
    }

    println(formatDouble(energy(bodies), 9));
}
