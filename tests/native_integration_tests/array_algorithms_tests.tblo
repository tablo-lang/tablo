func reverse_in_place(arr: array<int>): void {
    var i: int = 0;
    var j: int = len(arr) - 1;
    while (i < j) {
        var tmp: int = arr[i];
        arr[i] = arr[j];
        arr[j] = tmp;
        i = i + 1;
        j = j - 1;
    }
}

func filter_even(arr: array<int>): array<int> {
    var out: array<int> = [];
    foreach (x in arr) {
        if (x % 2 == 0) {
            push(out, x);
        }
    }
    return out;
}

func main() {
    var data: array<int> = [5, 4, 3, 2, 1];
    println(data);

    reverse_in_place(data);
    println(data);

    println(filter_even(data));
}

