import "fixtures/process.tblo";

func isWindowsHost(): bool {
    var lower = envGet("ComSpec");
    if (lower.1 == nil && lower.0 != nil) {
        return true;
    }

    var upper = envGet("COMSPEC");
    if (upper.1 == nil && upper.0 != nil) {
        return true;
    }

    return false;
}

func tlsFixtureCommand(port: int): (string, array<string>) {
    var script = "$ErrorActionPreference='Stop';" +
                 "$port=" + str(port) + ";" +
                 "$listener=[System.Net.Sockets.TcpListener]::new([System.Net.IPAddress]::Loopback,$port);" +
                 "$listener.Start();" +
                 "$rsa=[System.Security.Cryptography.RSA]::Create(2048);" +
                 "$req=[System.Security.Cryptography.X509Certificates.CertificateRequest]::new('CN=localhost',$rsa,[System.Security.Cryptography.HashAlgorithmName]::SHA256,[System.Security.Cryptography.RSASignaturePadding]::Pkcs1);" +
                 "$san=[System.Security.Cryptography.X509Certificates.SubjectAlternativeNameBuilder]::new();" +
                 "$san.AddDnsName('localhost');" +
                 "$req.CertificateExtensions.Add($san.Build());" +
                 "$req.CertificateExtensions.Add([System.Security.Cryptography.X509Certificates.X509BasicConstraintsExtension]::new($false,$false,0,$false));" +
                 "$req.CertificateExtensions.Add([System.Security.Cryptography.X509Certificates.X509KeyUsageExtension]::new([System.Security.Cryptography.X509Certificates.X509KeyUsageFlags]::DigitalSignature,$false));" +
                 "$oids=[System.Security.Cryptography.OidCollection]::new();" +
                 "$null=$oids.Add([System.Security.Cryptography.Oid]::new('1.3.6.1.5.5.7.3.1'));" +
                 "$req.CertificateExtensions.Add([System.Security.Cryptography.X509Certificates.X509EnhancedKeyUsageExtension]::new($oids,$false));" +
                 "$certTmp=$req.CreateSelfSigned([DateTimeOffset]::Now.AddMinutes(-5),[DateTimeOffset]::Now.AddHours(1));" +
                 "$pfx=$certTmp.Export([System.Security.Cryptography.X509Certificates.X509ContentType]::Pfx,'vml');" +
                 "$cert=[System.Security.Cryptography.X509Certificates.X509Certificate2]::new($pfx,'vml',[System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::MachineKeySet -bor [System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::PersistKeySet -bor [System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::Exportable);" +
                 "[Console]::Out.WriteLine('READY');" +
                 "$client=$listener.AcceptTcpClient();" +
                 "$stream=$client.GetStream();" +
                 "$ssl=[System.Net.Security.SslStream]::new($stream,$false);" +
                 "$ssl.AuthenticateAsServer($cert,$false,[System.Security.Authentication.SslProtocols]::Tls12,$false);" +
                 "$buf=New-Object byte[] 4096;" +
                 "$null=$ssl.Read($buf,0,$buf.Length);" +
                 "$resp=[System.Text.Encoding]::ASCII.GetBytes(\"HTTP/1.1 200 OK`r`nContent-Length: 2`r`nConnection: close`r`n`r`nok\");" +
                 "$ssl.Write($resp,0,$resp.Length);" +
                 "$ssl.Flush();" +
                 "$ssl.Dispose();" +
                 "$client.Dispose();" +
                 "$listener.Stop();";

    return ("powershell",
            [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                script
            ]);
}

func waitForFixtureReady(handle: ProcessHandle): bool {
    var buffered = "";
    var i = 0;
    while (i < 200) {
        var chunk_r = processReadStdoutChunk(handle, 256);
        if (chunk_r.1 == nil && chunk_r.0 != nil) {
            buffered = buffered + (chunk_r.0 as string);
            if (find(buffered, "READY") >= 0) {
                return true;
            }
        }

        var waited = processWaitFor(handle, 10);
        if (waited.1 == nil && waited.0.finished) {
            return find(buffered, "READY") >= 0;
        }

        i = i + 1;
    }

    return false;
}

func main(): void {
    var ok_start = false;
    var ok_ready = false;
    var ok_req = false;
    var ok_status = false;
    var ok_body = false;
    var ok_wait = false;
    var ok_finished = false;
    var ok_exit = false;

    if (!isWindowsHost() || !tlsIsAvailable()) {
        ok_start = true;
        ok_ready = true;
        ok_req = true;
        ok_status = true;
        ok_body = true;
        ok_wait = true;
        ok_finished = true;
        ok_exit = true;
    } else {
        var handle: ProcessHandle = processDefaultHandle();
        var selected_port: int = 0;
        var ports: array<int> = [19681, 19682, 19683, 19684];

        foreach (p in ports) {
            var cmd = tlsFixtureCommand(p);
            var started = processStartDefault(cmd.0, cmd.1);
            if (started.1 != nil) {
                continue;
            }

            handle = started.0;
            var _close_err = processCloseInput(handle);
            if (waitForFixtureReady(handle)) {
                ok_start = true;
                ok_ready = true;
                selected_port = p;
                break;
            }

            var _terminate = processTerminate(handle);
            var _wait_after_terminate = processWaitFor(handle, 1000);
            handle = processDefaultHandle();
        }

        if (ok_start && selected_port > 0) {
            var req = httpRequestWithOptions("GET",
                                             "https://localhost:" + str(selected_port) + "/",
                                             nil,
                                             nil,
                                             5000,
                                             {"tlsInsecureSkipVerify": true} as map<string, any>);
            ok_req = req.1 == nil;
            if (req.1 == nil && typeOf(req.0) == "map") {
                var response = req.0 as map<string, any>;
                var status_any = mapGet(response, "status");
                var body_any = mapGet(response, "body");
                ok_status = status_any != nil && typeOf(status_any) == "int" && (status_any as int) == 200;
                ok_body = body_any != nil && typeOf(body_any) == "string" && (body_any as string) == "ok";
            }

            var waited = processWaitFor(handle, 4000);
            ok_wait = waited.1 == nil;
            if (waited.1 == nil) {
                ok_finished = waited.0.finished;
                ok_exit = waited.0.exitCode == 0;
            }

            if (!ok_finished) {
                var _term_final = processTerminate(handle);
                var _wait_final = processWaitFor(handle, 1000);
            }
        } else if (handle.id >= 0) {
            var _term_fallback = processTerminate(handle);
            var _wait_fallback = processWaitFor(handle, 1000);
        }
    }

    println(ok_start);
    println(ok_ready);
    println(ok_req);
    println(ok_status);
    println(ok_body);
    println(ok_wait);
    println(ok_finished);
    println(ok_exit);
}

