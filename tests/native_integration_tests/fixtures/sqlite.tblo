// SQLite stdlib helpers for backend/CLI workflows.
// Wraps sqlite* runtime builtins with contextual errors and typed decode helpers.

record SqliteDb {
    id: int,
    path: string
};

record SqliteStatement {
    id: int,
    db: SqliteDb
};

func sqliteStdError(code: int, message: string, data: any): Error {
    var err: Error = { code: code, message: message, data: data };
    return err;
}

func sqliteError(code: int, message: string, context: string, detail: any): Error {
    var data: map<string, any> = { "context": context };
    if (detail != nil) {
        mapSetString(data, "detail", detail);
    }
    return sqliteStdError(code, message, data);
}

func sqliteWrapError(err_any: any, context: string, detail: any): Error {
    var err: Error = err_any as Error;
    var data: map<string, any> = {
        "context": context,
        "causeCode": err.code,
        "causeMessage": err.message,
        "causeData": err.data
    };
    if (detail != nil) {
        mapSetString(data, "detail", detail);
    }
    return sqliteStdError(err.code, err.message, data);
}

func sqliteDefaultDb(): SqliteDb {
    var db: SqliteDb = {
        id: -1,
        path: ""
    };
    return db;
}

func sqliteDefaultStatement(): SqliteStatement {
    var stmt: SqliteStatement = {
        id: -1,
        db: sqliteDefaultDb()
    };
    return stmt;
}

func sqliteOpenDb(path: string): (SqliteDb, Error?) {
    var empty: SqliteDb = sqliteDefaultDb();
    if (path == "") {
        return (empty,
                sqliteError(ERR_INVALID_ARGUMENT,
                            "path must not be empty",
                            "sqliteOpenDb.path",
                            path));
    }

    var opened = sqliteOpen(path);
    if (opened.1 != nil) {
        return (empty,
                sqliteWrapError(opened.1,
                                "sqliteOpenDb",
                                { "path": path } as any));
    }

    var db: SqliteDb = {
        id: opened.0 as int,
        path: path
    };
    return (db, nil);
}

func sqliteOpenMemory(): (SqliteDb, Error?) {
    return sqliteOpenDb(":memory:");
}

func sqliteCloseDb(db: SqliteDb): Error? {
    var closed = sqliteClose(db.id);
    if (closed.1 != nil) {
        return sqliteWrapError(closed.1,
                               "sqliteCloseDb",
                               {
                                   "dbId": db.id,
                                   "path": db.path
                               } as any);
    }
    if (!closed.0) {
        return sqliteError(ERR_IO,
                           "sqliteClose returned false",
                           "sqliteCloseDb",
                           { "dbId": db.id, "path": db.path } as any);
    }
    return nil;
}

func sqliteExecSql(db: SqliteDb, sql: string): (bool, Error?) {
    if (sql == "") {
        return (false,
                sqliteError(ERR_INVALID_ARGUMENT,
                            "sql must not be empty",
                            "sqliteExecSql.sql",
                            sql));
    }

    var executed = sqliteExec(db.id, sql);
    if (executed.1 != nil) {
        return (false,
                sqliteWrapError(executed.1,
                                "sqliteExecSql",
                                {
                                    "dbId": db.id,
                                    "path": db.path,
                                    "sql": sql
                                } as any));
    }
    if (!executed.0) {
        return (false,
                sqliteError(ERR_IO,
                            "sqliteExec returned false",
                            "sqliteExecSql",
                            { "dbId": db.id, "sql": sql } as any));
    }
    return (true, nil);
}

func sqliteExecBatch(db: SqliteDb, statements: array<string>): (int, Error?) {
    var count: int = 0;
    var i: int = 0;
    while (i < len(statements)) {
        var stmt_sql: string = statements[i];
        var done = sqliteExecSql(db, stmt_sql);
        if (done.1 != nil) {
            return (count,
                    sqliteWrapError(done.1,
                                    "sqliteExecBatch.statement",
                                    {
                                        "index": i,
                                        "sql": stmt_sql
                                    } as any));
        }
        count = count + 1;
        i = i + 1;
    }
    return (count, nil);
}

func sqliteExecBatchTx(db: SqliteDb, statements: array<string>): (int, Error?) {
    var begin_err = sqliteBeginTx(db);
    if (begin_err != nil) {
        return (0,
                sqliteWrapError(begin_err,
                                "sqliteExecBatchTx.begin",
                                {
                                    "dbId": db.id,
                                    "path": db.path
                                } as any));
    }

    var executed = sqliteExecBatch(db, statements);
    if (executed.1 != nil) {
        var rollback_err = sqliteRollbackTx(db);
        if (rollback_err != nil) {
            return (executed.0,
                    sqliteWrapError(rollback_err,
                                    "sqliteExecBatchTx.rollback",
                                    {
                                        "dbId": db.id,
                                        "path": db.path,
                                        "executedCount": executed.0,
                                        "execError": executed.1
                                    } as any));
        }
        return (executed.0,
                sqliteWrapError(executed.1,
                                "sqliteExecBatchTx.exec",
                                {
                                    "dbId": db.id,
                                    "path": db.path,
                                    "executedCount": executed.0
                                } as any));
    }

    var commit_err = sqliteCommitTx(db);
    if (commit_err != nil) {
        return (executed.0,
                sqliteWrapError(commit_err,
                                "sqliteExecBatchTx.commit",
                                {
                                    "dbId": db.id,
                                    "path": db.path,
                                    "executedCount": executed.0
                                } as any));
    }

    return (executed.0, nil);
}

func sqliteBeginTx(db: SqliteDb): Error? {
    var started = sqliteExecSql(db, "begin transaction;");
    if (started.1 != nil) {
        return sqliteWrapError(started.1,
                               "sqliteBeginTx",
                               {
                                   "dbId": db.id,
                                   "path": db.path
                               } as any);
    }
    return nil;
}

func sqliteCommitTx(db: SqliteDb): Error? {
    var committed = sqliteExecSql(db, "commit;");
    if (committed.1 != nil) {
        return sqliteWrapError(committed.1,
                               "sqliteCommitTx",
                               {
                                   "dbId": db.id,
                                   "path": db.path
                               } as any);
    }
    return nil;
}

func sqliteRollbackTx(db: SqliteDb): Error? {
    var rolled = sqliteExecSql(db, "rollback;");
    if (rolled.1 != nil) {
        return sqliteWrapError(rolled.1,
                               "sqliteRollbackTx",
                               {
                                   "dbId": db.id,
                                   "path": db.path
                               } as any);
    }
    return nil;
}

func sqliteDecodeRows(raw_rows: any): (array<map<string, any>>, Error?) {
    var out: array<map<string, any>> = [];
    if (raw_rows == nil || typeOf(raw_rows) != "array") {
        return (out,
                sqliteError(ERR_PARSE,
                            "sqlite row payload must be array",
                            "sqliteDecodeRows.type",
                            raw_rows));
    }

    var rows_any: array<any> = raw_rows as array<any>;
    var i: int = 0;
    while (i < len(rows_any)) {
        var row_any: any = rows_any[i];
        if (row_any == nil || typeOf(row_any) != "map") {
            return (out,
                    sqliteError(ERR_PARSE,
                                "sqlite row must be map",
                                "sqliteDecodeRows.rowType",
                                {
                                    "index": i,
                                    "valueType": typeOf(row_any)
                                } as any));
        }
        push(out, row_any as map<string, any>);
        i = i + 1;
    }
    return (out, nil);
}

func sqliteQueryAll(db: SqliteDb, sql: string): (array<map<string, any>>, Error?) {
    var out: array<map<string, any>> = [];
    if (sql == "") {
        return (out,
                sqliteError(ERR_INVALID_ARGUMENT,
                            "sql must not be empty",
                            "sqliteQueryAll.sql",
                            sql));
    }

    var queried = sqliteQuery(db.id, sql);
    if (queried.1 != nil) {
        return (out,
                sqliteWrapError(queried.1,
                                "sqliteQueryAll",
                                {
                                    "dbId": db.id,
                                    "path": db.path,
                                    "sql": sql
                                } as any));
    }

    return sqliteDecodeRows(queried.0 as any);
}

func sqliteQueryOne(db: SqliteDb, sql: string): (map<string, any>?, Error?) {
    var all = sqliteQueryAll(db, sql);
    if (all.1 != nil) {
        return (nil, all.1);
    }
    if (len(all.0) == 0) {
        return (nil, nil);
    }
    return (all.0[0], nil);
}

func sqlitePrepareQuery(db: SqliteDb, sql: string): (SqliteStatement, Error?) {
    var empty: SqliteStatement = sqliteDefaultStatement();
    if (sql == "") {
        return (empty,
                sqliteError(ERR_INVALID_ARGUMENT,
                            "sql must not be empty",
                            "sqlitePrepareQuery.sql",
                            sql));
    }

    var prepared = sqlitePrepare(db.id, sql);
    if (prepared.1 != nil) {
        return (empty,
                sqliteWrapError(prepared.1,
                                "sqlitePrepareQuery",
                                {
                                    "dbId": db.id,
                                    "path": db.path,
                                    "sql": sql
                                } as any));
    }

    var stmt: SqliteStatement = {
        id: prepared.0 as int,
        db: db
    };
    return (stmt, nil);
}

func sqliteBindIntParam(stmt: SqliteStatement, index: int, value: int): Error? {
    var bound = sqliteBindInt(stmt.id, index, value);
    if (bound.1 != nil) {
        return sqliteWrapError(bound.1,
                               "sqliteBindIntParam",
                               {
                                   "statementId": stmt.id,
                                   "dbId": stmt.db.id,
                                   "index": index
                               } as any);
    }
    if (!bound.0) {
        return sqliteError(ERR_IO,
                           "sqliteBindInt returned false",
                           "sqliteBindIntParam",
                           { "statementId": stmt.id, "index": index } as any);
    }
    return nil;
}

