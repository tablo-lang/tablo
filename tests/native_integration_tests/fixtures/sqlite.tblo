    var bound = sqliteBindNull(stmt.id, index);
    if (bound.1 != nil) {
        return sqliteWrapError(bound.1,
                               "sqliteBindNullParam",
                               {
                                   "statementId": stmt.id,
                                   "dbId": stmt.db.id,
                                   "index": index
                               } as any);
    }
    if (!bound.0) {
        return sqliteError(ERR_IO,
                           "sqliteBindNull returned false",
