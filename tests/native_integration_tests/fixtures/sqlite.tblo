func sqliteResetStmt(stmt: SqliteStatement): Error? {
    var reset = sqliteReset(stmt.id);
    if (reset.1 != nil) {
        return sqliteWrapError(reset.1,
                               "sqliteResetStmt",
                               {
                                   "statementId": stmt.id,
                                   "dbId": stmt.db.id
                               } as any);
    }
    if (!reset.0) {
        return sqliteError(ERR_IO,
                           "sqliteReset returned false",
                           "sqliteResetStmt",
                           { "statementId": stmt.id } as any);
    }
    return nil;
}

func sqliteClearStmtBindings(stmt: SqliteStatement): Error? {
    var cleared = sqliteClearBindings(stmt.id);
    if (cleared.1 != nil) {
        return sqliteWrapError(cleared.1,
                               "sqliteClearStmtBindings",
                               {
                                   "statementId": stmt.id,
                                   "dbId": stmt.db.id
                               } as any);
    }
    if (!cleared.0) {
        return sqliteError(ERR_IO,
                           "sqliteClearBindings returned false",
                           "sqliteClearStmtBindings",
                           { "statementId": stmt.id } as any);
    }
    return nil;
}

func sqliteChangesCount(db: SqliteDb): (int, Error?) {
    var changed = sqliteChanges(db.id);
    if (changed.1 != nil) {
        return (0,
                sqliteWrapError(changed.1,
                                "sqliteChangesCount",
                                {
                                    "dbId": db.id,
                                    "path": db.path
                                } as any));
    }
    return (changed.0 as int, nil);
}

func sqliteLastInsertId(db: SqliteDb): (int, Error?) {
    var last = sqliteLastInsertRowId(db.id);
    if (last.1 != nil) {
        return (0,
                sqliteWrapError(last.1,
                                "sqliteLastInsertId",
                                {
                                    "dbId": db.id,
                                    "path": db.path
                                } as any));
    }
    return (last.0 as int, nil);
}

func sqliteBindParam(stmt: SqliteStatement, index: int, value: any): Error? {
    if (index <= 0) {
        return sqliteError(ERR_INVALID_ARGUMENT,
                           "parameter index must be >= 1",
                           "sqliteBindParam.index",
                           index as any);
    }

    if (value == nil) {
        return sqliteBindNullParam(stmt, index);
    }

    var value_type: string = typeOf(value);
    if (value_type == "nil") {
        return sqliteBindNullParam(stmt, index);
    }
    if (value_type == "int") {
        return sqliteBindIntParam(stmt, index, value as int);
    }
    if (value_type == "bool") {
        var as_int: int = 0;
        if (value as bool) {
            as_int = 1;
        }
        return sqliteBindIntParam(stmt, index, as_int);
    }
    if (value_type == "double") {
        return sqliteBindDoubleParam(stmt, index, value);
    }
    if (value_type == "string") {
        return sqliteBindStringParam(stmt, index, value as string);
    }
    if (value_type == "bytes") {
        return sqliteBindBytesParam(stmt, index, value as bytes);
    }

    return sqliteError(ERR_INVALID_ARGUMENT,
                       "unsupported sqlite parameter type",
                       "sqliteBindParam.type",
                       {
                           "index": index,
                           "valueType": value_type
                       } as any);
}

func sqliteBindParams(stmt: SqliteStatement, params: array<any>): Error? {
    var clear_err = sqliteClearStmtBindings(stmt);
    if (clear_err != nil) {
        return sqliteWrapError(clear_err,
                               "sqliteBindParams.clear",
                               { "statementId": stmt.id } as any);
    }

    var i: int = 0;
    while (i < len(params)) {
        var bind_err = sqliteBindParam(stmt, i + 1, params[i]);
        if (bind_err != nil) {
            return sqliteWrapError(bind_err,
                                   "sqliteBindParams.bind",
                                   {
                                       "statementId": stmt.id,
                                       "index": i + 1
                                   } as any);
        }
        i = i + 1;
    }
    return nil;
}

func sqliteExecPrepared(stmt: SqliteStatement, params: array<any>): Error? {
    var reset_err = sqliteResetStmt(stmt);
    if (reset_err != nil) {
        return sqliteWrapError(reset_err,
                               "sqliteExecPrepared.reset",
                               { "statementId": stmt.id } as any);
    }

    var bind_err = sqliteBindParams(stmt, params);
    if (bind_err != nil) {
        return sqliteWrapError(bind_err,
                               "sqliteExecPrepared.bind",
                               { "statementId": stmt.id } as any);
    }

    var stepped = sqliteStepRow(stmt);
    if (stepped.1 != nil) {
        return sqliteWrapError(stepped.1,
                               "sqliteExecPrepared.step",
                               { "statementId": stmt.id } as any);
    }
    if (stepped.0 != nil) {
        return sqliteError(ERR_PARSE,
                           "sqliteExecPrepared expected no row result",
                           "sqliteExecPrepared.stepResult",
                           { "statementId": stmt.id } as any);
    }
    return nil;
}

func sqliteExecPreparedMany(stmt: SqliteStatement, rows: array<array<any>>): (int, Error?) {
    var count: int = 0;
    var i: int = 0;
    while (i < len(rows)) {
        var exec_err = sqliteExecPrepared(stmt, rows[i]);
        if (exec_err != nil) {
            return (count,
                    sqliteWrapError(exec_err,
                                    "sqliteExecPreparedMany.exec",
                                    {
                                        "statementId": stmt.id,
                                        "index": i
                                    } as any));
        }
        count = count + 1;
        i = i + 1;
    }
    return (count, nil);
}

func sqliteQueryPreparedAll(stmt: SqliteStatement, params: array<any>): (array<map<string, any>>, Error?) {
    var out: array<map<string, any>> = [];

    var reset_err = sqliteResetStmt(stmt);
    if (reset_err != nil) {
        return (out,
                sqliteWrapError(reset_err,
                                "sqliteQueryPreparedAll.reset",
                                { "statementId": stmt.id } as any));
    }

    var bind_err = sqliteBindParams(stmt, params);
    if (bind_err != nil) {
        return (out,
                sqliteWrapError(bind_err,
                                "sqliteQueryPreparedAll.bind",
                                { "statementId": stmt.id } as any));
    }

    while (true) {
        var stepped = sqliteStepRow(stmt);
        if (stepped.1 != nil) {
            return (out,
                    sqliteWrapError(stepped.1,
                                    "sqliteQueryPreparedAll.step",
                                    { "statementId": stmt.id } as any));
        }
        if (stepped.0 == nil) {
            break;
        }
        push(out, stepped.0 as map<string, any>);
    }

    return (out, nil);
}

func sqliteQueryPreparedOne(stmt: SqliteStatement, params: array<any>): (map<string, any>?, Error?) {
    var all = sqliteQueryPreparedAll(stmt, params);
    if (all.1 != nil) {
        return (nil, all.1);
    }
    if (len(all.0) == 0) {
        return (nil, nil);
    }
    return (all.0[0], nil);
}

func sqliteQueryPreparedAllAs(stmt: SqliteStatement, params: array<any>, schema: any): (array<any>, Error?) {
    var out: array<any> = [];
    var rows = sqliteQueryPreparedAll(stmt, params);
    if (rows.1 != nil) {
        return (out, rows.1);
    }

    var i: int = 0;
    while (i < len(rows.0)) {
        var decoded = jsonDecode(rows.0[i] as any, schema);
        if (decoded.1 != nil) {
            return (out,
                    sqliteWrapError(decoded.1,
                                    "sqliteQueryPreparedAllAs.decode",
                                    {
                                        "statementId": stmt.id,
                                        "index": i
                                    } as any));
        }
        push(out, decoded.0);
        i = i + 1;
    }

    return (out, nil);
}

func sqliteQueryPreparedOneAs(stmt: SqliteStatement, params: array<any>, schema: any): (any, Error?) {
    var row = sqliteQueryPreparedOne(stmt, params);
    if (row.1 != nil) {
        return (nil, row.1);
    }
    if (row.0 == nil) {
        return (nil, nil);
    }

    var decoded = jsonDecode(row.0 as any, schema);
    if (decoded.1 != nil) {
        return (nil,
                sqliteWrapError(decoded.1,
                                "sqliteQueryPreparedOneAs.decode",
                                { "statementId": stmt.id } as any));
    }
    return (decoded.0, nil);
}

func sqliteStepRow(stmt: SqliteStatement): (map<string, any>?, Error?) {
    var stepped = sqliteStep(stmt.id);
    if (stepped.1 != nil) {
        return (nil,
                sqliteWrapError(stepped.1,
                                "sqliteStepRow",
                                {
                                    "statementId": stmt.id,
                                    "dbId": stmt.db.id
                                } as any));
    }
    if (stepped.0 == nil) {
        return (nil, nil);
    }
    if (typeOf(stepped.0) != "map") {
        return (nil,
                sqliteError(ERR_PARSE,
                            "sqliteStep row must be map or nil",
                            "sqliteStepRow.type",
                            stepped.0));
    }
    return (stepped.0 as map<string, any>, nil);
}

func sqliteFinalizeStmt(stmt: SqliteStatement): Error? {
    var finalized = sqliteFinalize(stmt.id);
    if (finalized.1 != nil) {
        return sqliteWrapError(finalized.1,
                               "sqliteFinalizeStmt",
                               {
                                   "statementId": stmt.id,
                                   "dbId": stmt.db.id
                               } as any);
    }
    if (!finalized.0) {
        return sqliteError(ERR_IO,
                           "sqliteFinalize returned false",
                           "sqliteFinalizeStmt",
                           { "statementId": stmt.id } as any);
    }
    return nil;
}

func sqliteQueryAllAs(db: SqliteDb, sql: string, schema: any): (array<any>, Error?) {
    var out: array<any> = [];
    var rows = sqliteQueryAll(db, sql);
    if (rows.1 != nil) {
        return (out, rows.1);
    }

    var i: int = 0;
    while (i < len(rows.0)) {
        var decoded = jsonDecode(rows.0[i] as any, schema);
        if (decoded.1 != nil) {
            return (out,
                    sqliteWrapError(decoded.1,
                                    "sqliteQueryAllAs.decode",
                                    {
                                        "index": i,
                                        "sql": sql
                                    } as any));
        }
        push(out, decoded.0);
        i = i + 1;
    }

    return (out, nil);
}

func sqliteQueryOneAs(db: SqliteDb, sql: string, schema: any): (any, Error?) {
    var row = sqliteQueryOne(db, sql);
    if (row.1 != nil) {
        return (nil, row.1);
    }
    if (row.0 == nil) {
        return (nil, nil);
    }

    var decoded = jsonDecode(row.0 as any, schema);
    if (decoded.1 != nil) {
        return (nil,
                sqliteWrapError(decoded.1,
                                "sqliteQueryOneAs.decode",
                                { "sql": sql } as any));
    }
    return (decoded.0, nil);
}
