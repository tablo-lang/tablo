}
func tomlKeyNeedsQuotes(key: string): bool {
    if (key == "") {
        return true;
    }
    var i: int = 0;
    while (i < len(key)) {
        if (!tomlIsBareKeyChar(substring(key, i, 1))) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func tomlEscapeString(input: string): string {
    var out: string = "";
    var i: int = 0;
    while (i < len(input)) {
        var ch: string = substring(input, i, 1);
        if (ch == "\\") {
            out = out + "\\\\";
        } else if (ch == "\"") {
            out = out + "\\\"";
        } else if (ch == "\n") {
            out = out + "\\n";
        } else if (ch == "\r") {
            out = out + "\\r";
        } else if (ch == "\t") {
            out = out + "\\t";
        } else {
            out = out + ch;
        }
        i = i + 1;
    }
    return out;
}

func tomlFormatKey(key: string): string {
    if (!tomlKeyNeedsQuotes(key)) {
        return key;
    }
    return "\"" + tomlEscapeString(key) + "\"";
}

func tomlFormatPath(path: array<string>): string {
    var out: string = "";
    var i: int = 0;
    while (i < len(path)) {
        if (i > 0) {
            out = out + ".";
        }
        out = out + tomlFormatKey(path[i]);
        i = i + 1;
    }
    return out;
}

func tomlStringifyArray(items: array<any>, depth: int): (string, Error?) {
    var out: string = "[";
    var i: int = 0;
    foreach (value_any in items) {
        if (i > 0) {
            out = out + ", ";
        }
        var value_r = tomlStringifyValue(value_any, depth + 1);
        if (value_r.1 != nil) {
            return ("", value_r.1);
        }
        out = out + value_r.0;
        i = i + 1;
    }
    out = out + "]";
    return (out, nil);
}

func tomlStringifyValue(value: any, depth: int): (string, Error?) {
    if (depth > 64) {
        return ("", tomlError(ERR_LIMIT, "TOML stringify nesting depth exceeded", "toml.stringify.depth", -1, 1, depth));
    }

    if (value == nil) {
        return ("", tomlError(ERR_INVALID_ARGUMENT, "TOML stringify does not support nil", "toml.stringify.value.nil", -1, 1, nil));
    }

    var t: string = typeOf(value);
    if (t == "string") {
        return ("\"" + tomlEscapeString(value as string) + "\"", nil);
    }
    if (t == "int") {
        return (str(value as int), nil);
    }
    if (t == "bool") {
        if (value as bool) {
            return ("true", nil);
        }
        return ("false", nil);
    }
    if (t == "array") {
        return tomlStringifyArray(value as array<any>, depth + 1);
    }

    return ("",
            tomlError(ERR_INVALID_ARGUMENT,
                      "unsupported TOML value type during stringify",
                      "toml.stringify.value.type",
                      -1,
                      1,
                      t));
}

func tomlStringifyTableInternal(table: map<string, any>,
                                path: array<string>,
                                depth: int): (string, Error?) {
    if (depth > 64) {
        return ("", tomlError(ERR_LIMIT, "TOML stringify nesting depth exceeded", "toml.stringify.table.depth", -1, 1, depth));
    }

    var value_lines: array<string> = [];
    var child_keys: array<string> = [];
    foreach (key_any in keys(table)) {
        if (key_any == nil || typeOf(key_any) != "string") {
            return ("",
                    tomlError(ERR_INVALID_ARGUMENT,
                              "table key must be string",
                              "toml.stringify.key.type",
                              -1,
                              1,
                              key_any));
        }

        var key: string = key_any as string;
        var value: any = mapGetString(table, key);
        if (value == nil) {
            return ("",
                    tomlError(ERR_INVALID_ARGUMENT,
                              "TOML stringify does not support nil table values",
                              "toml.stringify.value.nil",
                              -1,
                              1,
                              key));
        }

        if (typeOf(value) == "map") {
            push(child_keys, key);
            continue;
        }

        var encoded = tomlStringifyValue(value, depth + 1);
        if (encoded.1 != nil) {
            return ("", encoded.1);
        }

        push(value_lines, tomlFormatKey(key) + " = " + encoded.0);
    }

    var out: string = "";
    if (len(path) > 0) {
        out = out + "[" + tomlFormatPath(path) + "]\n";
    }

    var i: int = 0;
    while (i < len(value_lines)) {
        out = out + value_lines[i] + "\n";
        i = i + 1;
    }

    var child_idx: int = 0;
    while (child_idx < len(child_keys)) {
        var child_key: string = child_keys[child_idx];
        var child_any: any = mapGetString(table, child_key);
        if (typeOf(child_any) != "map") {
            return ("",
                    tomlError(ERR_INVALID_ARGUMENT,
                              "expected child table",
                              "toml.stringify.child.type",
                              -1,
                              1,
                              child_key));
        }

        if (out != "" && !endsWith(out, "\n\n")) {
            out = out + "\n";
        }

        var child_path: array<string> = tomlCopyPath(path);
        push(child_path, child_key);
        var child_block = tomlStringifyTableInternal(child_any as map<string, any>, child_path, depth + 1);
        if (child_block.1 != nil) {
            return ("", child_block.1);
        }
        out = out + child_block.0;

        child_idx = child_idx + 1;
    }

    return (out, nil);
}

func tomlStringify(doc: map<string, any>): (string, Error?) {
    var encoded = tomlStringifyTableInternal(doc, [], 0);
    if (encoded.1 != nil) {
        return ("", encoded.1);
    }
    var out: string = encoded.0;
    while (endsWith(out, "\n")) {
        out = substring(out, 0, len(out) - 1);
    }
    return (out, nil);
}
