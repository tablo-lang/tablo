func cryptoSessionTokenIssueText(secret_text: string,
                                 config: CryptoSessionTokenConfig,
                                 subject: string,
                                 extra_claims: map<string, any>,
                                 now_ms: int): (CryptoSessionTokenIssueResult, Error?) {
