                                                                 next_claims.0,
                                                                 issued_at_ms,
                                                                 expires_at_ms);
        if (sealed.2 != nil) {
            return (empty, wrapError(sealed.2, "cryptoSessionTokenIssueText"));
        }
        token = sealed.0;
        jwt_id = sealed.1;
    }

    var issued: CryptoSessionTokenIssueResult = {
        token: token,
        jwtId: jwt_id,
        subject: subject,
        issuedAtMillis: issued_at_ms,
        expiresAtMillis: expires_at_ms,
        keyId: config.keyId
