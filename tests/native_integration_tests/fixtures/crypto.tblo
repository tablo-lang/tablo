func cryptoConstantTimeBytesEqual(left: bytes, right: bytes): (bool, Error?) {
    var equal = constantTimeBytesEqual(left, right);
    if (equal.1 != nil) {
        return (false, wrapError(equal.1, "cryptoConstantTimeBytesEqual"));
    }
    return (equal.0, nil);
}

func cryptoConstantTimeTextEqual(left: string, right: string): (bool, Error?) {
    var left_r = stringToBytes(left);
    if (left_r.1 != nil) {
        return (false, wrapError(left_r.1, "cryptoConstantTimeTextEqual"));
    }

    var right_r = stringToBytes(right);
    if (right_r.1 != nil) {
        return (false, wrapError(right_r.1, "cryptoConstantTimeTextEqual"));
    }

    return cryptoConstantTimeBytesEqual(left_r.0, right_r.0);
}

func cryptoHmacSha256VerifyBytes(key: bytes, data: bytes, expected_tag: bytes): (bool, Error?) {
    var actual = cryptoHmacSha256Bytes(key, data);
