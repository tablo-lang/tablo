                                             revocations: CryptoSignedJsonClaimsRevocationStore,
                                             access_claims: map<string, any>,
                                             refresh_claim_overrides: map<string, any>): (CryptoSessionTokenPairRotateResult, Error?) {
    var result: CryptoSessionTokenPairRotateResult = cryptoEmptySessionTokenPairRotateResult(revocations);
    var verified = cryptoSessionTokenPairVerifyRefreshText(refresh_secret_text,
                                                           config,
                                                           refresh_token,
                                                           now_ms,
                                                           revocations);
    if (verified.1 != nil) {
        return (result, wrapError(verified.1, "cryptoSessionTokenPairRotateRefreshText"));
    }

    result.expired = verified.0.expired;
    result.revoked = verified.0.revoked;
    result.sessionId = verified.0.sessionId;
    if (verified.0.tokenKind != nil &&
        (verified.0.tokenKind as string) == CRYPTO_SESSION_TOKEN_KIND_REFRESH) {
        result.previousRefreshJwtId = verified.0.jwtId;
    }
    result.revocations = verified.0.revocations;

    if (!verified.0.ok || verified.0.expired || verified.0.revoked) {
        return (result, nil);
    }

    var inherited_refresh_claims = cryptoSessionTokenPairStripManagedClaims(verified.0.claims.claims);
    var refresh_next_claims = cryptoSessionTokenPairMergeClaims(inherited_refresh_claims,
                                                                refresh_claim_overrides);

    var revoke_old_refresh = cryptoSessionTokenRevokeVerified(verified.0.revocations, verified.0);
    if (revoke_old_refresh.1 != nil) {
        result.revocations = revoke_old_refresh.0;
        return (result, wrapError(revoke_old_refresh.1, "cryptoSessionTokenPairRotateRefreshText"));
    }

    result.revocations = revoke_old_refresh.0;
    var replacement_pair = cryptoSessionTokenPairIssueWithSessionIdText(access_secret_text,
                                                                        refresh_secret_text,
                                                                        config,
                                                                        verified.0.sessionId as string,
                                                                        verified.0.subject as string,
                                                                        access_claims,
                                                                        refresh_next_claims,
                                                                        now_ms,
                                                                        "cryptoSessionTokenPairRotateRefreshText");
    if (replacement_pair.1 != nil) {
        return (result, wrapError(replacement_pair.1, "cryptoSessionTokenPairRotateRefreshText"));
    }

    result.ok = true;
    result.pair = replacement_pair.0;
    result.sessionId = replacement_pair.0.sessionId;
    return (result, nil);
}

func cryptoSessionTokenPairRotateRefreshTextNow(access_secret_text: string,
                                                refresh_secret_text: string,
                                                config: CryptoSessionTokenPairConfig,
                                                refresh_token: string,
                                                revocations: CryptoSignedJsonClaimsRevocationStore,
                                                access_claims: map<string, any>,
                                                refresh_claim_overrides: map<string, any>): (CryptoSessionTokenPairRotateResult, Error?) {
    return cryptoSessionTokenPairRotateRefreshText(access_secret_text,
                                                   refresh_secret_text,
                                                   config,
                                                   refresh_token,
                                                   timeNowMillis(),
                                                   revocations,
                                                   access_claims,
                                                   refresh_claim_overrides);
}
