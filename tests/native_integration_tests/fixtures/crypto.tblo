        var sealed_with_key_id = cryptoSignedJsonClaimsSealTextWithKeyIdAndAutoJwtId(secret_text,
                                                                                     config.keyId as string,
                                                                                     next_claims.0,
                                                                                     issued_at_ms,
                                                                                     expires_at_ms);
