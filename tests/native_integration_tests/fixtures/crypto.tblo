func cryptoSignedJsonClaimsDecodeUnverified(token: string): (CryptoSignedJsonClaimsEnvelope, Error?) {
    var decoded = cryptoSignedTokenDecode(token);
    if (decoded.1 != nil) {
        return (cryptoEmptySignedJsonClaimsEnvelope(),
                wrapError(decoded.1, "cryptoSignedJsonClaimsDecodeUnverified"));
    }

    var claims = cryptoSignedJsonClaimsFromTokenEnvelope(decoded.0,
                                                         "cryptoSignedJsonClaimsDecodeUnverified");
    if (claims.1 != nil) {
        return (cryptoEmptySignedJsonClaimsEnvelope(),
                wrapError(claims.1, "cryptoSignedJsonClaimsDecodeUnverified"));
    }
    return (claims.0, nil);
}

func cryptoSignedJsonClaimsValidateRegistered(claims: CryptoSignedJsonClaimsEnvelope,
                                              policy: CryptoSignedJsonClaimsValidationPolicy,
                                              now_ms: int): (bool, Error?) {
    var policy_err = cryptoValidateSignedJsonClaimsValidationPolicy(policy,
                                                                    "cryptoSignedJsonClaimsValidateRegistered");
    if (policy_err != nil) {
        return (false, wrapError(policy_err, "cryptoSignedJsonClaimsValidateRegistered"));
    }

    var issuer_any: any = mapGetString(claims.claims, "iss");
    if (issuer_any != nil) {
        if (typeOf(issuer_any) != "string") {
            return (false, nil);
        }

        var issuer: string = issuer_any as string;
        if (issuer == "") {
            return (false, nil);
        }

        if (policy.issuer != nil && issuer != (policy.issuer as string)) {
            return (false, nil);
        }
    } else if (policy.requireIssuer || policy.issuer != nil) {
        return (false, nil);
    }

    var audience_any: any = mapGetString(claims.claims, "aud");
    if (audience_any != nil) {
        if (!cryptoSignedJsonClaimsAudienceMatches(audience_any, policy.audience)) {
            return (false, nil);
        }
    } else if (policy.requireAudience || policy.audience != nil) {
        return (false, nil);
    }

    var not_before_any: any = mapGetString(claims.claims, "nbf");
    if (not_before_any != nil) {
        if (typeOf(not_before_any) != "int") {
            return (false, nil);
        }

        var not_before_ms: int = not_before_any as int;
        if (not_before_ms < 0) {
            return (false, nil);
        }

