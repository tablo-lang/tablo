    }

    var detached_parts = cryptoSplitAesGcmSealed(sealed.0);
    if (detached_parts.2 != nil) {
        return (cryptoEmptyBytes(), cryptoEmptyBytes(), wrapError(detached_parts.2, "cryptoAesGcmSealDetached"));
    }
    return (detached_parts.0, detached_parts.1, nil);
}

