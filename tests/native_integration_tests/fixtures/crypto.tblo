// Cryptographic hash, MAC, key-derivation, and authenticated-encryption helpers.
// Focused on practical application workflows rather than full protocol suites.

import "encoding.tblo";
import "random.tblo";
import "uuid.tblo";

const CRYPTO_PASSWORD_AES_GCM_ENVELOPE_VERSION: string = "v1";
const CRYPTO_PASSWORD_AES_GCM_SALT_BYTES: int = 16;
const CRYPTO_PASSWORD_AES_GCM_NONCE_BYTES: int = 12;
const CRYPTO_PASSWORD_AES_GCM_KEY_BYTES: int = 32;
const CRYPTO_PASSWORD_AES_GCM_DEFAULT_ITERATIONS: int = 600000;
const CRYPTO_PASSWORD_HASH_SCHEME: string = "pbkdf2-sha256";
const CRYPTO_PASSWORD_HASH_VERSION: string = "v1";
const CRYPTO_PASSWORD_HASH_SALT_BYTES: int = 16;
const CRYPTO_PASSWORD_HASH_BYTES: int = 32;
const CRYPTO_PASSWORD_HASH_DEFAULT_ITERATIONS: int = 600000;
const CRYPTO_SIGNED_TOKEN_VERSION: string = "v1";
const CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM: string = "sid";
const CRYPTO_SESSION_TOKEN_KIND_CLAIM: string = "tokenKind";
const CRYPTO_SESSION_TOKEN_KIND_ACCESS: string = "access";
const CRYPTO_SESSION_TOKEN_KIND_REFRESH: string = "refresh";

record CryptoPasswordAesGcmEnvelope {
    version: string,
    iterations: int,
    salt: bytes,
    nonce: bytes,
    sealed: bytes
}

record CryptoPasswordHash {
    scheme: string,
    version: string,
    iterations: int,
    salt: bytes,
    digest: bytes
}

record CryptoSignedTokenEnvelope {
    version: string,
    issuedAtMillis: int,
    expiresAtMillis: int,
    payload: bytes
}

record CryptoSignedJsonClaimsEnvelope {
    version: string,
    issuedAtMillis: int,
    expiresAtMillis: int,
    keyId: string?,
    claims: map<string, any>
}

record CryptoSignedJsonClaimsValidationPolicy {
    issuer: string?,
    audience: string?,
    requireIssuer: bool,
    requireAudience: bool,
    requireNotBefore: bool,
    requireJti: bool,
    clockSkewMillis: int
}

record CryptoSignedJsonClaimsRevocationStore {
    entries: map<string, any>,
    nextExpiryMillis: int
}

record CryptoSessionTokenConfig {
    issuer: string?,
    audience: string?,
    keyId: string?,
    ttlMillis: int,
    clockSkewMillis: int,
    includeNotBefore: bool
}

record CryptoSessionTokenIssueResult {
    token: string,
    jwtId: string,
    subject: string,
    issuedAtMillis: int,
    expiresAtMillis: int,
    keyId: string?
}

record CryptoSessionTokenVerifyResult {
    ok: bool,
    expired: bool,
    revoked: bool,
    keyId: string?,
    jwtId: string?,
    subject: string?,
    sessionId: string?,
    tokenKind: string?,
    claims: CryptoSignedJsonClaimsEnvelope,
    revocations: CryptoSignedJsonClaimsRevocationStore
}

record CryptoSessionTokenPairConfig {
    access: CryptoSessionTokenConfig,
    refresh: CryptoSessionTokenConfig
}

record CryptoSessionTokenPairIssueResult {
    sessionId: string,
    access: CryptoSessionTokenIssueResult,
    refresh: CryptoSessionTokenIssueResult
}

record CryptoSessionTokenPairRotateResult {
    ok: bool,
    expired: bool,
    revoked: bool,
    sessionId: string?,
    previousRefreshJwtId: string?,
    pair: CryptoSessionTokenPairIssueResult,
    revocations: CryptoSignedJsonClaimsRevocationStore
}

func cryptoEmptyBytes(): bytes {
    return bytesWithSize(0, 0).0;
}

func cryptoEmptyPasswordAesGcmEnvelope(): CryptoPasswordAesGcmEnvelope {
    return {
        version: "",
        iterations: 0,
        salt: cryptoEmptyBytes(),
        nonce: cryptoEmptyBytes(),
        sealed: cryptoEmptyBytes()
    };
}

func cryptoEmptyPasswordHash(): CryptoPasswordHash {
    return {
        scheme: "",
        version: "",
        iterations: 0,
        salt: cryptoEmptyBytes(),
        digest: cryptoEmptyBytes()
    };
}

func cryptoEmptySignedTokenEnvelope(): CryptoSignedTokenEnvelope {
    return {
        version: "",
        issuedAtMillis: 0,
        expiresAtMillis: 0,
        payload: cryptoEmptyBytes()
    };
}

func cryptoEmptySignedJsonClaimsEnvelope(): CryptoSignedJsonClaimsEnvelope {
    return {
        version: "",
        issuedAtMillis: 0,
        expiresAtMillis: 0,
        keyId: nil,
        claims: {}
    };
}

func cryptoSignedJsonClaimsDefaultValidationPolicy(): CryptoSignedJsonClaimsValidationPolicy {
    return {
        issuer: nil,
        audience: nil,
        requireIssuer: false,
        requireAudience: false,
        requireNotBefore: false,
        requireJti: false,
        clockSkewMillis: 0
    };
}

func cryptoSignedJsonClaimsRevocationStoreNew(): CryptoSignedJsonClaimsRevocationStore {
    return {
        entries: {},
        nextExpiryMillis: 0
    };
}

func cryptoSessionTokenDefaultConfig(): CryptoSessionTokenConfig {
    return {
        issuer: nil,
        audience: nil,
        keyId: nil,
        ttlMillis: 900000,
        clockSkewMillis: 30000,
        includeNotBefore: true
    };
}

func cryptoEmptySessionTokenIssueResult(): CryptoSessionTokenIssueResult {
    return {
        token: "",
        jwtId: "",
        subject: "",
        issuedAtMillis: 0,
        expiresAtMillis: 0,
        keyId: nil
    };
}

func cryptoEmptySessionTokenVerifyResult(revocations: CryptoSignedJsonClaimsRevocationStore): CryptoSessionTokenVerifyResult {
    return {
        ok: false,
        expired: false,
        revoked: false,
        keyId: nil,
        jwtId: nil,
        subject: nil,
        sessionId: nil,
        tokenKind: nil,
        claims: cryptoEmptySignedJsonClaimsEnvelope(),
        revocations: revocations
    };
}

func cryptoSessionTokenPairDefaultConfig(): CryptoSessionTokenPairConfig {
    var access: CryptoSessionTokenConfig = cryptoSessionTokenDefaultConfig();
    var refresh: CryptoSessionTokenConfig = cryptoSessionTokenDefaultConfig();
    refresh.ttlMillis = 2592000000;
    return {
        access: access,
        refresh: refresh
    };
}

func cryptoEmptySessionTokenPairIssueResult(): CryptoSessionTokenPairIssueResult {
    return {
        sessionId: "",
        access: cryptoEmptySessionTokenIssueResult(),
        refresh: cryptoEmptySessionTokenIssueResult()
    };
}

func cryptoEmptySessionTokenPairRotateResult(revocations: CryptoSignedJsonClaimsRevocationStore): CryptoSessionTokenPairRotateResult {
    return {
        ok: false,
        expired: false,
        revoked: false,
        sessionId: nil,
        previousRefreshJwtId: nil,
        pair: cryptoEmptySessionTokenPairIssueResult(),
        revocations: revocations
    };
}

func cryptoStdError(code: int, message: string, data: any): Error {
    var err: Error = { code: code, message: message, data: data };
    return err;
}

func cryptoError(code: int, message: string, context: string, detail: any): Error {
    var data: map<string, any> = {
        "context": context,
        "detail": detail
    };
    return cryptoStdError(code, message, data);
}

func cryptoIsAsciiDigits(text: string): bool {
    if (len(text) == 0) {
        return false;
    }

    var i: int = 0;
    while (i < len(text)) {
        if (find("0123456789", substring(text, i, 1)) < 0) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

func cryptoValidatePasswordEnvelopeIterations(iterations: int, context: string): Error? {
    if (iterations < 1) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "iterations must be >= 1",
                           context,
                           iterations);
    }
    return nil;
}

func cryptoValidatePasswordEnvelopeShape(envelope: CryptoPasswordAesGcmEnvelope,
                                         context: string): Error? {
    if (envelope.version != CRYPTO_PASSWORD_AES_GCM_ENVELOPE_VERSION) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "unsupported envelope version",
                           context,
                           envelope.version);
    }

    var iterations_err = cryptoValidatePasswordEnvelopeIterations(envelope.iterations, context);
    if (iterations_err != nil) {
        return iterations_err;
    }

    if (len(envelope.salt) != CRYPTO_PASSWORD_AES_GCM_SALT_BYTES) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "AES-GCM password envelope salt must be 16 bytes",
                           context,
                           len(envelope.salt));
    }

    if (len(envelope.nonce) != CRYPTO_PASSWORD_AES_GCM_NONCE_BYTES) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "AES-GCM password envelope nonce must be 12 bytes",
                           context,
                           len(envelope.nonce));
    }

    if (len(envelope.sealed) < 16) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "AES-GCM password envelope sealed payload must include a 16-byte tag",
                           context,
                           len(envelope.sealed));
    }

    return nil;
}

func cryptoValidatePasswordHashIterations(iterations: int, context: string): Error? {
    if (iterations < 1) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "iterations must be >= 1",
                           context,
                           iterations);
    }
    return nil;
}

func cryptoValidatePasswordHashShape(hash: CryptoPasswordHash, context: string): Error? {
    if (hash.scheme != CRYPTO_PASSWORD_HASH_SCHEME) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "unsupported password hash scheme",
                           context,
                           hash.scheme);
    }

    if (hash.version != CRYPTO_PASSWORD_HASH_VERSION) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "unsupported password hash version",
                           context,
                           hash.version);
    }

    var iterations_err = cryptoValidatePasswordHashIterations(hash.iterations, context);
    if (iterations_err != nil) {
        return iterations_err;
    }

    if (len(hash.salt) != CRYPTO_PASSWORD_HASH_SALT_BYTES) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "password hash salt must be 16 bytes",
                           context,
                           len(hash.salt));
    }

    if (len(hash.digest) != CRYPTO_PASSWORD_HASH_BYTES) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "password hash digest must be 32 bytes",
                           context,
                           len(hash.digest));
    }

    return nil;
}

func cryptoValidateSignedTokenTimes(issued_at_ms: int, expires_at_ms: int, context: string): Error? {
    if (issued_at_ms < 0) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "issuedAtMillis must be >= 0",
                           context,
                           issued_at_ms);
    }

    if (expires_at_ms <= issued_at_ms) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "expiresAtMillis must be greater than issuedAtMillis",
                           context,
                           {
                               "issuedAtMillis": issued_at_ms,
                               "expiresAtMillis": expires_at_ms
                           });
    }

    return nil;
}

func cryptoValidateSignedTokenTtl(ttl_ms: int, context: string): Error? {
    if (ttl_ms < 1) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "ttlMs must be >= 1",
                           context,
                           ttl_ms);
    }
    return nil;
}

func cryptoValidateSignedTokenShape(token: CryptoSignedTokenEnvelope, context: string): Error? {
    if (token.version != CRYPTO_SIGNED_TOKEN_VERSION) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "unsupported signed token version",
                           context,
                           token.version);
    }
    return cryptoValidateSignedTokenTimes(token.issuedAtMillis, token.expiresAtMillis, context);
}

func cryptoValidateSignedJsonClaimsKeyId(key_id: string, context: string): Error? {
    if (key_id == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "keyId must not be empty",
                           context,
                           key_id);
    }
    return nil;
}

func cryptoValidateSignedJsonClaimsValidationPolicy(policy: CryptoSignedJsonClaimsValidationPolicy,
                                                    context: string): Error? {
    if (policy.issuer != nil && (policy.issuer as string) == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "policy issuer must not be empty",
                           context,
                           policy.issuer);
    }

    if (policy.audience != nil && (policy.audience as string) == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "policy audience must not be empty",
                           context,
                           policy.audience);
    }

    if (policy.clockSkewMillis < 0) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "policy clockSkewMillis must be >= 0",
                           context,
                           policy.clockSkewMillis);
    }

    return nil;
}

func cryptoValidateSessionTokenConfig(config: CryptoSessionTokenConfig,
                                      context: string): Error? {
    if (config.issuer != nil && (config.issuer as string) == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "session issuer must not be empty",
                           context,
                           config.issuer);
    }

    if (config.audience != nil && (config.audience as string) == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "session audience must not be empty",
                           context,
                           config.audience);
    }

    if (config.keyId != nil) {
        var key_id_err = cryptoValidateSignedJsonClaimsKeyId(config.keyId as string, context);
        if (key_id_err != nil) {
            return key_id_err;
        }
    }

    if (config.ttlMillis < 1) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "session ttlMillis must be >= 1",
                           context,
                           config.ttlMillis);
    }

    if (config.clockSkewMillis < 0) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "session clockSkewMillis must be >= 0",
                           context,
                           config.clockSkewMillis);
    }

    return nil;
}

func cryptoCloneAnyMap(values: map<string, any>): map<string, any> {
    var out: map<string, any> = {};
    foreach (key_any in keys(values)) {
        if (key_any != nil && typeOf(key_any) == "string") {
            var key: string = key_any as string;
            mapSetString(out, key, mapGetString(values, key));
        }
    }
    return out;
}

func cryptoSignedJsonClaimsNew(): map<string, any> {
    return {};
}

func cryptoValidateSignedJsonClaimNonEmptyString(value: string,
                                                 claim_name: string,
                                                 context: string): Error? {
    if (value == "") {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           claim_name + " claim must not be empty",
                           context,
                           value);
    }
    return nil;
}

func cryptoValidateSignedJsonClaimNotBefore(not_before_ms: int, context: string): Error? {
    if (not_before_ms < 0) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "nbf claim must be >= 0",
                           context,
                           not_before_ms);
    }
    return nil;
}

func cryptoValidateSignedJsonClaimAudiences(audiences: array<string>,
                                            context: string): Error? {
    if (len(audiences) == 0) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "aud claim array must not be empty",
                           context,
                           audiences);
    }

    var i: int = 0;
    while (i < len(audiences)) {
        var audience: string = audiences[i];
        var audience_err = cryptoValidateSignedJsonClaimNonEmptyString(audience, "aud", context);
        if (audience_err != nil) {
            return audience_err;
        }
        i = i + 1;
    }

    return nil;
}

func cryptoValidateSignedJsonClaimExpiryMillis(expires_at_ms: int,
                                               context: string): Error? {
    if (expires_at_ms < 1) {
        return cryptoError(ERR_INVALID_ARGUMENT,
                           "expiresAtMillis must be >= 1",
                           context,
                           expires_at_ms);
    }
    return nil;
}

func cryptoNormalizeWallTimeMillis(now_ms: int): int {
    if (now_ms < 0) {
        return 0;
    }
    return now_ms;
}

func cryptoSignedJsonClaimsExtractJwtId(claims: CryptoSignedJsonClaimsEnvelope,
                                        require_present: bool,
                                        context: string): (string?, Error?) {
    var jwt_id_any: any = mapGetString(claims.claims, "jti");
    if (jwt_id_any == nil) {
        if (require_present) {
            return (nil,
                    cryptoError(ERR_INVALID_ARGUMENT,
                                "claims must contain string field 'jti'",
                                context,
                                nil));
        }
        return (nil, nil);
    }

    if (typeOf(jwt_id_any) != "string") {
        return (nil,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "claims field 'jti' must be string",
                            context,
                            typeOf(jwt_id_any)));
    }

    var jwt_id: string = jwt_id_any as string;
    var jwt_id_err = cryptoValidateSignedJsonClaimNonEmptyString(jwt_id, "jti", context);
    if (jwt_id_err != nil) {
        return (nil, jwt_id_err);
    }

    return (jwt_id, nil);
}

func cryptoSignedJsonClaimsSetSubject(claims: map<string, any>,
                                      subject: string): (map<string, any>, Error?) {
    var subject_err = cryptoValidateSignedJsonClaimNonEmptyString(subject,
                                                                  "sub",
                                                                  "cryptoSignedJsonClaimsSetSubject");
    if (subject_err != nil) {
        return (claims, subject_err);
    }

    mapSetString(claims, "sub", subject as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsSetIssuer(claims: map<string, any>,
                                     issuer: string): (map<string, any>, Error?) {
    var issuer_err = cryptoValidateSignedJsonClaimNonEmptyString(issuer,
                                                                 "iss",
                                                                 "cryptoSignedJsonClaimsSetIssuer");
    if (issuer_err != nil) {
        return (claims, issuer_err);
    }

    mapSetString(claims, "iss", issuer as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsSetAudience(claims: map<string, any>,
                                       audience: string): (map<string, any>, Error?) {
    var audience_err = cryptoValidateSignedJsonClaimNonEmptyString(audience,
                                                                   "aud",
                                                                   "cryptoSignedJsonClaimsSetAudience");
    if (audience_err != nil) {
        return (claims, audience_err);
    }

    mapSetString(claims, "aud", audience as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsSetAudiences(claims: map<string, any>,
                                        audiences: array<string>): (map<string, any>, Error?) {
    var audience_err = cryptoValidateSignedJsonClaimAudiences(audiences,
                                                              "cryptoSignedJsonClaimsSetAudiences");
    if (audience_err != nil) {
        return (claims, audience_err);
    }

    var audience_values: array<any> = [];
    var i: int = 0;
    while (i < len(audiences)) {
        push(audience_values, audiences[i] as any);
        i = i + 1;
    }

    mapSetString(claims, "aud", audience_values as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsSetNotBefore(claims: map<string, any>,
                                        not_before_ms: int): (map<string, any>, Error?) {
    var not_before_err = cryptoValidateSignedJsonClaimNotBefore(not_before_ms,
                                                                "cryptoSignedJsonClaimsSetNotBefore");
    if (not_before_err != nil) {
        return (claims, not_before_err);
    }

    mapSetString(claims, "nbf", not_before_ms as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsSetJwtId(claims: map<string, any>,
                                    jwt_id: string): (map<string, any>, Error?) {
    var jwt_id_err = cryptoValidateSignedJsonClaimNonEmptyString(jwt_id,
                                                                 "jti",
                                                                 "cryptoSignedJsonClaimsSetJwtId");
    if (jwt_id_err != nil) {
        return (claims, jwt_id_err);
    }

    mapSetString(claims, "jti", jwt_id as any);
    return (claims, nil);
}

func cryptoSignedJsonClaimsEnsureJwtId(claims: map<string, any>): (map<string, any>, string, Error?) {
    var existing_any: any = mapGetString(claims, "jti");
    if (existing_any != nil) {
        if (typeOf(existing_any) != "string") {
            return (claims,
                    "",
                    cryptoError(ERR_INVALID_ARGUMENT,
                                "claims field 'jti' must be string",
                                "cryptoSignedJsonClaimsEnsureJwtId",
                                typeOf(existing_any)));
        }

        var existing_jti: string = existing_any as string;
        var existing_err = cryptoValidateSignedJsonClaimNonEmptyString(existing_jti,
                                                                       "jti",
                                                                       "cryptoSignedJsonClaimsEnsureJwtId");
        if (existing_err != nil) {
            return (claims, "", existing_err);
        }

        return (claims, existing_jti, nil);
    }

    var generated = uuidV4();
    if (generated.1 != nil) {
        return (claims,
                "",
                wrapError(generated.1, "cryptoSignedJsonClaimsEnsureJwtId"));
    }

    mapSetString(claims, "jti", generated.0 as any);
    return (claims, generated.0, nil);
}

func cryptoSessionTokenOptionalStringClaim(claims: CryptoSignedJsonClaimsEnvelope,
                                           claim_name: string): string? {
    var value_any: any = mapGetString(claims.claims, claim_name);
    if (value_any == nil || typeOf(value_any) != "string") {
        return nil;
    }

    var value: string = value_any as string;
    if (value == "") {
        return nil;
    }
    return value;
}

func cryptoSessionTokenExtractSubject(claims: CryptoSignedJsonClaimsEnvelope,
                                      context: string): (string, Error?) {
    var subject_any: any = mapGetString(claims.claims, "sub");
    if (subject_any == nil || typeOf(subject_any) != "string") {
        return ("",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "claims must contain string field 'sub'",
                            context,
                            subject_any));
    }

    var subject: string = subject_any as string;
    var subject_err = cryptoValidateSignedJsonClaimNonEmptyString(subject, "sub", context);
    if (subject_err != nil) {
        return ("", subject_err);
    }
    return (subject, nil);
}

func cryptoSessionTokenValidationPolicy(config: CryptoSessionTokenConfig,
                                        context: string): (CryptoSignedJsonClaimsValidationPolicy, Error?) {
    var policy: CryptoSignedJsonClaimsValidationPolicy = cryptoSignedJsonClaimsDefaultValidationPolicy();

    var config_err = cryptoValidateSessionTokenConfig(config, context);
    if (config_err != nil) {
        return (policy, config_err);
    }

    policy.issuer = config.issuer;
    policy.audience = config.audience;
    policy.requireIssuer = config.issuer != nil;
    policy.requireAudience = config.audience != nil;
    policy.requireNotBefore = config.includeNotBefore;
    policy.requireJti = true;
    policy.clockSkewMillis = config.clockSkewMillis;
    return (policy, nil);
}

func cryptoValidateSessionTokenPairConfig(config: CryptoSessionTokenPairConfig,
                                          context: string): Error? {
    var access_err = cryptoValidateSessionTokenConfig(config.access, context + ".access");
    if (access_err != nil) {
        return access_err;
    }

    var refresh_err = cryptoValidateSessionTokenConfig(config.refresh, context + ".refresh");
    if (refresh_err != nil) {
        return refresh_err;
    }

    return nil;
}

func cryptoSessionTokenBuildClaims(config: CryptoSessionTokenConfig,
                                   subject: string,
                                   extra_claims: map<string, any>,
                                   issued_at_ms: int,
                                   context: string): (map<string, any>, Error?) {
    var config_err = cryptoValidateSessionTokenConfig(config, context);
    if (config_err != nil) {
        return ({}, config_err);
    }

    var next_claims: map<string, any> = cryptoCloneAnyMap(extra_claims);

    var subject_claims = cryptoSignedJsonClaimsSetSubject(next_claims, subject);
    if (subject_claims.1 != nil) {
        return ({}, subject_claims.1);
    }
    next_claims = subject_claims.0;

    if (config.issuer != nil) {
        var issuer_claims = cryptoSignedJsonClaimsSetIssuer(next_claims, config.issuer as string);
        if (issuer_claims.1 != nil) {
            return ({}, issuer_claims.1);
        }
        next_claims = issuer_claims.0;
    }

    if (config.audience != nil) {
        var audience_claims = cryptoSignedJsonClaimsSetAudience(next_claims, config.audience as string);
        if (audience_claims.1 != nil) {
            return ({}, audience_claims.1);
        }
        next_claims = audience_claims.0;
    }

    if (config.includeNotBefore) {
        var nbf_claims = cryptoSignedJsonClaimsSetNotBefore(next_claims, issued_at_ms);
        if (nbf_claims.1 != nil) {
            return ({}, nbf_claims.1);
        }
        next_claims = nbf_claims.0;
    }

    return (next_claims, nil);
}

func cryptoSessionTokenPairBuildClaims(base_claims: map<string, any>,
                                       session_id: string,
                                       token_kind: string): map<string, any> {
    var next_claims: map<string, any> = cryptoCloneAnyMap(base_claims);
    mapSetString(next_claims, CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM, session_id as any);
    mapSetString(next_claims, CRYPTO_SESSION_TOKEN_KIND_CLAIM, token_kind as any);
    return next_claims;
}

func cryptoSessionTokenExtractSessionId(claims: CryptoSignedJsonClaimsEnvelope,
                                        context: string): (string, Error?) {
    var session_id_any: any = mapGetString(claims.claims, CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM);
    if (session_id_any == nil || typeOf(session_id_any) != "string") {
        return ("",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "claims must contain string field '" + CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM + "'",
                            context,
                            session_id_any));
    }

    var session_id: string = session_id_any as string;
    if (!uuidIsValid(session_id)) {
        return ("",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "session token sid must be a valid UUID",
                            context,
                            session_id));
    }

    return (session_id, nil);
}

func cryptoSessionTokenExtractTokenKind(claims: CryptoSignedJsonClaimsEnvelope,
                                        context: string): (string, Error?) {
    var token_kind_any: any = mapGetString(claims.claims, CRYPTO_SESSION_TOKEN_KIND_CLAIM);
    if (token_kind_any == nil || typeOf(token_kind_any) != "string") {
        return ("",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "claims must contain string field '" + CRYPTO_SESSION_TOKEN_KIND_CLAIM + "'",
                            context,
                            token_kind_any));
    }

    var token_kind: string = token_kind_any as string;
    if (token_kind != CRYPTO_SESSION_TOKEN_KIND_ACCESS &&
        token_kind != CRYPTO_SESSION_TOKEN_KIND_REFRESH) {
        return ("",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "tokenKind must be 'access' or 'refresh'",
                            context,
                            token_kind));
    }

    return (token_kind, nil);
}

func cryptoSessionTokenPairValidateVerifiedKind(verified: CryptoSessionTokenVerifyResult,
                                                expected_kind: string,
                                                context: string): CryptoSessionTokenVerifyResult {
    var next: CryptoSessionTokenVerifyResult = verified;
    next.sessionId = cryptoSessionTokenOptionalStringClaim(verified.claims,
                                                           CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM);
    next.tokenKind = cryptoSessionTokenOptionalStringClaim(verified.claims,
                                                           CRYPTO_SESSION_TOKEN_KIND_CLAIM);

    if (!verified.ok || verified.expired || verified.revoked) {
        return next;
    }

    var session_id_r = cryptoSessionTokenExtractSessionId(verified.claims, context);
    if (session_id_r.1 != nil) {
        next.ok = false;
        next.sessionId = nil;
        return next;
    }
    next.sessionId = session_id_r.0;

    var token_kind_r = cryptoSessionTokenExtractTokenKind(verified.claims, context);
    if (token_kind_r.1 != nil) {
        next.ok = false;
        next.tokenKind = nil;
        return next;
    }

    next.tokenKind = token_kind_r.0;
    if (token_kind_r.0 != expected_kind) {
        next.ok = false;
    }

    return next;
}

func cryptoSessionTokenPairStripManagedClaims(claims: map<string, any>): map<string, any> {
    var next_claims: map<string, any> = cryptoCloneAnyMap(claims);
    mapDeleteString(next_claims, "sub");
    mapDeleteString(next_claims, "iss");
    mapDeleteString(next_claims, "aud");
    mapDeleteString(next_claims, "nbf");
    mapDeleteString(next_claims, "jti");
    mapDeleteString(next_claims, CRYPTO_SESSION_TOKEN_SESSION_ID_CLAIM);
    mapDeleteString(next_claims, CRYPTO_SESSION_TOKEN_KIND_CLAIM);
    return next_claims;
}

func cryptoSessionTokenPairMergeClaims(base_claims: map<string, any>,
                                       override_claims: map<string, any>): map<string, any> {
    var next_claims: map<string, any> = cryptoCloneAnyMap(base_claims);
    foreach (key_any in keys(override_claims)) {
        if (key_any != nil && typeOf(key_any) == "string") {
            var key: string = key_any as string;
            mapSetString(next_claims, key, mapGetString(override_claims, key));
        }
    }
    return next_claims;
}

func cryptoSessionTokenPairIssueWithSessionIdText(access_secret_text: string,
                                                  refresh_secret_text: string,
                                                  config: CryptoSessionTokenPairConfig,
                                                  session_id: string,
                                                  subject: string,
                                                  access_claims: map<string, any>,
                                                  refresh_claims: map<string, any>,
                                                  now_ms: int,
                                                  context: string): (CryptoSessionTokenPairIssueResult, Error?) {
    var empty = cryptoEmptySessionTokenPairIssueResult();
    if (!uuidIsValid(session_id)) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "session token pair sid must be a valid UUID",
                            context,
                            session_id));
    }

    var access_next_claims = cryptoSessionTokenPairBuildClaims(access_claims,
                                                               session_id,
                                                               CRYPTO_SESSION_TOKEN_KIND_ACCESS);
    var refresh_next_claims = cryptoSessionTokenPairBuildClaims(refresh_claims,
                                                                session_id,
                                                                CRYPTO_SESSION_TOKEN_KIND_REFRESH);

    var access_issued = cryptoSessionTokenIssueText(access_secret_text,
                                                    config.access,
                                                    subject,
                                                    access_next_claims,
                                                    now_ms);
    if (access_issued.1 != nil) {
        return (empty, wrapError(access_issued.1, context));
    }

    var refresh_issued = cryptoSessionTokenIssueText(refresh_secret_text,
                                                     config.refresh,
                                                     subject,
                                                     refresh_next_claims,
                                                     now_ms);
    if (refresh_issued.1 != nil) {
        return (empty, wrapError(refresh_issued.1, context));
    }

    var issued: CryptoSessionTokenPairIssueResult = {
        sessionId: session_id,
        access: access_issued.0,
        refresh: refresh_issued.0
    };
    return (issued, nil);
}

func cryptoSignedJsonClaimsRevocationStoreCount(store: CryptoSignedJsonClaimsRevocationStore): int {
    return mapCount(store.entries);
}

func cryptoSignedJsonClaimsRevocationStoreComputeNextExpiry(store: CryptoSignedJsonClaimsRevocationStore): int {
    var next_expiry_ms: int = 0;
    var key_items: array<any> = keys(store.entries);
    foreach (key_any in key_items) {
        if (key_any == nil || typeOf(key_any) != "string") {
            continue;
        }

        var expires_any: any = mapGetString(store.entries, key_any as string);
        if (expires_any == nil || typeOf(expires_any) != "int") {
            continue;
        }

        var expires_at_ms: int = expires_any as int;
        if (expires_at_ms > 0 && (next_expiry_ms == 0 || expires_at_ms < next_expiry_ms)) {
            next_expiry_ms = expires_at_ms;
        }
    }
    return next_expiry_ms;
}

func cryptoSignedJsonClaimsRevocationStorePurgeExpiredAt(store: CryptoSignedJsonClaimsRevocationStore,
                                                         now_ms: int): (CryptoSignedJsonClaimsRevocationStore, int) {
    var normalized_now: int = cryptoNormalizeWallTimeMillis(now_ms);
    if (mapCount(store.entries) == 0) {
        store.nextExpiryMillis = 0;
        return (store, 0);
    }

    if (store.nextExpiryMillis <= 0 || normalized_now < store.nextExpiryMillis) {
        return (store, 0);
    }

    var removed: int = 0;
    var next_expiry_ms: int = 0;
    var key_items: array<any> = keys(store.entries);
    foreach (key_any in key_items) {
        if (key_any == nil || typeOf(key_any) != "string") {
            continue;
        }

        var key: string = key_any as string;
        var expires_any: any = mapGetString(store.entries, key);
        if (expires_any == nil || typeOf(expires_any) != "int") {
            mapDeleteString(store.entries, key);
            removed = removed + 1;
            continue;
        }

        var expires_at_ms: int = expires_any as int;
        if (expires_at_ms <= normalized_now) {
            mapDeleteString(store.entries, key);
            removed = removed + 1;
            continue;
        }

        if (next_expiry_ms == 0 || expires_at_ms < next_expiry_ms) {
            next_expiry_ms = expires_at_ms;
        }
    }

    store.nextExpiryMillis = next_expiry_ms;
    return (store, removed);
}

func cryptoSignedJsonClaimsRevocationStorePurgeExpired(store: CryptoSignedJsonClaimsRevocationStore): (CryptoSignedJsonClaimsRevocationStore, int) {
    return cryptoSignedJsonClaimsRevocationStorePurgeExpiredAt(store, timeNowMillis());
}

func cryptoSignedJsonClaimsRevocationStoreRevokeId(store: CryptoSignedJsonClaimsRevocationStore,
                                                   jwt_id: string,
                                                   expires_at_ms: int): (CryptoSignedJsonClaimsRevocationStore, Error?) {
    var jwt_id_err = cryptoValidateSignedJsonClaimNonEmptyString(jwt_id,
                                                                 "jti",
                                                                 "cryptoSignedJsonClaimsRevocationStoreRevokeId");
    if (jwt_id_err != nil) {
        return (store, jwt_id_err);
    }

    var expires_err = cryptoValidateSignedJsonClaimExpiryMillis(expires_at_ms,
                                                                "cryptoSignedJsonClaimsRevocationStoreRevokeId");
    if (expires_err != nil) {
        return (store, expires_err);
    }

    mapSetString(store.entries, jwt_id, expires_at_ms as any);
    if (store.nextExpiryMillis == 0 || expires_at_ms < store.nextExpiryMillis) {
        store.nextExpiryMillis = expires_at_ms;
    }
    return (store, nil);
}

func cryptoSignedJsonClaimsRevocationStoreRevoke(store: CryptoSignedJsonClaimsRevocationStore,
                                                 claims: CryptoSignedJsonClaimsEnvelope): (CryptoSignedJsonClaimsRevocationStore, Error?) {
    var jwt_id = cryptoSignedJsonClaimsExtractJwtId(claims,
                                                    true,
                                                    "cryptoSignedJsonClaimsRevocationStoreRevoke");
    if (jwt_id.1 != nil) {
        return (store, wrapError(jwt_id.1, "cryptoSignedJsonClaimsRevocationStoreRevoke"));
    }

    return cryptoSignedJsonClaimsRevocationStoreRevokeId(store,
                                                         jwt_id.0 as string,
                                                         claims.expiresAtMillis);
}

func cryptoSignedJsonClaimsRevocationStoreHasJwtIdAt(store: CryptoSignedJsonClaimsRevocationStore,
                                                     jwt_id: string,
                                                     now_ms: int): (CryptoSignedJsonClaimsRevocationStore, bool, Error?) {
    var purged = cryptoSignedJsonClaimsRevocationStorePurgeExpiredAt(store, now_ms);
    var next: CryptoSignedJsonClaimsRevocationStore = purged.0;

    var jwt_id_err = cryptoValidateSignedJsonClaimNonEmptyString(jwt_id,
                                                                 "jti",
                                                                 "cryptoSignedJsonClaimsRevocationStoreHasJwtIdAt");
    if (jwt_id_err != nil) {
        return (next, false, jwt_id_err);
    }

    return (next, mapHasString(next.entries, jwt_id), nil);
}

func cryptoSignedJsonClaimsRevocationStoreHasJwtId(store: CryptoSignedJsonClaimsRevocationStore,
                                                   jwt_id: string): (CryptoSignedJsonClaimsRevocationStore, bool, Error?) {
    return cryptoSignedJsonClaimsRevocationStoreHasJwtIdAt(store, jwt_id, timeNowMillis());
}

func cryptoSignedJsonClaimsRevocationStoreIsRevokedAt(store: CryptoSignedJsonClaimsRevocationStore,
                                                      claims: CryptoSignedJsonClaimsEnvelope,
                                                      now_ms: int): (CryptoSignedJsonClaimsRevocationStore, bool, Error?) {
    var purged = cryptoSignedJsonClaimsRevocationStorePurgeExpiredAt(store, now_ms);
    var next: CryptoSignedJsonClaimsRevocationStore = purged.0;

    var jwt_id = cryptoSignedJsonClaimsExtractJwtId(claims,
                                                    false,
                                                    "cryptoSignedJsonClaimsRevocationStoreIsRevokedAt");
    if (jwt_id.1 != nil) {
        return (next, false, wrapError(jwt_id.1, "cryptoSignedJsonClaimsRevocationStoreIsRevokedAt"));
    }

    if (jwt_id.0 == nil) {
        return (next, false, nil);
    }

    return (next, mapHasString(next.entries, jwt_id.0 as string), nil);
}

func cryptoSignedJsonClaimsRevocationStoreIsRevoked(store: CryptoSignedJsonClaimsRevocationStore,
                                                    claims: CryptoSignedJsonClaimsEnvelope): (CryptoSignedJsonClaimsRevocationStore, bool, Error?) {
    return cryptoSignedJsonClaimsRevocationStoreIsRevokedAt(store, claims, timeNowMillis());
}

func cryptoSignedJsonClaimsRevocationStoreDelete(store: CryptoSignedJsonClaimsRevocationStore,
                                                 jwt_id: string): (CryptoSignedJsonClaimsRevocationStore, bool, Error?) {
    var jwt_id_err = cryptoValidateSignedJsonClaimNonEmptyString(jwt_id,
                                                                 "jti",
                                                                 "cryptoSignedJsonClaimsRevocationStoreDelete");
    if (jwt_id_err != nil) {
        return (store, false, jwt_id_err);
    }

    if (!mapHasString(store.entries, jwt_id)) {
        return (store, false, nil);
    }

    mapDeleteString(store.entries, jwt_id);
    store.nextExpiryMillis = cryptoSignedJsonClaimsRevocationStoreComputeNextExpiry(store);
    return (store, true, nil);
}

func cryptoSignedJsonClaimsAudienceMatches(value_any: any,
                                           expected_audience: string?): bool {
    if (value_any == nil) {
        return false;
    }

    if (typeOf(value_any) == "string") {
        var audience_one: string = value_any as string;
        if (audience_one == "") {
            return false;
        }

        if (expected_audience == nil) {
            return true;
        }
        return audience_one == (expected_audience as string);
    }

    if (typeOf(value_any) != "array") {
        return false;
    }

    var audience_many: array<any> = value_any as array<any>;
    if (len(audience_many) == 0) {
        return false;
    }

    var i: int = 0;
    while (i < len(audience_many)) {
        var item: any = audience_many[i];
        if (item == nil || typeOf(item) != "string") {
            return false;
        }

        var audience_item: string = item as string;
        if (audience_item == "") {
            return false;
        }

        i = i + 1;
    }

    if (expected_audience == nil) {
        return true;
    }
    return contains(audience_many, expected_audience as any);
}

func cryptoCopyBytesRange(data: bytes, start: int, count: int): (bytes, Error?) {
    if (start < 0 || count < 0 || start > len(data) || count > (len(data) - start)) {
        return (cryptoEmptyBytes(),
                cryptoError(ERR_INVALID_ARGUMENT,
                            "byte range is out of bounds",
                            "cryptoCopyBytesRange",
                            {"start": start, "count": count, "length": len(data)}));
    }

    var out: bytes = bytesWithSize(count, 0).0;
    var i: int = 0;
    while (i < count) {
        out[i] = data[start + i];
        i = i + 1;
    }
    return (out, nil);
}

func cryptoSplitAesGcmSealed(sealed: bytes): (bytes, bytes, Error?) {
    if (len(sealed) < 16) {
        return (cryptoEmptyBytes(),
                cryptoEmptyBytes(),
                cryptoError(ERR_INVALID_ARGUMENT,
                            "AES-GCM sealed payload must include a 16-byte tag",
                            "cryptoSplitAesGcmSealed",
                            len(sealed)));
    }

    var ciphertext_len: int = len(sealed) - 16;
    var ciphertext = cryptoCopyBytesRange(sealed, 0, ciphertext_len);
    if (ciphertext.1 != nil) {
        return (cryptoEmptyBytes(),
                cryptoEmptyBytes(),
                wrapError(ciphertext.1, "cryptoSplitAesGcmSealed"));
    }

    var tag = cryptoCopyBytesRange(sealed, ciphertext_len, 16);
    if (tag.1 != nil) {
        return (cryptoEmptyBytes(),
                cryptoEmptyBytes(),
                wrapError(tag.1, "cryptoSplitAesGcmSealed"));
    }

    return (ciphertext.0, tag.0, nil);
}

func cryptoJoinAesGcmDetached(ciphertext: bytes, tag: bytes): (bytes, Error?) {
    if (len(tag) != 16) {
        return (cryptoEmptyBytes(),
                cryptoError(ERR_INVALID_ARGUMENT,
                            "AES-GCM tag must be 16 bytes",
                            "cryptoJoinAesGcmDetached",
                            len(tag)));
    }

    var joined = bytesJoin([ciphertext, tag]);
    if (joined.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(joined.1, "cryptoJoinAesGcmDetached"));
    }
    return (joined.0, nil);
}

func cryptoSha256Bytes(data: bytes): (bytes, Error?) {
    var hashed = sha256Bytes(data);
    if (hashed.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(hashed.1, "cryptoSha256Bytes"));
    }
    return (hashed.0, nil);
}

func cryptoSha256Hex(data: bytes): (string, Error?) {
    var hashed = cryptoSha256Bytes(data);
    if (hashed.1 != nil) {
        return ("", wrapError(hashed.1, "cryptoSha256Hex"));
    }

    var encoded = bytesToHex(hashed.0);
    if (encoded.1 != nil) {
        return ("", wrapError(encoded.1, "cryptoSha256Hex"));
    }
    return (encoded.0, nil);
}

func cryptoSha256Text(text: string): (bytes, Error?) {
    var bytes_r = stringToBytes(text);
    if (bytes_r.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(bytes_r.1, "cryptoSha256Text"));
    }
    return cryptoSha256Bytes(bytes_r.0);
}

