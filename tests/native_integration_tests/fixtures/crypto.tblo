func cryptoPasswordHashDerive(password: string,
                              salt: bytes,
                              iterations: int,
                              context: string): (bytes, Error?) {
    var password_r = stringToBytes(password);
    if (password_r.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(password_r.1, context));
    }

    var derived = cryptoPbkdf2HmacSha256Bytes(password_r.0,
                                              salt,
                                              iterations,
                                              CRYPTO_PASSWORD_HASH_BYTES);
    if (derived.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(derived.1, context));
    }
    return (derived.0, nil);
}

func cryptoPasswordHashEncode(hash: CryptoPasswordHash, with_padding: bool): (string, Error?) {
    var shape_err = cryptoValidatePasswordHashShape(hash, "cryptoPasswordHashEncode");
    if (shape_err != nil) {
        return ("", shape_err);
    }

    var salt = encodingBase64UrlEncodeBytes(hash.salt, with_padding);
    if (salt.1 != nil) {
        return ("", wrapError(salt.1, "cryptoPasswordHashEncode"));
    }

    var digest = encodingBase64UrlEncodeBytes(hash.digest, with_padding);
    if (digest.1 != nil) {
        return ("", wrapError(digest.1, "cryptoPasswordHashEncode"));
    }

    return (hash.scheme +
            "." +
            hash.version +
            "." +
            str(hash.iterations) +
            "." +
            salt.0 +
            "." +
            digest.0,
            nil);
}

func cryptoPasswordHashDecode(encoded: string): (CryptoPasswordHash, Error?) {
    var empty = cryptoEmptyPasswordHash();
    var parts: array<string> = split(encoded, ".");
    if (len(parts) != 5) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "password hash must have 5 dot-separated parts",
                            "cryptoPasswordHashDecode",
                            len(parts)));
    }

    if (parts[0] != CRYPTO_PASSWORD_HASH_SCHEME) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "unsupported password hash scheme",
                            "cryptoPasswordHashDecode",
                            parts[0]));
    }

    if (parts[1] != CRYPTO_PASSWORD_HASH_VERSION) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "unsupported password hash version",
                            "cryptoPasswordHashDecode",
                            parts[1]));
    }

    if (!cryptoIsAsciiDigits(parts[2])) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "password hash iterations must be decimal digits",
                            "cryptoPasswordHashDecode",
                            parts[2]));
    }

    var iterations: int = toInt(parts[2]);
    var iterations_err = cryptoValidatePasswordHashIterations(iterations, "cryptoPasswordHashDecode");
    if (iterations_err != nil) {
        return (empty, iterations_err);
    }

    var salt = encodingBase64UrlDecodeToBytes(parts[3]);
    if (salt.1 != nil) {
        return (empty, wrapError(salt.1, "cryptoPasswordHashDecode"));
    }

    var digest = encodingBase64UrlDecodeToBytes(parts[4]);
    if (digest.1 != nil) {
        return (empty, wrapError(digest.1, "cryptoPasswordHashDecode"));
    }

    var hash: CryptoPasswordHash = {
        scheme: parts[0],
        version: parts[1],
        iterations: iterations,
        salt: salt.0,
        digest: digest.0
    };

    var shape_err = cryptoValidatePasswordHashShape(hash, "cryptoPasswordHashDecode");
    if (shape_err != nil) {
        return (empty, shape_err);
    }
    return (hash, nil);
}

func cryptoPasswordHashCreate(password: string, iterations: int): (CryptoPasswordHash, Error?) {
    var empty = cryptoEmptyPasswordHash();
    var iterations_err = cryptoValidatePasswordHashIterations(iterations, "cryptoPasswordHashCreate");
    if (iterations_err != nil) {
        return (empty, iterations_err);
    }

    var salt = randomSecureBytes(CRYPTO_PASSWORD_HASH_SALT_BYTES);
    if (salt.1 != nil) {
        return (empty, wrapError(salt.1, "cryptoPasswordHashCreate"));
    }

    var digest = cryptoPasswordHashDerive(password,
                                          salt.0,
                                          iterations,
                                          "cryptoPasswordHashCreate");
    if (digest.1 != nil) {
        return (empty, wrapError(digest.1, "cryptoPasswordHashCreate"));
    }

    var hash: CryptoPasswordHash = {
        scheme: CRYPTO_PASSWORD_HASH_SCHEME,
        version: CRYPTO_PASSWORD_HASH_VERSION,
        iterations: iterations,
        salt: salt.0,
        digest: digest.0
    };
    return (hash, nil);
}

func cryptoPasswordHashCreateDefault(password: string): (CryptoPasswordHash, Error?) {
    return cryptoPasswordHashCreate(password, CRYPTO_PASSWORD_HASH_DEFAULT_ITERATIONS);
}

func cryptoPasswordHashVerify(password: string, hash: CryptoPasswordHash): (bool, Error?) {
    var shape_err = cryptoValidatePasswordHashShape(hash, "cryptoPasswordHashVerify");
    if (shape_err != nil) {
        return (false, shape_err);
    }

    var derived = cryptoPasswordHashDerive(password,
                                           hash.salt,
                                           hash.iterations,
                                           "cryptoPasswordHashVerify");
    if (derived.1 != nil) {
        return (false, wrapError(derived.1, "cryptoPasswordHashVerify"));
    }

    return cryptoConstantTimeBytesEqual(derived.0, hash.digest);
}

func cryptoPasswordHashNeedsRehash(hash: CryptoPasswordHash, minimum_iterations: int): (bool, Error?) {
    var minimum_err = cryptoValidatePasswordHashIterations(minimum_iterations, "cryptoPasswordHashNeedsRehash");
    if (minimum_err != nil) {
        return (false, minimum_err);
    }

    var shape_err = cryptoValidatePasswordHashShape(hash, "cryptoPasswordHashNeedsRehash");
    if (shape_err != nil) {
        return (false, shape_err);
    }

    return (hash.iterations < minimum_iterations, nil);
}

func cryptoPasswordHashCreateBase64Url(password: string,
                                       iterations: int,
                                       with_padding: bool): (string, Error?) {
    var hash = cryptoPasswordHashCreate(password, iterations);
    if (hash.1 != nil) {
        return ("", wrapError(hash.1, "cryptoPasswordHashCreateBase64Url"));
    }
    return cryptoPasswordHashEncode(hash.0, with_padding);
}

func cryptoPasswordHashCreateBase64UrlDefault(password: string): (string, Error?) {
    return cryptoPasswordHashCreateBase64Url(password,
                                            CRYPTO_PASSWORD_HASH_DEFAULT_ITERATIONS,
                                            false);
}

func cryptoPasswordHashVerifyBase64Url(password: string, encoded: string): (bool, Error?) {
    var hash = cryptoPasswordHashDecode(encoded);
    if (hash.1 != nil) {
        return (false, wrapError(hash.1, "cryptoPasswordHashVerifyBase64Url"));
    }
    return cryptoPasswordHashVerify(password, hash.0);
}

func cryptoPasswordHashVerifyAndUpgrade(password: string,
                                        hash: CryptoPasswordHash,
                                        minimum_iterations: int): (bool, bool, CryptoPasswordHash, Error?) {
    var empty = cryptoEmptyPasswordHash();
    var verified = cryptoPasswordHashVerify(password, hash);
    if (verified.1 != nil) {
        return (false, false, empty, wrapError(verified.1, "cryptoPasswordHashVerifyAndUpgrade"));
    }

    if (!verified.0) {
        return (false, false, empty, nil);
    }

    var needs_rehash = cryptoPasswordHashNeedsRehash(hash, minimum_iterations);
    if (needs_rehash.1 != nil) {
        return (false, false, empty, wrapError(needs_rehash.1, "cryptoPasswordHashVerifyAndUpgrade"));
    }

    if (!needs_rehash.0) {
        return (true, false, empty, nil);
    }

    var upgraded = cryptoPasswordHashCreate(password, minimum_iterations);
    if (upgraded.1 != nil) {
        return (false, false, empty, wrapError(upgraded.1, "cryptoPasswordHashVerifyAndUpgrade"));
    }

    return (true, true, upgraded.0, nil);
}

func cryptoPasswordHashVerifyAndUpgradeDefault(password: string,
                                               hash: CryptoPasswordHash): (bool, bool, CryptoPasswordHash, Error?) {
    return cryptoPasswordHashVerifyAndUpgrade(password,
                                              hash,
                                              CRYPTO_PASSWORD_HASH_DEFAULT_ITERATIONS);
}

func cryptoPasswordHashVerifyAndUpgradeBase64Url(password: string,
                                                 encoded: string,
                                                 minimum_iterations: int,
                                                 with_padding: bool): (bool, bool, string, Error?) {
    var hash = cryptoPasswordHashDecode(encoded);
    if (hash.1 != nil) {
        return (false, false, "", wrapError(hash.1, "cryptoPasswordHashVerifyAndUpgradeBase64Url"));
    }

    var upgraded = cryptoPasswordHashVerifyAndUpgrade(password, hash.0, minimum_iterations);
    if (upgraded.3 != nil) {
        return (false, false, "", wrapError(upgraded.3, "cryptoPasswordHashVerifyAndUpgradeBase64Url"));
    }

    if (!upgraded.0 || !upgraded.1) {
        return (upgraded.0, false, "", nil);
    }

    var encoded_hash = cryptoPasswordHashEncode(upgraded.2, with_padding);
    if (encoded_hash.1 != nil) {
        return (false, false, "", wrapError(encoded_hash.1, "cryptoPasswordHashVerifyAndUpgradeBase64Url"));
    }

    return (true, true, encoded_hash.0, nil);
}

func cryptoPasswordHashVerifyAndUpgradeBase64UrlDefault(password: string,
                                                        encoded: string): (bool, bool, string, Error?) {
    return cryptoPasswordHashVerifyAndUpgradeBase64Url(password,
                                                       encoded,
                                                       CRYPTO_PASSWORD_HASH_DEFAULT_ITERATIONS,
                                                       false);
}

func cryptoSignedTokenBuildBody(version: string,
                                issued_at_ms: int,
                                expires_at_ms: int,
                                payload_b64url: string): string {
    return version +
           "." +
           str(issued_at_ms) +
           "." +
           str(expires_at_ms) +
           "." +
           payload_b64url;
}

func cryptoSignedTokenMac(secret: bytes, body: string, context: string): (bytes, Error?) {
    var body_r = stringToBytes(body);
    if (body_r.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(body_r.1, context));
    }

    return cryptoHmacSha256Bytes(secret, body_r.0);
}

func cryptoSignedTokenDecodeInternal(token: string): (CryptoSignedTokenEnvelope, bytes, string, Error?) {
    var empty = cryptoEmptySignedTokenEnvelope();
    var parts: array<string> = split(token, ".");
    if (len(parts) != 5) {
        return (empty,
                cryptoEmptyBytes(),
                "",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "signed token must have 5 dot-separated parts",
                            "cryptoSignedTokenDecode",
                            len(parts)));
    }

    if (parts[0] != CRYPTO_SIGNED_TOKEN_VERSION) {
        return (empty,
                cryptoEmptyBytes(),
                "",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "unsupported signed token version",
                            "cryptoSignedTokenDecode",
                            parts[0]));
    }

    if (!cryptoIsAsciiDigits(parts[1]) || !cryptoIsAsciiDigits(parts[2])) {
        return (empty,
                cryptoEmptyBytes(),
                "",
                cryptoError(ERR_INVALID_ARGUMENT,
                            "signed token time fields must be decimal digits",
                            "cryptoSignedTokenDecode",
                            {"issuedAtMillis": parts[1], "expiresAtMillis": parts[2]}));
    }

    var issued_at_ms: int = toInt(parts[1]);
    var expires_at_ms: int = toInt(parts[2]);
    var times_err = cryptoValidateSignedTokenTimes(issued_at_ms,
                                                   expires_at_ms,
                                                   "cryptoSignedTokenDecode");
    if (times_err != nil) {
        return (empty, cryptoEmptyBytes(), "", times_err);
    }

    var payload = encodingBase64UrlDecodeToBytes(parts[3]);
    if (payload.1 != nil) {
        return (empty,
                cryptoEmptyBytes(),
                "",
                wrapError(payload.1, "cryptoSignedTokenDecode"));
    }

    var tag = encodingBase64UrlDecodeToBytes(parts[4]);
    if (tag.1 != nil) {
        return (empty,
                cryptoEmptyBytes(),
                "",
                wrapError(tag.1, "cryptoSignedTokenDecode"));
    }

    var envelope: CryptoSignedTokenEnvelope = {
        version: parts[0],
        issuedAtMillis: issued_at_ms,
        expiresAtMillis: expires_at_ms,
        payload: payload.0
    };
    var shape_err = cryptoValidateSignedTokenShape(envelope, "cryptoSignedTokenDecode");
    if (shape_err != nil) {
        return (empty, cryptoEmptyBytes(), "", shape_err);
    }

    return (envelope,
            tag.0,
            cryptoSignedTokenBuildBody(parts[0], issued_at_ms, expires_at_ms, parts[3]),
            nil);
}

func cryptoSignedTokenSeal(secret: bytes,
                           payload: bytes,
                           issued_at_ms: int,
                           expires_at_ms: int): (string, Error?) {
    var times_err = cryptoValidateSignedTokenTimes(issued_at_ms, expires_at_ms, "cryptoSignedTokenSeal");
    if (times_err != nil) {
        return ("", times_err);
    }

    var payload_b64 = encodingBase64UrlEncodeBytes(payload, false);
    if (payload_b64.1 != nil) {
        return ("", wrapError(payload_b64.1, "cryptoSignedTokenSeal"));
    }

    var body = cryptoSignedTokenBuildBody(CRYPTO_SIGNED_TOKEN_VERSION,
                                          issued_at_ms,
                                          expires_at_ms,
                                          payload_b64.0);
    var mac = cryptoSignedTokenMac(secret, body, "cryptoSignedTokenSeal");
    if (mac.1 != nil) {
        return ("", wrapError(mac.1, "cryptoSignedTokenSeal"));
    }

    var tag_b64 = encodingBase64UrlEncodeBytes(mac.0, false);
    if (tag_b64.1 != nil) {
        return ("", wrapError(tag_b64.1, "cryptoSignedTokenSeal"));
    }

    return (body + "." + tag_b64.0, nil);
}

func cryptoSignedTokenSealWithTtl(secret: bytes, payload: bytes, ttl_ms: int): (string, Error?) {
    var ttl_err = cryptoValidateSignedTokenTtl(ttl_ms, "cryptoSignedTokenSealWithTtl");
    if (ttl_err != nil) {
        return ("", ttl_err);
    }

    var issued_at_ms: int = timeNowMillis();
    return cryptoSignedTokenSeal(secret, payload, issued_at_ms, issued_at_ms + ttl_ms);
}

func cryptoSignedTokenSealText(secret_text: string,
                               payload_text: string,
                               issued_at_ms: int,
                               expires_at_ms: int): (string, Error?) {
    var secret_r = stringToBytes(secret_text);
    if (secret_r.1 != nil) {
        return ("", wrapError(secret_r.1, "cryptoSignedTokenSealText"));
    }

    var payload_r = stringToBytes(payload_text);
    if (payload_r.1 != nil) {
        return ("", wrapError(payload_r.1, "cryptoSignedTokenSealText"));
    }

    return cryptoSignedTokenSeal(secret_r.0, payload_r.0, issued_at_ms, expires_at_ms);
}

func cryptoSignedTokenSealTextWithTtl(secret_text: string,
                                      payload_text: string,
                                      ttl_ms: int): (string, Error?) {
    var secret_r = stringToBytes(secret_text);
    if (secret_r.1 != nil) {
        return ("", wrapError(secret_r.1, "cryptoSignedTokenSealTextWithTtl"));
    }

    var payload_r = stringToBytes(payload_text);
    if (payload_r.1 != nil) {
        return ("", wrapError(payload_r.1, "cryptoSignedTokenSealTextWithTtl"));
    }

    return cryptoSignedTokenSealWithTtl(secret_r.0, payload_r.0, ttl_ms);
}

func cryptoSignedTokenDecode(token: string): (CryptoSignedTokenEnvelope, Error?) {
    var decoded = cryptoSignedTokenDecodeInternal(token);
    if (decoded.3 != nil) {
        return (cryptoEmptySignedTokenEnvelope(), wrapError(decoded.3, "cryptoSignedTokenDecode"));
    }
    return (decoded.0, nil);
}

func cryptoSignedTokenVerify(secret: bytes,
                             token: string,
                             now_ms: int): (bool, bool, CryptoSignedTokenEnvelope, Error?) {
    var empty = cryptoEmptySignedTokenEnvelope();
    var decoded = cryptoSignedTokenDecodeInternal(token);
    if (decoded.3 != nil) {
        return (false, false, empty, nil);
    }

    var mac = cryptoSignedTokenMac(secret, decoded.2, "cryptoSignedTokenVerify");
    if (mac.1 != nil) {
        return (false, false, empty, wrapError(mac.1, "cryptoSignedTokenVerify"));
    }

    var same = cryptoConstantTimeBytesEqual(mac.0, decoded.1);
    if (same.1 != nil) {
        return (false, false, empty, wrapError(same.1, "cryptoSignedTokenVerify"));
    }

    if (!same.0) {
        return (false, false, empty, nil);
    }

    if (now_ms > decoded.0.expiresAtMillis) {
        return (false, true, decoded.0, nil);
    }

    return (true, false, decoded.0, nil);
}

func cryptoSignedTokenVerifyNow(secret: bytes,
                                token: string): (bool, bool, CryptoSignedTokenEnvelope, Error?) {
    return cryptoSignedTokenVerify(secret, token, timeNowMillis());
}

func cryptoSignedTokenVerifyText(secret_text: string,
                                 token: string,
                                 now_ms: int): (bool, bool, CryptoSignedTokenEnvelope, Error?) {
    var secret_r = stringToBytes(secret_text);
    if (secret_r.1 != nil) {
        return (false,
                false,
                cryptoEmptySignedTokenEnvelope(),
                wrapError(secret_r.1, "cryptoSignedTokenVerifyText"));
    }
    return cryptoSignedTokenVerify(secret_r.0, token, now_ms);
}

func cryptoSignedTokenVerifyTextNow(secret_text: string,
                                    token: string): (bool, bool, CryptoSignedTokenEnvelope, Error?) {
    return cryptoSignedTokenVerifyText(secret_text, token, timeNowMillis());
}

func cryptoSignedJsonClaimsEncodePayload(key_id: string?,
                                         claims: map<string, any>,
                                         context: string): (bytes, Error?) {
    var payload_doc: map<string, any> = {
        "claims": claims as any
    };

    if (key_id != nil) {
        var key_id_str: string = key_id as string;
        var key_id_err = cryptoValidateSignedJsonClaimsKeyId(key_id_str, context);
        if (key_id_err != nil) {
            return (cryptoEmptyBytes(), key_id_err);
        }
        mapSetString(payload_doc, "kid", key_id_str as any);
    }

    var encoded = jsonStringify(payload_doc as any);
    if (encoded.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(encoded.1, context));
    }

    var payload = stringToBytes(encoded.0);
    if (payload.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(payload.1, context));
    }
    return (payload.0, nil);
}

func cryptoSignedJsonClaimsDecodePayload(payload: bytes,
                                         context: string): (string?, map<string, any>, Error?) {
    var payload_text = bytesToString(payload);
    if (payload_text.1 != nil) {
        return (nil, {}, wrapError(payload_text.1, context));
    }

    var parsed = jsonParse(payload_text.0);
    if (parsed.1 != nil) {
        return (nil, {}, wrapError(parsed.1, context));
    }

    if (typeOf(parsed.0) != "map") {
        return (nil,
                {},
                cryptoError(ERR_INVALID_ARGUMENT,
                            "signed JSON claims payload must decode to map<string, any>",
                            context,
                            typeOf(parsed.0)));
    }

    var payload_doc: map<string, any> = parsed.0 as map<string, any>;
    var claims_any: any = mapGetString(payload_doc, "claims");
    if (claims_any == nil || typeOf(claims_any) != "map") {
        return (nil,
                {},
                cryptoError(ERR_INVALID_ARGUMENT,
                            "signed JSON claims payload must contain map field 'claims'",
                            context,
                            claims_any));
    }

    var key_id_any: any = mapGetString(payload_doc, "kid");
    if (key_id_any != nil && typeOf(key_id_any) != "string") {
        return (nil,
                {},
                cryptoError(ERR_INVALID_ARGUMENT,
                            "signed JSON claims payload field 'kid' must be string when present",
                            context,
                            typeOf(key_id_any)));
    }

    if (key_id_any != nil) {
        var key_id_err = cryptoValidateSignedJsonClaimsKeyId(key_id_any as string, context);
        if (key_id_err != nil) {
            return (nil, {}, key_id_err);
        }
    }

    var key_id: string? = nil;
    if (key_id_any != nil) {
        key_id = key_id_any as string;
    }

    return (key_id, claims_any as map<string, any>, nil);
}

func cryptoSignedJsonClaimsFromTokenEnvelope(token: CryptoSignedTokenEnvelope,
                                             context: string): (CryptoSignedJsonClaimsEnvelope, Error?) {
    var empty = cryptoEmptySignedJsonClaimsEnvelope();
    var decoded = cryptoSignedJsonClaimsDecodePayload(token.payload, context);
    if (decoded.2 != nil) {
        return (empty, wrapError(decoded.2, context));
    }

    var envelope: CryptoSignedJsonClaimsEnvelope = {
        version: token.version,
        issuedAtMillis: token.issuedAtMillis,
        expiresAtMillis: token.expiresAtMillis,
        keyId: decoded.0,
        claims: decoded.1
    };
    return (envelope, nil);
}

func cryptoSignedJsonClaimsSeal(secret: bytes,
                                claims: map<string, any>,
                                issued_at_ms: int,
                                expires_at_ms: int): (string, Error?) {
    var payload = cryptoSignedJsonClaimsEncodePayload(nil,
                                                      claims,
                                                      "cryptoSignedJsonClaimsSeal");
    if (payload.1 != nil) {
        return ("", wrapError(payload.1, "cryptoSignedJsonClaimsSeal"));
    }

    return cryptoSignedTokenSeal(secret, payload.0, issued_at_ms, expires_at_ms);
}

