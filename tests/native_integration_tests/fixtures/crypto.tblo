    }
    return cryptoConstantTimeBytesEqual(actual.0, expected_tag);
}

func cryptoHmacSha256VerifyHex(key: bytes, data: bytes, expected_hex: string): (bool, Error?) {
    var expected = hexToBytes(expected_hex);
    if (expected.1 != nil) {
