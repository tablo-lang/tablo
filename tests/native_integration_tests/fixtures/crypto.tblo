func cryptoPasswordAesGcmDeriveKey(password: string,
                                   salt: bytes,
                                   iterations: int,
                                   context: string): (bytes, Error?) {
    var password_r = stringToBytes(password);
    if (password_r.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(password_r.1, context));
    }

    var derived = cryptoPbkdf2HmacSha256Bytes(password_r.0,
                                              salt,
                                              iterations,
                                              CRYPTO_PASSWORD_AES_GCM_KEY_BYTES);
    if (derived.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(derived.1, context));
    }
    return (derived.0, nil);
}

func cryptoPasswordAesGcmEncodeEnvelope(envelope: CryptoPasswordAesGcmEnvelope,
                                        with_padding: bool): (string, Error?) {
    var shape_err = cryptoValidatePasswordEnvelopeShape(envelope, "cryptoPasswordAesGcmEncodeEnvelope");
    if (shape_err != nil) {
        return ("", shape_err);
    }

    var salt = encodingBase64UrlEncodeBytes(envelope.salt, with_padding);
    if (salt.1 != nil) {
        return ("", wrapError(salt.1, "cryptoPasswordAesGcmEncodeEnvelope"));
    }

    var nonce = encodingBase64UrlEncodeBytes(envelope.nonce, with_padding);
    if (nonce.1 != nil) {
        return ("", wrapError(nonce.1, "cryptoPasswordAesGcmEncodeEnvelope"));
    }

    var sealed = encodingBase64UrlEncodeBytes(envelope.sealed, with_padding);
    if (sealed.1 != nil) {
        return ("", wrapError(sealed.1, "cryptoPasswordAesGcmEncodeEnvelope"));
    }

    return (envelope.version +
            "." +
            str(envelope.iterations) +
            "." +
            salt.0 +
            "." +
            nonce.0 +
            "." +
            sealed.0,
            nil);
}

func cryptoPasswordAesGcmDecodeEnvelope(encoded: string): (CryptoPasswordAesGcmEnvelope, Error?) {
    var empty = cryptoEmptyPasswordAesGcmEnvelope();
    var parts: array<string> = split(encoded, ".");
    if (len(parts) != 5) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "password AES-GCM envelope must have 5 dot-separated parts",
                            "cryptoPasswordAesGcmDecodeEnvelope",
                            len(parts)));
    }

    if (parts[0] != CRYPTO_PASSWORD_AES_GCM_ENVELOPE_VERSION) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "unsupported envelope version",
                            "cryptoPasswordAesGcmDecodeEnvelope",
                            parts[0]));
    }

    if (!cryptoIsAsciiDigits(parts[1])) {
        return (empty,
                cryptoError(ERR_INVALID_ARGUMENT,
                            "password AES-GCM envelope iterations must be decimal digits",
                            "cryptoPasswordAesGcmDecodeEnvelope",
                            parts[1]));
    }

    var iterations: int = toInt(parts[1]);
    var iterations_err = cryptoValidatePasswordEnvelopeIterations(iterations,
                                                                  "cryptoPasswordAesGcmDecodeEnvelope");
    if (iterations_err != nil) {
        return (empty, iterations_err);
    }

    var salt = encodingBase64UrlDecodeToBytes(parts[2]);
    if (salt.1 != nil) {
        return (empty, wrapError(salt.1, "cryptoPasswordAesGcmDecodeEnvelope"));
    }

    var nonce = encodingBase64UrlDecodeToBytes(parts[3]);
    if (nonce.1 != nil) {
        return (empty, wrapError(nonce.1, "cryptoPasswordAesGcmDecodeEnvelope"));
    }

    var sealed = encodingBase64UrlDecodeToBytes(parts[4]);
    if (sealed.1 != nil) {
        return (empty, wrapError(sealed.1, "cryptoPasswordAesGcmDecodeEnvelope"));
    }

    var envelope: CryptoPasswordAesGcmEnvelope = {
        version: parts[0],
        iterations: iterations,
        salt: salt.0,
        nonce: nonce.0,
        sealed: sealed.0
    };

    var shape_err = cryptoValidatePasswordEnvelopeShape(envelope, "cryptoPasswordAesGcmDecodeEnvelope");
    if (shape_err != nil) {
        return (empty, shape_err);
    }
    return (envelope, nil);
}

func cryptoPasswordAesGcmSeal(password: string,
                              plaintext: bytes,
                              aad: bytes,
                              iterations: int): (CryptoPasswordAesGcmEnvelope, Error?) {
    var empty = cryptoEmptyPasswordAesGcmEnvelope();
    var iterations_err = cryptoValidatePasswordEnvelopeIterations(iterations, "cryptoPasswordAesGcmSeal");
    if (iterations_err != nil) {
        return (empty, iterations_err);
    }

    var salt = randomSecureBytes(CRYPTO_PASSWORD_AES_GCM_SALT_BYTES);
    if (salt.1 != nil) {
        return (empty, wrapError(salt.1, "cryptoPasswordAesGcmSeal"));
    }

    var nonce = randomSecureBytes(CRYPTO_PASSWORD_AES_GCM_NONCE_BYTES);
    if (nonce.1 != nil) {
        return (empty, wrapError(nonce.1, "cryptoPasswordAesGcmSeal"));
    }

    var key = cryptoPasswordAesGcmDeriveKey(password,
                                            salt.0,
                                            iterations,
                                            "cryptoPasswordAesGcmSeal");
    if (key.1 != nil) {
        return (empty, wrapError(key.1, "cryptoPasswordAesGcmSeal"));
    }

    var sealed = cryptoAesGcmSeal(key.0, nonce.0, plaintext, aad);
    if (sealed.1 != nil) {
        return (empty, wrapError(sealed.1, "cryptoPasswordAesGcmSeal"));
    }

    var envelope: CryptoPasswordAesGcmEnvelope = {
        version: CRYPTO_PASSWORD_AES_GCM_ENVELOPE_VERSION,
        iterations: iterations,
        salt: salt.0,
        nonce: nonce.0,
        sealed: sealed.0
    };
    return (envelope, nil);
}

func cryptoPasswordAesGcmSealDefault(password: string,
                                     plaintext: bytes,
                                     aad: bytes): (CryptoPasswordAesGcmEnvelope, Error?) {
    return cryptoPasswordAesGcmSeal(password,
                                    plaintext,
                                    aad,
                                    CRYPTO_PASSWORD_AES_GCM_DEFAULT_ITERATIONS);
}

func cryptoPasswordAesGcmOpen(password: string,
                              envelope: CryptoPasswordAesGcmEnvelope,
                              aad: bytes): (bytes, Error?) {
    var shape_err = cryptoValidatePasswordEnvelopeShape(envelope, "cryptoPasswordAesGcmOpen");
    if (shape_err != nil) {
        return (cryptoEmptyBytes(), shape_err);
    }

    var key = cryptoPasswordAesGcmDeriveKey(password,
                                            envelope.salt,
                                            envelope.iterations,
                                            "cryptoPasswordAesGcmOpen");
    if (key.1 != nil) {
        return (cryptoEmptyBytes(), wrapError(key.1, "cryptoPasswordAesGcmOpen"));
    }

    return cryptoAesGcmOpen(key.0, envelope.nonce, envelope.sealed, aad);
}

