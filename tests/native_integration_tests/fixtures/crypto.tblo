    var tag_hex = bytesToHex(detached.1);
    if (tag_hex.1 != nil) {
        return ("", "", wrapError(tag_hex.1, "cryptoAesGcmSealDetachedHex"));
    }

    return (ciphertext_hex.0, tag_hex.0, nil);
}

