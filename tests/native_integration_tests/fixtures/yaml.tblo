func yamlLooksLikeBareKey(text: string): bool {
    if (text == "") {
        return false;
    }

    var i: int = 0;
    while (i < len(text)) {
        if (!yamlIsBareKeyChar(substring(text, i, 1))) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

func yamlEscapeString(text: string): string {
    var out: string = "";
    var i: int = 0;
    while (i < len(text)) {
        var ch: string = substring(text, i, 1);
        if (ch == "\\") {
            out = out + "\\\\";
        } else if (ch == "\"") {
            out = out + "\\\"";
        } else if (ch == "\n") {
            out = out + "\\n";
        } else if (ch == "\r") {
            out = out + "\\r";
        } else if (ch == "\t") {
            out = out + "\\t";
        } else {
            out = out + ch;
        }
        i = i + 1;
    }
    return out;
}

func yamlNeedsQuotedString(text: string): bool {
    if (text == "") {
        return true;
    }

    if (trim(text) != text) {
        return true;
    }

    if (startsWith(text, "-") ||
        startsWith(text, "[") ||
        startsWith(text, "{") ||
        text == "true" ||
        text == "false" ||
        yamlLooksLikeInt(text)) {
        return true;
    }

    var i: int = 0;
    while (i < len(text)) {
        var ch: string = substring(text, i, 1);
        if (ch == ":" || ch == "#" || ch == "," || ch == "[" || ch == "]" || ch == "\n" || ch == "\r" || ch == "\t") {
            return true;
        }
        i = i + 1;
    }

    return false;
}

func yamlFormatKey(key: string): string {
    if (yamlLooksLikeBareKey(key)) {
        return key;
    }
    return "\"" + yamlEscapeString(key) + "\"";
}

func yamlIndent(level: int): string {
    var out: string = "";
    var i: int = 0;
    while (i < level) {
        out = out + " ";
        i = i + 1;
    }
    return out;
}

func yamlStringifyInlineArray(items: array<any>, depth: int): (string, Error?) {
    var out: string = "[";
    var i: int = 0;
    foreach (item in items) {
        if (i > 0) {
            out = out + ", ";
        }
        var encoded = yamlStringifyScalar(item, depth + 1);
        if (encoded.1 != nil) {
            return ("", encoded.1);
        }
        out = out + encoded.0;
        i = i + 1;
    }
    out = out + "]";
    return (out, nil);
}

func yamlStringifyScalar(value: any, depth: int): (string, Error?) {
    if (depth > 64) {
        return ("",
                yamlError(ERR_LIMIT,
                          "YAML stringify nesting depth exceeded",
                          "yaml.stringify.depth",
                          -1,
                          1,
                          depth));
    }

    if (value == nil) {
        return ("",
                yamlError(ERR_INVALID_ARGUMENT,
                          "YAML stringify does not support nil values",
                          "yaml.stringify.nil",
                          -1,
                          1,
                          nil));
    }

    var t: string = typeOf(value);
    if (t == "string") {
        var s: string = value as string;
        if (yamlNeedsQuotedString(s)) {
            return ("\"" + yamlEscapeString(s) + "\"", nil);
        }
        return (s, nil);
    }
    if (t == "int") {
        return (str(value as int), nil);
    }
    if (t == "bool") {
        if (value as bool) {
            return ("true", nil);
        }
        return ("false", nil);
    }
    if (t == "array") {
        return yamlStringifyInlineArray(value as array<any>, depth + 1);
    }

    return ("",
            yamlError(ERR_INVALID_ARGUMENT,
                      "unsupported scalar type for YAML stringify",
                      "yaml.stringify.scalar.type",
                      -1,
                      1,
                      t));
}

func yamlStringifyMapInternal(table: map<string, any>, indent: int, depth: int): (string, Error?) {
    if (depth > 64) {
        return ("",
                yamlError(ERR_LIMIT,
                          "YAML stringify nesting depth exceeded",
                          "yaml.stringify.map.depth",
                          -1,
                          1,
                          depth));
    }

    var out: string = "";
    foreach (key_any in keys(table)) {
        if (key_any == nil || typeOf(key_any) != "string") {
            return ("",
                    yamlError(ERR_INVALID_ARGUMENT,
                              "mapping key must be a string",
                              "yaml.stringify.key.type",
                              -1,
                              1,
                              key_any));
        }

        var key: string = key_any as string;
        var value: any = mapGetString(table, key);
        if (value == nil) {
            return ("",
                    yamlError(ERR_INVALID_ARGUMENT,
                              "YAML stringify does not support nil mapping values",
                              "yaml.stringify.value.nil",
                              -1,
                              1,
                              key));
        }

        var key_text: string = yamlFormatKey(key);
        if (typeOf(value) == "map") {
            out = out + yamlIndent(indent) + key_text + ":\n";
            var child = yamlStringifyMapInternal(value as map<string, any>, indent + 2, depth + 1);
            if (child.1 != nil) {
                return ("", child.1);
            }
            out = out + child.0;
        } else {
            var scalar = yamlStringifyScalar(value, depth + 1);
            if (scalar.1 != nil) {
                return ("", scalar.1);
            }
            out = out + yamlIndent(indent) + key_text + ": " + scalar.0 + "\n";
        }
    }

    return (out, nil);
}

func yamlStringify(doc: map<string, any>): (string, Error?) {
    var encoded = yamlStringifyMapInternal(doc, 0, 0);
    if (encoded.1 != nil) {
        return ("", encoded.1);
    }

    var out: string = encoded.0;
    while (endsWith(out, "\n")) {
        out = substring(out, 0, len(out) - 1);
    }
    return (out, nil);
}
