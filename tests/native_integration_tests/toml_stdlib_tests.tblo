import "fixtures/toml.tblo";

func main(): void {
    var doc_text: string = "# app settings\n" +
                           "name = \"tablo\"\n" +
                           "port = 8080\n" +
                           "enabled = true\n" +
                           "tags = [\"lang\", \"vm\", \"2026\"]\n" +
                           "quoted.\"dotted.key\" = \"ok\"\n" +
                           "[server]\n" +
                           "host = \"127.0.0.1\"\n" +
                           "workers = 4\n" +
                           "[server.tls]\n" +
                           "enabled = false\n";

    var parsed = tomlParse(doc_text);
    println(parsed.1 == nil);

    if (parsed.1 == nil) {
        var name_r = tomlGetString(parsed.0, "name");
        println(name_r.1 == nil);
        if (name_r.1 == nil && name_r.0 != nil) println(name_r.0 == "tablo");

        var port_r = tomlGetInt(parsed.0, "port");
        println(port_r.1 == nil);
        if (port_r.1 == nil && port_r.0 != nil) println(port_r.0 == 8080);

        var enabled_r = tomlGetBool(parsed.0, "enabled");
        println(enabled_r.1 == nil);
        if (enabled_r.1 == nil && enabled_r.0 != nil) println(enabled_r.0);

        var tags_r = tomlGetArray(parsed.0, "tags");
        println(tags_r.1 == nil);
        if (tags_r.1 == nil && tags_r.0 != nil) {
            var tags: array<any> = tags_r.0 as array<any>;
            var tags_count: int = 0;
            var tags_first_ok: bool = false;
            var tags_last_ok: bool = false;
            foreach (tag_any in tags) {
                if (tags_count == 0 &&
                    typeOf(tag_any) == "string" &&
                    (tag_any as string) == "lang") {
                    tags_first_ok = true;
                }
                if (tags_count == 2 &&
                    typeOf(tag_any) == "string" &&
                    (tag_any as string) == "2026") {
                    tags_last_ok = true;
                }
                tags_count = tags_count + 1;
            }
            println(tags_count == 3);
            println(tags_first_ok);
            println(tags_last_ok);
        }

        var host_r = tomlGetString(parsed.0, "server.host");
        println(host_r.1 == nil);
        if (host_r.1 == nil && host_r.0 != nil) println(host_r.0 == "127.0.0.1");

        var workers_r = tomlGetInt(parsed.0, "server.workers");
        println(workers_r.1 == nil);
        if (workers_r.1 == nil && workers_r.0 != nil) println(workers_r.0 == 4);

        var tls_r = tomlGetBool(parsed.0, "server.tls.enabled");
        println(tls_r.1 == nil);
        if (tls_r.1 == nil && tls_r.0 != nil) println(!tls_r.0);

        var quoted_r = tomlGetString(parsed.0, "quoted.\"dotted.key\"");
        println(quoted_r.1 == nil);
        if (quoted_r.1 == nil && quoted_r.0 != nil) println(quoted_r.0 == "ok");

        var missing_r = tomlGetString(parsed.0, "missing.value");
        println(missing_r.1 == nil);
        println(missing_r.0 == nil);

        var bad_get = tomlGetInt(parsed.0, "name");
        println(bad_get.1 != nil);
        if (bad_get.1 != nil) println(bad_get.1.code == ERR_PARSE);

        var encoded = tomlStringify(parsed.0);
        println(encoded.1 == nil);
        if (encoded.1 == nil) {
            var roundtrip = tomlParse(encoded.0);
            println(roundtrip.1 == nil);
            if (roundtrip.1 == nil) {
                var round_name = tomlGetString(roundtrip.0, "name");
                println(round_name.1 == nil);
                if (round_name.1 == nil && round_name.0 != nil) println(round_name.0 == "tablo");

                var round_tls = tomlGetBool(roundtrip.0, "server.tls.enabled");
                println(round_tls.1 == nil);
                if (round_tls.1 == nil && round_tls.0 != nil) println(!round_tls.0);
            }
        }
    }

    var doc_array: string = "arr = [1, true, \"x\", [2, 3], ]\n";
    var parsed_array = tomlParse(doc_array);
    println(parsed_array.1 == nil);
    if (parsed_array.1 == nil) {
        var arr_r = tomlGetArray(parsed_array.0, "arr");
        println(arr_r.1 == nil);
        if (arr_r.1 == nil && arr_r.0 != nil) {
            var arr: array<any> = arr_r.0 as array<any>;
            var arr_count: int = 0;
            var arr_first_ok: bool = false;
            var arr_second_ok: bool = false;
            var arr_nested_ok: bool = false;
            foreach (item_any in arr) {
                if (arr_count == 0 &&
                    typeOf(item_any) == "int" &&
                    (item_any as int) == 1) {
                    arr_first_ok = true;
                }
                if (arr_count == 1 &&
                    typeOf(item_any) == "bool" &&
                    (item_any as bool)) {
                    arr_second_ok = true;
                }
                if (arr_count == 3 && typeOf(item_any) == "array") {
                    var nested: array<any> = item_any as array<any>;
                    var nested_count: int = 0;
                    foreach (nested_item in nested) {
                        if (nested_count == 1 &&
                            typeOf(nested_item) == "int" &&
                            (nested_item as int) == 3) {
                            arr_nested_ok = true;
                        }
                        nested_count = nested_count + 1;
                    }
                }
                arr_count = arr_count + 1;
            }
            println(arr_count == 4);
            println(arr_first_ok);
            println(arr_second_ok);
            println(arr_nested_ok);
        }
    }

    var dup = tomlParse("a = 1\na = 2\n");
    println(dup.1 != nil);
    if (dup.1 != nil) println(dup.1.code == ERR_PARSE);

    var bad_float = tomlParse("rate = 1.5\n");
    println(bad_float.1 != nil);
    if (bad_float.1 != nil) println(bad_float.1.code == ERR_PARSE);

    var bad_section = tomlParse("[[items]]\n");
    println(bad_section.1 != nil);
    if (bad_section.1 != nil) println(bad_section.1.code == ERR_PARSE);

    var bad_array = tomlParse("items = [1,,2]\n");
    println(bad_array.1 != nil);
    if (bad_array.1 != nil) println(bad_array.1.code == ERR_PARSE);
}
