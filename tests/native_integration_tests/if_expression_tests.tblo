func choose(flag: bool): int {
    return if (flag) {
        var base: int = 10;
        base + 2
    } else {
        var base: int = 3;
        base * 4
    };
}

func classify(value: int): string {
    return if (value < 0) {
        "negative"
    } else if (value == 0) {
        "zero"
    } else {
        var label: string = "positive";
        label
    };
}

func literalValue(flag: bool): int {
    return if (flag) 3 else 7;
}

func main() {
    println(choose(true));
    println(choose(false));
    println(classify(-1));
    println(classify(0));
    println(classify(9));
    println(literalValue(true));
    println(literalValue(false));
}
