    println(aes_key_256.1 == nil);

    if (aes_ctr.1 == nil && aes_plain.1 == nil && aes_key_128.1 == nil) {
        var aes_128 = cryptoAesCtrEncrypt(aes_key_128.0, aes_ctr.0, aes_plain.0);
        println(aes_128.1 == nil);
        if (aes_128.1 == nil) {
            var aes_128_hex = bytesToHex(aes_128.0);
            println(aes_128_hex.1 == nil);
            if (aes_128_hex.1 == nil) println(aes_128_hex.0 == "874d6191b620e3261bef6864990db6ce"
                                                                      + "9806f66b7970fdff8617187bb9fffdff"
                                                                      + "5ae4df3edbd5d35e5b4f09020db03eab"
                                                                      + "1e031dda2fbe03d1792170a0f3009cee");

            var aes_128_plain = cryptoAesCtrDecrypt(aes_key_128.0, aes_ctr.0, aes_128.0);
            println(aes_128_plain.1 == nil);
            if (aes_128_plain.1 == nil) {
                var aes_128_plain_hex = bytesToHex(aes_128_plain.0);
                println(aes_128_plain_hex.1 == nil);
                if (aes_128_plain_hex.1 == nil) println(aes_128_plain_hex.0 == "6bc1bee22e409f96e93d7e117393172a"
                                                                                  + "ae2d8a571e03ac9c9eb76fac45af8e51"
                                                                                  + "30c81c46a35ce411e5fbc1191a0a52ef"
                                                                                  + "f69f2445df4f9b17ad2b417be66c3710");
            }
        }
    }

    if (aes_ctr.1 == nil && aes_plain.1 == nil && aes_key_256.1 == nil) {
