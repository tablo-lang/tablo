    if (pb_zero.1 == nil) println(len(pb_zero.0) == 0);

    var hkdf_ikm_1 = hexToBytes("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b");
    var hkdf_salt_1 = hexToBytes("000102030405060708090a0b0c");
