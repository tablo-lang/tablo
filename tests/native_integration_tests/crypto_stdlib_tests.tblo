    }

    var aes_ctr = hexToBytes("f0f1f2f3f4f5f6f7f8f9fafbfcfdfeff");
    var aes_plain = hexToBytes("6bc1bee22e409f96e93d7e117393172a"
                               + "ae2d8a571e03ac9c9eb76fac45af8e51"
                               + "30c81c46a35ce411e5fbc1191a0a52ef"
                               + "f69f2445df4f9b17ad2b417be66c3710");
