                if (gcm_empty_b64url_open.1 == nil) println(len(gcm_empty_b64url_open.0) == 0);
            }
        }

        var gcm_zero_plain = hexToBytes("00000000000000000000000000000000");
        println(gcm_zero_plain.1 == nil);
        if (gcm_zero_plain.1 == nil) {
            var gcm_zero = cryptoAesGcmSeal(gcm_key_zero.0,
                                            gcm_nonce_zero.0,
                                            gcm_zero_plain.0,
                                            bytesWithSize(0, 0).0);
            println(gcm_zero.1 == nil);
            if (gcm_zero.1 == nil) {
                var gcm_zero_hex = bytesToHex(gcm_zero.0);
                println(gcm_zero_hex.1 == nil);
                if (gcm_zero_hex.1 == nil) println(gcm_zero_hex.0 == "0388dace60b6a392f328c2b971b2fe78ab6e47d42cec13bdf53a67b21257bddf");

                var gcm_zero_detached = cryptoAesGcmSealDetached(gcm_key_zero.0,
                                                                 gcm_nonce_zero.0,
                                                                 gcm_zero_plain.0,
                                                                 bytesWithSize(0, 0).0);
                println(gcm_zero_detached.2 == nil);
                if (gcm_zero_detached.2 == nil) {
                    var gcm_zero_cipher_hex = bytesToHex(gcm_zero_detached.0);
                    var gcm_zero_tag_hex = bytesToHex(gcm_zero_detached.1);
                    println(gcm_zero_cipher_hex.1 == nil);
                    println(gcm_zero_tag_hex.1 == nil);
                    if (gcm_zero_cipher_hex.1 == nil) println(gcm_zero_cipher_hex.0 == "0388dace60b6a392f328c2b971b2fe78");
                    if (gcm_zero_tag_hex.1 == nil) println(gcm_zero_tag_hex.0 == "ab6e47d42cec13bdf53a67b21257bddf");

                    var gcm_zero_open_detached = cryptoAesGcmOpenDetached(gcm_key_zero.0,
                                                                          gcm_nonce_zero.0,
