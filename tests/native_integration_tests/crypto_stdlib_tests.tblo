import "fixtures/crypto.tblo";

func runAutoJtiSessionTests(): void {
    var auto_jti_claims = cryptoSignedJsonClaimsNew();
    var auto_jti_claims_sub = cryptoSignedJsonClaimsSetSubject(auto_jti_claims, "auto-user");
    println(auto_jti_claims_sub.1 == nil);
    if (auto_jti_claims_sub.1 == nil) {
        auto_jti_claims = auto_jti_claims_sub.0;
    }

    var auto_jti_1 = cryptoSignedJsonClaimsEnsureJwtId(auto_jti_claims);
    println(auto_jti_1.2 == nil);
    if (auto_jti_1.2 == nil) {
        auto_jti_claims = auto_jti_1.0;
        println(len(auto_jti_1.1) == 36);
        println(substring(auto_jti_1.1, 8, 1) == "-");
        println((mapGetString(auto_jti_claims, "jti") as string) == auto_jti_1.1);

        var auto_jti_2 = cryptoSignedJsonClaimsEnsureJwtId(auto_jti_claims);
        println(auto_jti_2.2 == nil);
        if (auto_jti_2.2 == nil) {
            println(auto_jti_2.1 == auto_jti_1.1);
        }
    }

    var auto_jti_empty_claims = cryptoSignedJsonClaimsNew();
    mapSetString(auto_jti_empty_claims, "jti", "");
    var auto_jti_empty = cryptoSignedJsonClaimsEnsureJwtId(auto_jti_empty_claims);
    println(auto_jti_empty.2 != nil);

    var auto_jti_bad_type_claims = cryptoSignedJsonClaimsNew();
    mapSetString(auto_jti_bad_type_claims, "jti", 7);
    var auto_jti_bad_type = cryptoSignedJsonClaimsEnsureJwtId(auto_jti_bad_type_claims);
    println(auto_jti_bad_type.2 != nil);

    var auto_issue_claims = cryptoSignedJsonClaimsNew();
    mapSetString(auto_issue_claims, "role", "member");
    var auto_issue_sub = cryptoSignedJsonClaimsSetSubject(auto_issue_claims, "issue-user");
    println(auto_issue_sub.1 == nil);
    if (auto_issue_sub.1 == nil) {
        auto_issue_claims = auto_issue_sub.0;
    }
    var auto_issue_iss = cryptoSignedJsonClaimsSetIssuer(auto_issue_claims, "issue-issuer");
    println(auto_issue_iss.1 == nil);
    if (auto_issue_iss.1 == nil) {
        auto_issue_claims = auto_issue_iss.0;
    }
    var auto_issue_aud = cryptoSignedJsonClaimsSetAudience(auto_issue_claims, "issue-api");
    println(auto_issue_aud.1 == nil);
    if (auto_issue_aud.1 == nil) {
        auto_issue_claims = auto_issue_aud.0;
    }

    var auto_issue_policy: CryptoSignedJsonClaimsValidationPolicy = {
        issuer: "issue-issuer",
        audience: "issue-api",
        requireIssuer: true,
        requireAudience: true,
        requireNotBefore: false,
        requireJti: true,
        clockSkewMillis: 0
    };
    var auto_issue = cryptoSignedJsonClaimsSealTextWithAutoJwtId("issue-secret",
                                                                 auto_issue_claims,
                                                                 1000,
                                                                 4000);
    println(auto_issue.2 == nil);
    if (auto_issue.2 == nil) {
        println(len(auto_issue.1) == 36);

        var auto_issue_verify = cryptoSignedJsonClaimsVerifyTextWithPolicy("issue-secret",
                                                                           auto_issue.0,
                                                                           1500,
                                                                           auto_issue_policy);
        println(auto_issue_verify.3 == nil);
        if (auto_issue_verify.3 == nil) {
            println(auto_issue_verify.0 == true);
            println((mapGetString(auto_issue_verify.2.claims, "jti") as string) == auto_issue.1);
            println((mapGetString(auto_issue_verify.2.claims, "role") as string) == "member");
        }

        var auto_revocations = cryptoSignedJsonClaimsRevocationStoreNew();
        var auto_revoke = cryptoSignedJsonClaimsRevocationStoreRevokeId(auto_revocations,
                                                                        auto_issue.1,
                                                                        4000);
        println(auto_revoke.1 == nil);
        if (auto_revoke.1 == nil) {
            auto_revocations = auto_revoke.0;
            var auto_revoked_verify = cryptoSignedJsonClaimsVerifyTextWithPolicyAndRevocation("issue-secret",
                                                                                              auto_issue.0,
                                                                                              1500,
                                                                                              auto_issue_policy,
                                                                                              auto_revocations);
            println(auto_revoked_verify.5 == nil);
            if (auto_revoked_verify.5 == nil) {
                println(auto_revoked_verify.0 == false);
                println(auto_revoked_verify.2 == true);
            }
        }
    }

    var auto_issue_existing_claims = cryptoSignedJsonClaimsNew();
    var auto_issue_existing_jti = cryptoSignedJsonClaimsSetJwtId(auto_issue_existing_claims, "manual-jti");
    println(auto_issue_existing_jti.1 == nil);
    if (auto_issue_existing_jti.1 == nil) {
        auto_issue_existing_claims = auto_issue_existing_jti.0;
        var auto_issue_existing = cryptoSignedJsonClaimsSealTextWithAutoJwtId("issue-secret",
                                                                              auto_issue_existing_claims,
                                                                              1000,
                                                                              4000);
        println(auto_issue_existing.2 == nil);
        if (auto_issue_existing.2 == nil) {
            println(auto_issue_existing.1 == "manual-jti");
        }
    }

    var auto_issue_kid_claims = cryptoSignedJsonClaimsNew();
    var auto_issue_kid_sub = cryptoSignedJsonClaimsSetSubject(auto_issue_kid_claims, "kid-user");
    println(auto_issue_kid_sub.1 == nil);
    if (auto_issue_kid_sub.1 == nil) {
        auto_issue_kid_claims = auto_issue_kid_sub.0;
    }
    var auto_issue_kid = cryptoSignedJsonClaimsSealTextWithKeyIdAndAutoJwtIdTtl("kid-secret",
                                                                                 "kid-1",
                                                                                 auto_issue_kid_claims,
                                                                                 60000);
    println(auto_issue_kid.2 == nil);
    if (auto_issue_kid.2 == nil) {
        println(len(auto_issue_kid.1) == 36);
        var auto_issue_kid_ring: map<string, string> = {};
        mapSetString(auto_issue_kid_ring, "kid-1", "kid-secret");
        var auto_issue_kid_verify = cryptoSignedJsonClaimsVerifyTextKeyRing(auto_issue_kid_ring,
                                                                            auto_issue_kid.0,
                                                                            timeNowMillis());
        println(auto_issue_kid_verify.4 == nil);
        if (auto_issue_kid_verify.4 == nil) {
            println(auto_issue_kid_verify.0 == true);
            println((mapGetString(auto_issue_kid_verify.3.claims, "jti") as string) == auto_issue_kid.1);
        }
    }
}

func runSessionTokenWrapperTests(): void {
    var default_config = cryptoSessionTokenDefaultConfig();
    println(default_config.ttlMillis == 900000);
    println(default_config.clockSkewMillis == 30000);
    println(default_config.includeNotBefore == true);
    println(default_config.keyId == nil);

    var invalid_ttl_config = cryptoSessionTokenDefaultConfig();
    invalid_ttl_config.ttlMillis = 0;
    var invalid_ttl_issue = cryptoSessionTokenIssueText("session-secret",
                                                        invalid_ttl_config,
                                                        "user-1",
                                                        {},
                                                        1000);
    println(invalid_ttl_issue.1 != nil);

    var invalid_key_id_config = cryptoSessionTokenDefaultConfig();
    invalid_key_id_config.keyId = "";
    var invalid_key_id_issue = cryptoSessionTokenIssueText("session-secret",
                                                           invalid_key_id_config,
                                                           "user-1",
                                                           {},
                                                           1000);
    println(invalid_key_id_issue.1 != nil);

    var session_config = cryptoSessionTokenDefaultConfig();
    session_config.issuer = "session-issuer";
    session_config.audience = "session-api";
    session_config.ttlMillis = 5000;
    session_config.clockSkewMillis = 50;

    var session_claims: map<string, any> = {
        "role": "admin",
        "sub": "wrong-subject",
        "iss": "wrong-issuer",
        "aud": "wrong-audience",
        "nbf": 7
    };
    var issued = cryptoSessionTokenIssueText("session-secret",
                                             session_config,
                                             "user-1",
                                             session_claims,
                                             1000);
    println(issued.1 == nil);
    if (issued.1 == nil) {
        println(issued.0.subject == "user-1");
        println(issued.0.keyId == nil);
        println(len(issued.0.jwtId) == 36);
        println(issued.0.issuedAtMillis == 1000);
        println(issued.0.expiresAtMillis == 6000);

        var verify_store = cryptoSignedJsonClaimsRevocationStoreNew();
        var verified = cryptoSessionTokenVerifyText("session-secret",
                                                    session_config,
                                                    issued.0.token,
                                                    1200,
                                                    verify_store);
        println(verified.1 == nil);
        if (verified.1 == nil) {
            println(verified.0.ok == true);
            println(verified.0.expired == false);
            println(verified.0.revoked == false);
            println((verified.0.subject as string) == "user-1");
            println((verified.0.jwtId as string) == issued.0.jwtId);
            println(verified.0.keyId == nil);
            println((mapGetString(verified.0.claims.claims, "role") as string) == "admin");
            println((mapGetString(verified.0.claims.claims, "sub") as string) == "user-1");
            println((mapGetString(verified.0.claims.claims, "iss") as string) == "session-issuer");
            println((mapGetString(verified.0.claims.claims, "aud") as string) == "session-api");
            println((mapGetString(verified.0.claims.claims, "nbf") as int) == 1000);

            verify_store = verified.0.revocations;
            var revoked_issued = cryptoSessionTokenRevokeIssued(verify_store, issued.0);
            println(revoked_issued.1 == nil);
            if (revoked_issued.1 == nil) {
                verify_store = revoked_issued.0;
                var revoked_verify = cryptoSessionTokenVerifyText("session-secret",
                                                                  session_config,
                                                                  issued.0.token,
                                                                  1200,
                                                                  verify_store);
                println(revoked_verify.1 == nil);
                if (revoked_verify.1 == nil) {
                    println(revoked_verify.0.ok == false);
                    println(revoked_verify.0.expired == false);
                    println(revoked_verify.0.revoked == true);
                    println((revoked_verify.0.jwtId as string) == issued.0.jwtId);
                }
            }
        }

        var expired = cryptoSessionTokenVerifyText("session-secret",
                                                   session_config,
                                                   issued.0.token,
                                                   7000,
                                                   cryptoSignedJsonClaimsRevocationStoreNew());
        println(expired.1 == nil);
        if (expired.1 == nil) {
            println(expired.0.ok == false);
            println(expired.0.expired == true);
            println(expired.0.revoked == false);
        }
    }

    var missing_subject_claims: map<string, any> = {
        "iss": "session-issuer",
        "aud": "session-api",
        "nbf": 1000,
        "jti": "manual-jti"
    };
    var missing_subject_token = cryptoSignedJsonClaimsSealText("session-secret",
                                                               missing_subject_claims,
                                                               1000,
                                                               6000);
    println(missing_subject_token.1 == nil);
    if (missing_subject_token.1 == nil) {
        var missing_subject_verify = cryptoSessionTokenVerifyText("session-secret",
                                                                  session_config,
                                                                  missing_subject_token.0,
                                                                  1200,
                                                                  cryptoSignedJsonClaimsRevocationStoreNew());
        println(missing_subject_verify.1 == nil);
        if (missing_subject_verify.1 == nil) {
            println(missing_subject_verify.0.ok == false);
            println(missing_subject_verify.0.expired == false);
            println(missing_subject_verify.0.revoked == false);
            println(missing_subject_verify.0.subject == nil);
            println((missing_subject_verify.0.jwtId as string) == "manual-jti");
        }
    }

    var issue_now = cryptoSessionTokenIssueTextNow("session-secret",
                                                   session_config,
                                                   "now-user",
                                                   {});
    println(issue_now.1 == nil);
    if (issue_now.1 == nil) {
        println(issue_now.0.expiresAtMillis > issue_now.0.issuedAtMillis);
        var verify_now = cryptoSessionTokenVerifyTextNow("session-secret",
                                                         session_config,
                                                         issue_now.0.token,
                                                         cryptoSignedJsonClaimsRevocationStoreNew());
        println(verify_now.1 == nil);
        if (verify_now.1 == nil) {
            println(verify_now.0.ok == true);
            println((verify_now.0.subject as string) == "now-user");
        }
    }

    var key_ring_config = cryptoSessionTokenDefaultConfig();
    key_ring_config.issuer = "session-issuer";
    key_ring_config.audience = "session-api";
    key_ring_config.keyId = "k2";
    key_ring_config.ttlMillis = 5000;

    var key_ring_claims: map<string, any> = {
        "scope": "session"
    };
    var key_ring_issue = cryptoSessionTokenIssueText("new-secret",
                                                     key_ring_config,
                                                     "ring-user",
                                                     key_ring_claims,
                                                     2000);
    println(key_ring_issue.1 == nil);
    if (key_ring_issue.1 == nil) {
        println((key_ring_issue.0.keyId as string) == "k2");

        var key_ring: map<string, string> = {};
        mapSetString(key_ring, "k1", "old-secret");
        mapSetString(key_ring, "k2", "new-secret");

        var key_ring_verify = cryptoSessionTokenVerifyTextKeyRing(key_ring,
                                                                  key_ring_config,
                                                                  key_ring_issue.0.token,
                                                                  2300,
                                                                  cryptoSignedJsonClaimsRevocationStoreNew());
        println(key_ring_verify.1 == nil);
        if (key_ring_verify.1 == nil) {
            println(key_ring_verify.0.ok == true);
            println(key_ring_verify.0.expired == false);
            println(key_ring_verify.0.revoked == false);
            println((key_ring_verify.0.keyId as string) == "k2");
            println((key_ring_verify.0.subject as string) == "ring-user");
            println((key_ring_verify.0.jwtId as string) == key_ring_issue.0.jwtId);
            println((mapGetString(key_ring_verify.0.claims.claims, "scope") as string) == "session");

            var revoke_verified = cryptoSessionTokenRevokeVerified(key_ring_verify.0.revocations,
                                                                   key_ring_verify.0);
            println(revoke_verified.1 == nil);
            if (revoke_verified.1 == nil) {
                var key_ring_revoked = cryptoSessionTokenVerifyTextKeyRing(key_ring,
                                                                           key_ring_config,
                                                                           key_ring_issue.0.token,
                                                                           2300,
                                                                           revoke_verified.0);
                println(key_ring_revoked.1 == nil);
                if (key_ring_revoked.1 == nil) {
                    println(key_ring_revoked.0.ok == false);
                    println(key_ring_revoked.0.revoked == true);
                    println((key_ring_revoked.0.keyId as string) == "k2");
                }
            }
        }

        var key_ring_issue_now = cryptoSessionTokenIssueTextNow("new-secret",
                                                                key_ring_config,
                                                                "ring-now",
                                                                {});
        println(key_ring_issue_now.1 == nil);
        if (key_ring_issue_now.1 == nil) {
            var key_ring_verify_now = cryptoSessionTokenVerifyTextKeyRingNow(key_ring,
                                                                             key_ring_config,
                                                                             key_ring_issue_now.0.token,
                                                                             cryptoSignedJsonClaimsRevocationStoreNew());
            println(key_ring_verify_now.1 == nil);
            if (key_ring_verify_now.1 == nil) {
                println(key_ring_verify_now.0.ok == true);
                println((key_ring_verify_now.0.subject as string) == "ring-now");
            }
        }
    }
}

func runSessionTokenPairTests(): void {
    var default_pair_config = cryptoSessionTokenPairDefaultConfig();
    println(default_pair_config.access.ttlMillis == 900000);
    println(default_pair_config.refresh.ttlMillis == 2592000000);
    println(default_pair_config.access.includeNotBefore == true);
    println(default_pair_config.refresh.includeNotBefore == true);

    var invalid_pair_config = cryptoSessionTokenPairDefaultConfig();
    invalid_pair_config.refresh.ttlMillis = 0;
    var invalid_pair_issue = cryptoSessionTokenPairIssueText("access-secret",
                                                             "refresh-secret",
                                                             invalid_pair_config,
                                                             "pair-user",
                                                             {},
                                                             {},
                                                             1000);
    println(invalid_pair_issue.1 != nil);

    var pair_config = cryptoSessionTokenPairDefaultConfig();
    pair_config.access.issuer = "pair-issuer";
    pair_config.access.audience = "pair-api";
    pair_config.access.ttlMillis = 5000;
    pair_config.refresh.issuer = "pair-issuer";
    pair_config.refresh.audience = "pair-refresh";
    pair_config.refresh.keyId = "rk2";
    pair_config.refresh.ttlMillis = 20000;
    pair_config.refresh.clockSkewMillis = 100;

    var access_claims: map<string, any> = {
        "role": "reader",
        "tokenKind": "wrong-kind",
        "sid": "wrong-session-id"
    };
    var refresh_claims: map<string, any> = {
        "scope": "offline"
    };
    var issued_pair = cryptoSessionTokenPairIssueText("access-secret",
                                                      "refresh-secret",
                                                      pair_config,
                                                      "pair-user",
                                                      access_claims,
                                                      refresh_claims,
                                                      1000);
    println(issued_pair.1 == nil);
    if (issued_pair.1 == nil) {
        println(len(issued_pair.0.sessionId) == 36);
        println(issued_pair.0.access.subject == "pair-user");
        println(issued_pair.0.refresh.subject == "pair-user");
        println(issued_pair.0.access.issuedAtMillis == 1000);
        println(issued_pair.0.access.expiresAtMillis == 6000);
        println((issued_pair.0.refresh.keyId as string) == "rk2");
        println(issued_pair.0.refresh.expiresAtMillis == 21000);

        var access_verify = cryptoSessionTokenPairVerifyAccessText("access-secret",
                                                                   pair_config,
                                                                   issued_pair.0.access.token,
                                                                   1200,
                                                                   cryptoSignedJsonClaimsRevocationStoreNew());
        println(access_verify.1 == nil);
        if (access_verify.1 == nil) {
            println(access_verify.0.ok == true);
            println(access_verify.0.expired == false);
            println(access_verify.0.revoked == false);
            println((access_verify.0.subject as string) == "pair-user");
            println((access_verify.0.sessionId as string) == issued_pair.0.sessionId);
            println((access_verify.0.tokenKind as string) == "access");
            println((mapGetString(access_verify.0.claims.claims, "role") as string) == "reader");
            println((mapGetString(access_verify.0.claims.claims, "tokenKind") as string) == "access");
            println((mapGetString(access_verify.0.claims.claims, "sid") as string) == issued_pair.0.sessionId);

            var wrong_pair_kind = cryptoSessionTokenPairValidateRefresh(access_verify.0);
            println(wrong_pair_kind.ok == false);
            println((wrong_pair_kind.tokenKind as string) == "access");
            println((wrong_pair_kind.sessionId as string) == issued_pair.0.sessionId);
        }

        var refresh_verify = cryptoSessionTokenPairVerifyRefreshText("refresh-secret",
                                                                     pair_config,
                                                                     issued_pair.0.refresh.token,
                                                                     1200,
                                                                     cryptoSignedJsonClaimsRevocationStoreNew());
        println(refresh_verify.1 == nil);
        if (refresh_verify.1 == nil) {
            println(refresh_verify.0.ok == true);
            println(refresh_verify.0.expired == false);
            println(refresh_verify.0.revoked == false);
            println((refresh_verify.0.subject as string) == "pair-user");
            println((refresh_verify.0.sessionId as string) == issued_pair.0.sessionId);
            println((refresh_verify.0.tokenKind as string) == "refresh");
            println((refresh_verify.0.keyId as string) == "rk2");
            println((mapGetString(refresh_verify.0.claims.claims, "scope") as string) == "offline");
        }

        var revoked_pair_store = cryptoSignedJsonClaimsRevocationStoreNew();
        var revoked_pair = cryptoSessionTokenPairRevokeIssued(revoked_pair_store, issued_pair.0);
        println(revoked_pair.1 == nil);
        if (revoked_pair.1 == nil) {
            revoked_pair_store = revoked_pair.0;
            println(cryptoSignedJsonClaimsRevocationStoreCount(revoked_pair_store) == 2);

            var access_revoked = cryptoSessionTokenPairVerifyAccessText("access-secret",
                                                                        pair_config,
                                                                        issued_pair.0.access.token,
                                                                        1200,
                                                                        revoked_pair_store);
            println(access_revoked.1 == nil);
            if (access_revoked.1 == nil) {
                println(access_revoked.0.ok == false);
                println(access_revoked.0.revoked == true);
            }

            var refresh_revoked = cryptoSessionTokenPairVerifyRefreshText("refresh-secret",
                                                                          pair_config,
                                                                          issued_pair.0.refresh.token,
                                                                          1200,
                                                                          revoked_pair_store);
            println(refresh_revoked.1 == nil);
            if (refresh_revoked.1 == nil) {
                println(refresh_revoked.0.ok == false);
                println(refresh_revoked.0.revoked == true);
            }
        }

        var refresh_key_ring: map<string, string> = {};
        mapSetString(refresh_key_ring, "rk1", "old-refresh");
        mapSetString(refresh_key_ring, "rk2", "refresh-secret");
        var refresh_key_ring_verify = cryptoSessionTokenVerifyTextKeyRing(refresh_key_ring,
                                                                          pair_config.refresh,
                                                                          issued_pair.0.refresh.token,
                                                                          1200,
                                                                          cryptoSignedJsonClaimsRevocationStoreNew());
        println(refresh_key_ring_verify.1 == nil);
        if (refresh_key_ring_verify.1 == nil) {
            var refresh_key_ring_validated = cryptoSessionTokenPairValidateRefresh(refresh_key_ring_verify.0);
            println(refresh_key_ring_validated.ok == true);
            println((refresh_key_ring_validated.keyId as string) == "rk2");
            println((refresh_key_ring_validated.sessionId as string) == issued_pair.0.sessionId);
            println((refresh_key_ring_validated.tokenKind as string) == "refresh");
        }
    }

    var invalid_sid_claims: map<string, any> = {
        "sid": "not-a-uuid",
        "tokenKind": "access"
    };
    var invalid_sid_token = cryptoSessionTokenIssueText("access-secret",
                                                        pair_config.access,
                                                        "pair-user",
                                                        invalid_sid_claims,
                                                        1000);
    println(invalid_sid_token.1 == nil);
    if (invalid_sid_token.1 == nil) {
        var invalid_sid_verify = cryptoSessionTokenPairVerifyAccessText("access-secret",
                                                                        pair_config,
                                                                        invalid_sid_token.0.token,
                                                                        1200,
                                                                        cryptoSignedJsonClaimsRevocationStoreNew());
        println(invalid_sid_verify.1 == nil);
        if (invalid_sid_verify.1 == nil) {
            println(invalid_sid_verify.0.ok == false);
            println(invalid_sid_verify.0.sessionId == nil);
            println((invalid_sid_verify.0.tokenKind as string) == "access");
        }
    }

    var issued_pair_now = cryptoSessionTokenPairIssueTextNow("access-secret",
                                                             "refresh-secret",
                                                             pair_config,
                                                             "pair-now",
                                                             {},
                                                             {});
    println(issued_pair_now.1 == nil);
    if (issued_pair_now.1 == nil) {
        println(len(issued_pair_now.0.sessionId) == 36);
        var verify_pair_now = cryptoSessionTokenPairVerifyAccessText("access-secret",
                                                                     pair_config,
                                                                     issued_pair_now.0.access.token,
                                                                     timeNowMillis(),
                                                                     cryptoSignedJsonClaimsRevocationStoreNew());
        println(verify_pair_now.1 == nil);
        if (verify_pair_now.1 == nil) {
            println(verify_pair_now.0.ok == true);
            println((verify_pair_now.0.subject as string) == "pair-now");
        }
    }
}

func runSessionTokenPairRotationTests(): void {
    var pair_config = cryptoSessionTokenPairDefaultConfig();
    pair_config.access.issuer = "rotate-issuer";
    pair_config.access.audience = "rotate-api";
    pair_config.access.ttlMillis = 5000;
    pair_config.refresh.issuer = "rotate-issuer";
    pair_config.refresh.audience = "rotate-refresh";
    pair_config.refresh.ttlMillis = 20000;

    var issued_pair = cryptoSessionTokenPairIssueText("access-secret",
                                                      "refresh-secret",
                                                      pair_config,
                                                      "rotate-user",
                                                      {
                                                          "role": "reader"
                                                      },
                                                      {
                                                          "scope": "offline",
                                                          "family": "fam-1"
                                                      },
                                                      1000);
    println(issued_pair.1 == nil);
    if (issued_pair.1 == nil) {
        var rotate = cryptoSessionTokenPairRotateRefreshText("access-secret",
                                                             "refresh-secret",
                                                             pair_config,
                                                             issued_pair.0.refresh.token,
                                                             2000,
                                                             cryptoSignedJsonClaimsRevocationStoreNew(),
                                                             {
                                                                 "role": "writer"
                                                             },
                                                             {});
        println(rotate.1 == nil);
        if (rotate.1 == nil) {
            println(rotate.0.ok == true);
            println(rotate.0.expired == false);
            println(rotate.0.revoked == false);
            println((rotate.0.sessionId as string) == issued_pair.0.sessionId);
            println((rotate.0.previousRefreshJwtId as string) == issued_pair.0.refresh.jwtId);
            println(cryptoSignedJsonClaimsRevocationStoreCount(rotate.0.revocations) == 1);
            println(rotate.0.pair.sessionId == issued_pair.0.sessionId);
            println(rotate.0.pair.access.subject == "rotate-user");
            println(rotate.0.pair.refresh.subject == "rotate-user");
            println(rotate.0.pair.refresh.jwtId != issued_pair.0.refresh.jwtId);

            var old_refresh = cryptoSessionTokenPairVerifyRefreshText("refresh-secret",
                                                                      pair_config,
                                                                      issued_pair.0.refresh.token,
                                                                      2500,
                                                                      rotate.0.revocations);
            println(old_refresh.1 == nil);
            if (old_refresh.1 == nil) {
                println(old_refresh.0.ok == false);
                println(old_refresh.0.revoked == true);
            }

            var new_refresh = cryptoSessionTokenPairVerifyRefreshText("refresh-secret",
                                                                      pair_config,
                                                                      rotate.0.pair.refresh.token,
                                                                      2500,
                                                                      rotate.0.revocations);
            println(new_refresh.1 == nil);
            if (new_refresh.1 == nil) {
                println(new_refresh.0.ok == true);
                println((new_refresh.0.sessionId as string) == issued_pair.0.sessionId);
                println((new_refresh.0.tokenKind as string) == "refresh");
                println((mapGetString(new_refresh.0.claims.claims, "scope") as string) == "offline");
                println((mapGetString(new_refresh.0.claims.claims, "family") as string) == "fam-1");
            }

            var new_access = cryptoSessionTokenPairVerifyAccessText("access-secret",
                                                                    pair_config,
                                                                    rotate.0.pair.access.token,
                                                                    2500,
                                                                    rotate.0.revocations);
            println(new_access.1 == nil);
            if (new_access.1 == nil) {
                println(new_access.0.ok == true);
                println((new_access.0.sessionId as string) == issued_pair.0.sessionId);
                println((new_access.0.tokenKind as string) == "access");
                println((mapGetString(new_access.0.claims.claims, "role") as string) == "writer");
            }
        }

        var rotate_with_access = cryptoSessionTokenPairRotateRefreshText("access-secret",
                                                                         "refresh-secret",
                                                                         pair_config,
                                                                         issued_pair.0.access.token,
                                                                         2000,
                                                                         cryptoSignedJsonClaimsRevocationStoreNew(),
                                                                         {},
                                                                         {});
        println(rotate_with_access.1 == nil);
        if (rotate_with_access.1 == nil) {
            println(rotate_with_access.0.ok == false);
            println(rotate_with_access.0.expired == false);
            println(rotate_with_access.0.revoked == false);
            println(rotate_with_access.0.sessionId == nil);
            println(rotate_with_access.0.previousRefreshJwtId == nil);
        }

        var rotate_expired = cryptoSessionTokenPairRotateRefreshText("access-secret",
                                                                     "refresh-secret",
                                                                     pair_config,
                                                                     issued_pair.0.refresh.token,
                                                                     25000,
                                                                     cryptoSignedJsonClaimsRevocationStoreNew(),
                                                                     {},
                                                                     {});
        println(rotate_expired.1 == nil);
        if (rotate_expired.1 == nil) {
            println(rotate_expired.0.ok == false);
            println(rotate_expired.0.expired == true);
            println(rotate_expired.0.revoked == false);
            println((rotate_expired.0.previousRefreshJwtId as string) == issued_pair.0.refresh.jwtId);
        }

        var revoked_refresh_store = cryptoSignedJsonClaimsRevocationStoreNew();
        var revoke_old_refresh = cryptoSessionTokenRevokeIssued(revoked_refresh_store, issued_pair.0.refresh);
        println(revoke_old_refresh.1 == nil);
        if (revoke_old_refresh.1 == nil) {
            revoked_refresh_store = revoke_old_refresh.0;
            var rotate_revoked = cryptoSessionTokenPairRotateRefreshText("access-secret",
                                                                         "refresh-secret",
                                                                         pair_config,
                                                                         issued_pair.0.refresh.token,
                                                                         2000,
                                                                         revoked_refresh_store,
                                                                         {},
                                                                         {});
            println(rotate_revoked.1 == nil);
            if (rotate_revoked.1 == nil) {
                println(rotate_revoked.0.ok == false);
                println(rotate_revoked.0.expired == false);
                println(rotate_revoked.0.revoked == true);
            }
        }
    }

    var issued_pair_now = cryptoSessionTokenPairIssueTextNow("access-secret",
                                                             "refresh-secret",
                                                             pair_config,
                                                             "rotate-now",
                                                             {},
                                                             {
                                                                 "scope": "offline"
                                                             });
    println(issued_pair_now.1 == nil);
    if (issued_pair_now.1 == nil) {
        var rotate_now = cryptoSessionTokenPairRotateRefreshTextNow("access-secret",
                                                                    "refresh-secret",
                                                                    pair_config,
                                                                    issued_pair_now.0.refresh.token,
                                                                    cryptoSignedJsonClaimsRevocationStoreNew(),
                                                                    {},
                                                                    {});
        println(rotate_now.1 == nil);
        if (rotate_now.1 == nil) {
            println(rotate_now.0.ok == true);
            println((rotate_now.0.sessionId as string) == issued_pair_now.0.sessionId);
            println(rotate_now.0.pair.sessionId == issued_pair_now.0.sessionId);
        }
    }
}

func main(): void {
    var empty_sha = cryptoSha256TextHex("");
