            revocations = purge_after.0;
            println(purge_after.1 == 1);
            println(cryptoSignedJsonClaimsRevocationStoreCount(revocations) == 0);
        }
    }

    if (claims_token.1 == nil) {
        var claims_without_jti = cryptoSignedJsonClaimsDecodeUnverified(claims_token.0);
        println(claims_without_jti.1 == nil);
        if (claims_without_jti.1 == nil) {
            var revoke_missing_jti = cryptoSignedJsonClaimsRevocationStoreRevoke(revocations,
                                                                                 claims_without_jti.0);
            println(revoke_missing_jti.1 != nil);
        }
    }

    var revoke_bad_id = cryptoSignedJsonClaimsRevocationStoreRevokeId(revocations, "", 3000);
    println(revoke_bad_id.1 != nil);

    var revoke_bad_expiry = cryptoSignedJsonClaimsRevocationStoreRevokeId(revocations,
                                                                          "token-1",
                                                                          0);
    println(revoke_bad_expiry.1 != nil);

    runAutoJtiSessionTests();
    runSessionTokenWrapperTests();
    runSessionTokenPairTests();
    runSessionTokenPairRotationTests();
}
