    var gcm_nonce_zero = hexToBytes("000000000000000000000000");
    println(gcm_key_zero.1 == nil);
    println(gcm_nonce_zero.1 == nil);
    if (gcm_key_zero.1 == nil && gcm_nonce_zero.1 == nil) {
        var gcm_empty = cryptoAesGcmSeal(gcm_key_zero.0,
                                         gcm_nonce_zero.0,
                                         bytesWithSize(0, 0).0,
                                         bytesWithSize(0, 0).0);
        println(gcm_empty.1 == nil);
        if (gcm_empty.1 == nil) {
            var gcm_empty_hex = bytesToHex(gcm_empty.0);
            println(gcm_empty_hex.1 == nil);
            if (gcm_empty_hex.1 == nil) println(gcm_empty_hex.0 == "58e2fccefa7e3061367f1d57a4e7455a");

