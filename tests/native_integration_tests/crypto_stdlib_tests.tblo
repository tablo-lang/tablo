    var gcm_key = hexToBytes("feffe9928665731c6d6a8f9467308308");
    var gcm_nonce = hexToBytes("cafebabefacedbaddecaf888");
    var gcm_aad = hexToBytes("feedfacedeadbeeffeedfacedeadbeefabaddad2");
    var gcm_plain = hexToBytes("d9313225f88406e5a55909c5aff5269a"
                               + "86a7a9531534f7da2e4c303d8a318a72"
                               + "1c3c0c95956809532fcf0e2449a6b525"
                               + "b16aedf5aa0de657ba637b39");
    println(gcm_key.1 == nil);
    println(gcm_nonce.1 == nil);
    println(gcm_aad.1 == nil);
    println(gcm_plain.1 == nil);
    if (gcm_key.1 == nil && gcm_nonce.1 == nil && gcm_aad.1 == nil && gcm_plain.1 == nil) {
        var gcm_sealed = cryptoAesGcmSeal(gcm_key.0, gcm_nonce.0, gcm_plain.0, gcm_aad.0);
        println(gcm_sealed.1 == nil);
        if (gcm_sealed.1 == nil) {
            var gcm_sealed_hex = bytesToHex(gcm_sealed.0);
            println(gcm_sealed_hex.1 == nil);
            if (gcm_sealed_hex.1 == nil) println(gcm_sealed_hex.0 == "42831ec2217774244b7221b784d0d49c"
                                                                          + "e3aa212f2c02a4e035c17e2329aca12e"
                                                                          + "21d514b25466931c7d8f6a5aac84aa05"
                                                                          + "1ba30b396a0aac973d58e0915bc94fbc"
                                                                          + "3221a5db94fae95ae7121a47");

