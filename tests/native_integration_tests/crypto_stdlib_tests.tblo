                        println(gcm_zero_open_detached_hex.1 == nil);
                        if (gcm_zero_open_detached_hex.1 == nil) println(gcm_zero_open_detached_hex.0 == "00000000000000000000000000000000");
                    }

                    var gcm_zero_detached_hex = cryptoAesGcmSealDetachedHex(gcm_key_zero.0,
                                                                            gcm_nonce_zero.0,
                                                                            gcm_zero_plain.0,
                                                                            bytesWithSize(0, 0).0);
                    println(gcm_zero_detached_hex.2 == nil);
                    if (gcm_zero_detached_hex.2 == nil) {
                        println(gcm_zero_detached_hex.0 == "0388dace60b6a392f328c2b971b2fe78");
                        println(gcm_zero_detached_hex.1 == "ab6e47d42cec13bdf53a67b21257bddf");
                    }

                    var gcm_zero_bad_detached = cryptoAesGcmOpenDetached(gcm_key_zero.0,
                                                                         gcm_nonce_zero.0,
                                                                         gcm_zero_detached.0,
                                                                         bytesWithSize(1, 0).0,
                                                                         bytesWithSize(0, 0).0);
                    println(gcm_zero_bad_detached.1 != nil);
