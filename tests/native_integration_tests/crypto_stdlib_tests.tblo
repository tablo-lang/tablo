    if (hkdf_zero.1 == nil) println(len(hkdf_zero.0) == 0);

    var ct_left = stringToBytes("shared-secret");
    var ct_same = stringToBytes("shared-secret");
    var ct_other = stringToBytes("shared-secreu");
    var ct_short = stringToBytes("shared");
    println(ct_left.1 == nil);
    println(ct_same.1 == nil);
    println(ct_other.1 == nil);
    println(ct_short.1 == nil);
    if (ct_left.1 == nil && ct_same.1 == nil && ct_other.1 == nil && ct_short.1 == nil) {
        var ct_equal = cryptoConstantTimeBytesEqual(ct_left.0, ct_same.0);
        println(ct_equal.1 == nil);
        if (ct_equal.1 == nil) println(ct_equal.0 == true);

        var ct_diff = cryptoConstantTimeBytesEqual(ct_left.0, ct_other.0);
        println(ct_diff.1 == nil);
        if (ct_diff.1 == nil) println(ct_diff.0 == false);

        var ct_len = cryptoConstantTimeBytesEqual(ct_left.0, ct_short.0);
        println(ct_len.1 == nil);
        if (ct_len.1 == nil) println(ct_len.0 == false);
    }

    var ct_text_equal = cryptoConstantTimeTextEqual("abc", "abc");
    println(ct_text_equal.1 == nil);
    if (ct_text_equal.1 == nil) println(ct_text_equal.0 == true);

    var ct_text_diff = cryptoConstantTimeTextEqual("abc", "abd");
