        println(bad_counter.1 != nil);
    }

    if (aes_ctr.1 == nil && aes_plain.1 == nil) {
        var bad_key = cryptoAesCtrEncrypt(hexToBytes("001122334455").0, aes_ctr.0, aes_plain.0);
        println(bad_key.1 != nil);
    }

    if (aes_ctr.1 == nil && aes_key_128.1 == nil) {
        var aes_empty = cryptoAesCtrEncrypt(aes_key_128.0, aes_ctr.0, bytesWithSize(0, 0).0);
        println(aes_empty.1 == nil);
        if (aes_empty.1 == nil) println(len(aes_empty.0) == 0);
