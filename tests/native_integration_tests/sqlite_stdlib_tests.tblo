import "fixtures/sqlite.tblo";

func printTrueN(count: int): void {
    var i: int = 0;
    while (i < count) {
        println(true);
        i = i + 1;
    }
}

func runPreparedTypedWrappersTests(stmt: SqliteStatement, schema: map<string, any>): void {
    var many_typed = sqliteQueryPreparedAllAs(stmt, [5 as any], schema);
    println(many_typed.1 == nil);
    if (many_typed.1 == nil) {
        println(len(many_typed.0) == 1);
        if (len(many_typed.0) == 1) {
            var many_typed_row: map<string, any> = many_typed.0[0] as map<string, any>;
            println((mapGetString(many_typed_row, "name") as string) == "dina");
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
    }

    var onep_typed = sqliteQueryPreparedOneAs(stmt, [5 as any], schema);
    println(onep_typed.1 == nil);
    if (onep_typed.1 == nil) {
        println(onep_typed.0 != nil);
        if (onep_typed.0 != nil) {
            var onep_typed_row: map<string, any> = onep_typed.0 as map<string, any>;
            println((mapGetString(onep_typed_row, "name") as string) == "dina");
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
    }
}

func runPreparedManyAndTxBatchTests(db: SqliteDb): void {
    var bulk_insert = sqlitePrepareQuery(db, "insert into users(id, name, age) values (?1, ?2, ?3);");
    println(bulk_insert.1 == nil);
    if (bulk_insert.1 == nil) {
        var bulk_stmt: SqliteStatement = bulk_insert.0;
        var bulk_rows: array<array<any>> = [
            [6 as any, "erin" as any, 29 as any]
        ];
        var bulk_done = sqliteExecPreparedMany(bulk_stmt, bulk_rows);
        println(bulk_done.1 == nil);
        if (bulk_done.1 == nil) {
            println(bulk_done.0 == 1);
        } else {
            println(false);
        }
        println(sqliteFinalizeStmt(bulk_stmt) == nil);
    } else {
        println(false);
        println(false);
        println(false);
    }

    var tx_batch_ok = sqliteExecBatchTx(db, [
        "update users set age = age where id = 1;"
    ]);
    println(tx_batch_ok.1 == nil);
    if (tx_batch_ok.1 == nil) {
        println(tx_batch_ok.0 == 1);
    } else {
        println(false);
    }

    var tx_batch_fail = sqliteExecBatchTx(db, [
        "insert into users(id, name, age) values (7, 'finn', 31);",
        "insert into users(id, name, age) values (1, 'dup', 99);"
    ]);
    println(tx_batch_fail.1 != nil);
    if (tx_batch_fail.1 != nil) {
        var tx_row = sqliteQueryOne(db, "select id from users where id = 7;");
        println(tx_row.1 == nil);
        if (tx_row.1 == nil) {
            println(tx_row.0 == nil);
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
    }
}

func main(): void {
    var db_path: string = "tmp_sqlite_stdlib_test_" + str(timeMonotonicMillis()) + ".db";

    var opened = sqliteOpenDb(db_path);
    if (opened.1 != nil) {
        var err: Error = opened.1 as Error;
        if (err.code == ERR_UNSUPPORTED) {
            // Keep output stable on platforms where SQLite runtime is unavailable.
            printTrueN(101);
            return;
        }
    }

    println(opened.1 == nil);
    if (opened.1 != nil) {
        printTrueN(100);
        return;
    }

    var db: SqliteDb = opened.0;
    var created = sqliteExecSql(db, "create table users(id integer primary key, name text, age integer);");
    println(created.1 == nil);
    var blob_created = sqliteExecSql(db, "create table files(id integer primary key, payload blob);");
    println(blob_created.1 == nil);

    var batch = sqliteExecBatch(db, [
        "insert into users(id, name, age) values (1, 'alice', 30);",
        "insert into users(id, name, age) values (2, 'bob', 41);",
        "update users set age = age + 1 where id = 1;"
    ]);
    println(batch.1 == nil);
    if (batch.1 == nil) {
        println(batch.0 == 3);
    } else {
        println(false);
    }

    var prepared_insert = sqlitePrepareQuery(db, "insert into users(id, name, age) values (?1, ?2, ?3);");
    println(prepared_insert.1 == nil);
    if (prepared_insert.1 == nil) {
        var insert_stmt: SqliteStatement = prepared_insert.0;
        println(sqliteBindIntParam(insert_stmt, 1, 3) == nil);
        println(sqliteBindStringParam(insert_stmt, 2, "cara") == nil);
        println(sqliteBindDoubleParam(insert_stmt, 3, 27.5) == nil);

        var insert_step1 = sqliteStepRow(insert_stmt);
        println(insert_step1.1 == nil);
        if (insert_step1.1 == nil) {
            println(insert_step1.0 == nil);
        } else {
            println(false);
        }

        var changed1 = sqliteChangesCount(db);
        println(changed1.1 == nil);
        if (changed1.1 == nil) {
            println(changed1.0 == 1);
        } else {
            println(false);
        }

        var rowid1 = sqliteLastInsertId(db);
        println(rowid1.1 == nil);
        if (rowid1.1 == nil) {
            println(rowid1.0 == 3);
        } else {
            println(false);
        }

        println(sqliteResetStmt(insert_stmt) == nil);
        println(sqliteClearStmtBindings(insert_stmt) == nil);
        println(sqliteBindIntParam(insert_stmt, 1, 4) == nil);
        println(sqliteBindNullParam(insert_stmt, 2) == nil);
        println(sqliteBindIntParam(insert_stmt, 3, 18) == nil);

        var insert_step2 = sqliteStepRow(insert_stmt);
        println(insert_step2.1 == nil);
        if (insert_step2.1 == nil) {
            println(insert_step2.0 == nil);
        } else {
            println(false);
        }

        var changed2 = sqliteChangesCount(db);
        println(changed2.1 == nil);
        if (changed2.1 == nil) {
            println(changed2.0 == 1);
        } else {
            println(false);
        }

        var rowid2 = sqliteLastInsertId(db);
        println(rowid2.1 == nil);
        if (rowid2.1 == nil) {
            println(rowid2.0 == 4);
        } else {
            println(false);
        }

        println(sqliteFinalizeStmt(insert_stmt) == nil);
    } else {
        printTrueN(24);
    }

    var payload = stringToBytes("AB");
    println(payload.1 == nil);
    if (payload.1 == nil) {
        var blob_insert = sqlitePrepareQuery(db, "insert into files(id, payload) values (?1, ?2);");
        println(blob_insert.1 == nil);
        if (blob_insert.1 == nil) {
            var blob_stmt: SqliteStatement = blob_insert.0;
            println(sqliteBindIntParam(blob_stmt, 1, 1) == nil);
            println(sqliteBindBytesParam(blob_stmt, 2, payload.0) == nil);
            var blob_step = sqliteStepRow(blob_stmt);
            println(blob_step.1 == nil);
            if (blob_step.1 == nil) {
                println(blob_step.0 == nil);
            } else {
                println(false);
            }
            println(sqliteFinalizeStmt(blob_stmt) == nil);
        } else {
            printTrueN(5);
        }
    } else {
        printTrueN(6);
    }

    var blob_row = sqliteQueryOne(db, "select payload from files where id = 1;");
    println(blob_row.1 == nil);
    if (blob_row.1 == nil && blob_row.0 != nil) {
        var blob_map: map<string, any> = blob_row.0 as map<string, any>;
        var blob_value = mapGetString(blob_map, "payload");
        println(typeOf(blob_value) == "bytes");
        if (typeOf(blob_value) == "bytes") {
            var blob_hex = bytesToHex(blob_value as bytes);
            println(blob_hex.1 == nil);
            if (blob_hex.1 == nil) {
                println(blob_hex.0 == "4142");
            } else {
                println(false);
            }
        } else {
            println(false);
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
    }

    var rows = sqliteQueryAll(db, "select id, name, age from users order by id;");
    println(rows.1 == nil);
    if (rows.1 == nil) {
        println(len(rows.0) == 4);
        println((mapGetString(rows.0[0], "id") as int) == 1);
        println((mapGetString(rows.0[1], "name") as string) == "bob");
    } else {
        println(false);
        println(false);
        println(false);
    }

    var one = sqliteQueryOne(db, "select id, name, age from users where id = 1;");
    println(one.1 == nil);
    if (one.1 == nil) {
        println(one.0 != nil);
        if (one.0 != nil) {
            var row1: map<string, any> = one.0 as map<string, any>;
            println((mapGetString(row1, "name") as string) == "alice");
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
    }

    var prepared = sqlitePrepareQuery(db, "select id, name from users where id <= 2 order by id;");
    println(prepared.1 == nil);
    if (prepared.1 == nil) {
        var stmt: SqliteStatement = prepared.0;
        var step1 = sqliteStepRow(stmt);
        println(step1.1 == nil);
        if (step1.1 == nil) {
            println(step1.0 != nil);
            if (step1.0 != nil) {
                var row_step1: map<string, any> = step1.0 as map<string, any>;
                println((mapGetString(row_step1, "name") as string) == "alice");
            } else {
                println(false);
            }
        } else {
            println(false);
            println(false);
        }

        var step2 = sqliteStepRow(stmt);
        println(step2.1 == nil);
        if (step2.1 == nil) {
            println(step2.0 != nil);
        } else {
            println(false);
        }

        var step3 = sqliteStepRow(stmt);
        println(step3.1 == nil);
        if (step3.1 == nil) {
            println(step3.0 == nil);
        } else {
            println(false);
        }

        var finalize_err = sqliteFinalizeStmt(stmt);
        println(finalize_err == nil);
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var schema: map<string, any> = {
        "type": "record",
        "fields": {
            "id": "int",
            "name": "string",
            "age": "int"
        }
    };
    var typed = sqliteQueryOneAs(db, "select id, name, age from users where id = 2;", schema);
    println(typed.1 == nil);
    if (typed.1 == nil) {
        println(typed.0 != nil);
        if (typed.0 != nil) {
            var typed_row: map<string, any> = typed.0 as map<string, any>;
            println((mapGetString(typed_row, "name") as string) == "bob");
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
    }

    var tx_begin1 = sqliteBeginTx(db);
    println(tx_begin1 == nil);
    if (tx_begin1 == nil) {
        var tx_insert1 = sqlitePrepareQuery(db, "insert into users(id, name, age) values (?1, ?2, ?3);");
        println(tx_insert1.1 == nil);
        if (tx_insert1.1 == nil) {
            println(sqliteExecPrepared(tx_insert1.0, [5 as any, "dina" as any, 22 as any]) == nil);
            println(sqliteFinalizeStmt(tx_insert1.0) == nil);
        } else {
            println(false);
            println(false);
        }
        println(sqliteRollbackTx(db) == nil);
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var rolled = sqliteQueryOne(db, "select id from users where id = 5;");
    println(rolled.1 == nil);
    if (rolled.1 == nil) {
        println(rolled.0 == nil);
    } else {
        println(false);
    }

    var tx_begin2 = sqliteBeginTx(db);
    println(tx_begin2 == nil);
    if (tx_begin2 == nil) {
        var tx_insert2 = sqlitePrepareQuery(db, "insert into users(id, name, age) values (?1, ?2, ?3);");
        println(tx_insert2.1 == nil);
        if (tx_insert2.1 == nil) {
            println(sqliteExecPrepared(tx_insert2.0, [5 as any, "dina" as any, 22 as any]) == nil);
            println(sqliteFinalizeStmt(tx_insert2.0) == nil);
        } else {
            println(false);
            println(false);
        }
        println(sqliteCommitTx(db) == nil);
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var prepared_param = sqlitePrepareQuery(db, "select id, name, age from users where id >= ?1 order by id;");
    println(prepared_param.1 == nil);
    if (prepared_param.1 == nil) {
        var param_stmt: SqliteStatement = prepared_param.0;
        var many = sqliteQueryPreparedAll(param_stmt, [3 as any]);
        println(many.1 == nil);
        if (many.1 == nil) {
            println(len(many.0) == 3);
            println((mapGetString(many.0[2], "name") as string) == "dina");
        } else {
            println(false);
            println(false);
        }

        var onep = sqliteQueryPreparedOne(param_stmt, [5 as any]);
        println(onep.1 == nil);
        if (onep.1 == nil) {
            println(onep.0 != nil);
            if (onep.0 != nil) {
                var row5: map<string, any> = onep.0 as map<string, any>;
                println((mapGetString(row5, "age") as int) == 22);
            } else {
                println(false);
            }
        } else {
            println(false);
            println(false);
        }

        runPreparedTypedWrappersTests(param_stmt, schema);
        println(sqliteFinalizeStmt(param_stmt) == nil);
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    runPreparedManyAndTxBatchTests(db);

    var close_err = sqliteCloseDb(db);
    println(close_err == nil);

    var reopened = sqliteOpenDb(db_path);
    println(reopened.1 == nil);
    if (reopened.1 == nil) {
        var reopened_rows = sqliteQueryAll(reopened.0, "select id from users order by id;");
        println(reopened_rows.1 == nil);
        if (reopened_rows.1 == nil) {
            println(len(reopened_rows.0) == 6);
        } else {
            println(false);
        }
        var close_reopen_err = sqliteCloseDb(reopened.0);
        println(close_reopen_err == nil);
    } else {
        println(false);
        println(false);
        println(false);
    }

    var deleted_after = delete(db_path);
    var delete_ok: bool = false;
    if (deleted_after.1 == nil) {
        delete_ok = deleted_after.0;
    } else {
        var delete_err: Error = deleted_after.1 as Error;
        // Windows can transiently keep sqlite files busy; accept ERR_IO for cleanup.
        delete_ok = delete_err.code == ERR_IO;
    }
    println(delete_ok);
    println(true);

    var memory_db = sqliteOpenMemory();
    println(memory_db.1 == nil);
    if (memory_db.1 == nil) {
        println(sqliteCloseDb(memory_db.0) == nil);
    } else {
        println(false);
    }
}
