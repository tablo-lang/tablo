    println(started3.1 == nil);
    if (started3.1 == nil) {
        var wrote3 = processWriteInput(started3.0, "abc\n");
        println(wrote3.1 == nil);
        if (wrote3.1 == nil) {
            println(wrote3.0 == 4);
        } else {
            println(false);
        }

        var close3 = processCloseInput(started3.0);
        println(close3 == nil);

        var waited3 = processWaitFor(started3.0, 3000);
        println(waited3.1 == nil);
        if (waited3.1 == nil) {
            println(waited3.0.finished);
            println(waited3.0.exitCode == 0);
            println(find(waited3.0.stdout, "stdin:abc") >= 0);
        } else {
            println(false);
            println(false);
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
