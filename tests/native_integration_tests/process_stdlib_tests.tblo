    }

    var sleep_cmd = shellSleepCommand(2);
    var started4 = processStartDefault(sleep_cmd.0, sleep_cmd.1);
    println(started4.1 == nil);
    if (started4.1 == nil) {
        var close4 = processCloseInput(started4.0);
        println(close4 == nil);

        var waited4a = processWaitFor(started4.0, 25);
        println(waited4a.1 == nil);
        if (waited4a.1 == nil) {
            println(waited4a.0.timedOut);
            println(!waited4a.0.finished);
        } else {
            println(false);
            println(false);
        }

        var terminate4 = processTerminate(started4.0);
        println(terminate4 == nil);

        var waited4b = processWaitFor(started4.0, 3000);
        println(waited4b.1 == nil);
        if (waited4b.1 == nil) {
            println(waited4b.0.finished);
            println(waited4b.0.killed);
        } else {
            println(false);
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var started5 = processStartDefault(sleep_cmd.0, sleep_cmd.1);
    println(started5.1 == nil);
    if (started5.1 == nil) {
        var close5 = processCloseInput(started5.0);
        println(close5 == nil);

        var ctx5 = contextWithTimeoutMs(contextBackground(), 50);
        println(ctx5.1 == nil);
        if (ctx5.1 == nil) {
            var waited5 = processWaitWithContext(started5.0, ctx5.0, 10);
            println(waited5.1 != nil);
            if (waited5.1 != nil) {
                println(waited5.1.code == ERR_LIMIT);
            } else {
                println(false);
            }

            var done5 = processWaitFor(started5.0, 3000);
            println(done5.1 == nil);
            if (done5.1 == nil) {
                println(done5.0.finished);
            } else {
                println(false);
            }
        } else {
            println(false);
            println(false);
            println(false);
            println(false);
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var run_cmd = shellEchoOutCommand("run_default");
    var run_r = processRunDefault(run_cmd.0, run_cmd.1, 1000);
    println(run_r.1 == nil);
    if (run_r.1 == nil) {
        println(run_r.0.finished);
        println(run_r.0.exitCode == 0);
        println(find(run_r.0.stdout, "run_default") >= 0);
    } else {
        println(false);
        println(false);
        println(false);
    }

    var run_input_cmd = shellReadEchoCommand();
    var run_input_r = processRunWithInputDefault(run_input_cmd.0,
                                                 run_input_cmd.1,
