        var close1 = processCloseInput(started1.0);
        println(close1 == nil);

        var waited1 = processWaitFor(started1.0, 3000);
        println(waited1.1 == nil);
        if (waited1.1 == nil) {
            println(waited1.0.finished);
            println(!waited1.0.timedOut);
            println(waited1.0.exitCode == 0);
            println(find(waited1.0.stdout, "hello_process") >= 0);
        } else {
            println(false);
            println(false);
            println(false);
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
