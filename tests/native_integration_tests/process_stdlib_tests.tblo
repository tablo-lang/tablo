                                                 1000);
    println(run_input_r.1 == nil);
    if (run_input_r.1 == nil) {
        println(run_input_r.0.finished);
        println(run_input_r.0.exitCode == 0);
        println(find(run_input_r.0.stdout, "stdin:run_input") >= 0);
    } else {
        println(false);
        println(false);
        println(false);
    }

    var pipe_left = shellEchoOutCommand("pipe_message");
    var pipe_right = shellReadEchoCommand();
    var pipe_default = processRunPipelineDefault(pipe_left.0,
                                                 pipe_left.1,
                                                 pipe_right.0,
                                                 pipe_right.1,
                                                 1500);
    println(pipe_default.1 == nil);
    if (pipe_default.1 == nil) {
        println(pipe_default.0.left.finished);
        println(pipe_default.0.left.exitCode == 0);
        println(find(pipe_default.0.left.stdout, "pipe_message") >= 0);
        println(pipe_default.0.right.finished);
        println(pipe_default.0.right.exitCode == 0);
        println(find(pipe_default.0.right.stdout, "stdin:pipe_message") >= 0);
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var left_no_stdout: ProcessOptions = {
        captureStdout: false,
        captureStderr: true
    };
    var pipe_forced = processRunPipeline(pipe_left.0,
                                         pipe_left.1,
                                         pipe_right.0,
                                         pipe_right.1,
                                         1500,
                                         left_no_stdout,
                                         nil);
    println(pipe_forced.1 == nil);
    if (pipe_forced.1 == nil) {
        println(find(pipe_forced.0.left.stdout, "pipe_message") >= 0);
        println(find(pipe_forced.0.right.stdout, "stdin:pipe_message") >= 0);
    } else {
        println(false);
        println(false);
    }

    var chunk_cmd = shellEchoOutCommand("chunk_stream_message");
    var chunk_started = processStartDefault(chunk_cmd.0, chunk_cmd.1);
    println(chunk_started.1 == nil);
    if (chunk_started.1 == nil) {
        var chunk_close = processCloseInput(chunk_started.0);
        println(chunk_close == nil);

        var chunk_text: string = "";
        var chunk_ok: bool = true;
        var chunk_wait_ok: bool = true;
        var chunk_done: ProcessResult = processDefaultResult();
        var chunk_idle_rounds_after_finish: int = 0;
        while (true) {
            var got_chunk: bool = false;
            while (true) {
                var chunk_r = processReadStdoutChunk(chunk_started.0, 5);
                if (chunk_r.1 != nil) {
                    chunk_ok = false;
                    break;
                }
                if (chunk_r.0 == nil) {
                    break;
                }
                chunk_text = chunk_text + (chunk_r.0 as string);
                got_chunk = true;
            }
            if (!chunk_ok) {
                break;
            }

            var waited_chunk = processWaitFor(chunk_started.0, 20);
            if (waited_chunk.1 != nil) {
                chunk_ok = false;
                chunk_wait_ok = false;
                break;
            }
            chunk_done = waited_chunk.0;

            if (chunk_done.finished) {
                if (got_chunk) {
                    chunk_idle_rounds_after_finish = 0;
                } else {
                    chunk_idle_rounds_after_finish = chunk_idle_rounds_after_finish + 1;
                }
                if (chunk_idle_rounds_after_finish >= 2) {
                    break;
                }
            } else {
                chunk_idle_rounds_after_finish = 0;
            }
        }
        println(chunk_ok);
        println(find(chunk_text, "chunk_stream_message") >= 0);
        println(chunk_wait_ok);
        if (chunk_wait_ok) {
            println(chunk_done.finished);
        } else {
            println(false);
        }

        var chunk_tail = processReadStdoutChunk(chunk_started.0, 5);
        println(chunk_tail.1 == nil);
        if (chunk_tail.1 == nil) {
            println(chunk_tail.0 == nil);
        } else {
            println(false);
        }
    } else {
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
        println(false);
    }

    var pipe_stream = processRunPipelineStreamDefault(pipe_left.0,
                                                      pipe_left.1,
                                                      pipe_right.0,
                                                      pipe_right.1,
