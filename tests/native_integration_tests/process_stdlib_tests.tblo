import "fixtures/process.tblo";

func isWindowsHost(): bool {
    var lower = envGet("ComSpec");
    if (lower.1 == nil && lower.0 != nil) {
        return true;
    }

    var upper = envGet("COMSPEC");
    if (upper.1 == nil && upper.0 != nil) {
        return true;
    }

    return false;
}

func shellEchoOutCommand(message: string): (string, array<string>) {
    if (isWindowsHost()) {
        return ("cmd", ["/c", "echo " + message]);
    }
    return ("sh", ["-c", "echo " + message]);
}

func shellEchoErrCommand(message: string): (string, array<string>) {
    if (isWindowsHost()) {
        return ("cmd", ["/c", "echo " + message + " 1>&2"]);
    }
    return ("sh", ["-c", "echo " + message + " 1>&2"]);
}

func shellReadEchoCommand(): (string, array<string>) {
    if (isWindowsHost()) {
        return ("powershell",
                [
                    "-NoProfile",
                    "-Command",
                    "$t=[Console]::In.ReadToEnd(); [Console]::Out.Write('stdin:' + $t)"
                ]);
    }
    return ("sh", ["-c", "data=$(cat); printf 'stdin:%s' \"$data\""]);
}

func shellSleepCommand(seconds: int): (string, array<string>) {
    if (isWindowsHost()) {
        // ping -n N waits roughly N-1 seconds.
        return ("cmd", ["/c", "ping -n " + str(seconds + 1) + " 127.0.0.1 >nul"]);
    }
    return ("sh", ["-c", "sleep " + str(seconds)]);
}

func main(): void {
    var echo_cmd = shellEchoOutCommand("hello_process");
