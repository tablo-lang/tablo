// Random stdlib micro-benchmark.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_random_stdlib.tblo
//   ./build/Release/tablo run tests/benchmark_random_stdlib.tblo 2

import "native_integration_tests/fixtures/random.tblo";

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 500) {
        w = 500;
    }
    return w;
}

func buildInts(count: int): array<int> {
    var out: array<int> = [];
    var i: int = 0;
    while (i < count) {
        push(out, i + 1);
        i = i + 1;
    }
    return out;
}

func benchRandomShuffleInts(iters: int): void {
    randomSeed(12345);
    var base: array<int> = buildInts(32);
    var sink: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var shuffled: array<int> = randomShuffleInts(base);
        sink = sink + shuffled[0];
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var shuffled_i: array<int> = randomShuffleInts(base);
        sink = sink + shuffled_i[0];
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf randomShuffleInts", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func benchRandomSampleDistinctInts(iters: int): void {
    randomSeed(777);
    var base: array<int> = buildInts(64);
    var sink: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var sample_w = randomSampleDistinctInts(base, 8);
        if (sample_w.1 != nil) {
            println("perf randomSampleDistinctInts: warm run failed");
            return;
        }
        sink = sink + sample_w.0[0];
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var sample_i = randomSampleDistinctInts(base, 8);
        if (sample_i.1 != nil) {
            println("perf randomSampleDistinctInts: run failed");
            return;
        }
        sink = sink + sample_i.0[0];
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf randomSampleDistinctInts", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func benchRandomPseudoBytes16(iters: int): void {
    randomSeed(42);
    var sink: int = 0;

    var warm: int = warmup(iters);
    var w: int = 0;
    while (w < warm) {
        var bytes_w = randomPseudoBytes(16);
        if (bytes_w.1 != nil) {
            println("perf randomPseudoBytes16: warm run failed");
            return;
        }
        sink = sink + bytes_w.0[0];
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var bytes_i = randomPseudoBytes(16);
        if (bytes_i.1 != nil) {
            println("perf randomPseudoBytes16: run failed");
            return;
        }
        sink = sink + bytes_i.0[0];
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf randomPseudoBytes16", iters, start, end);

    if (sink == -1) {
        println("error");
    }
}

func main(): void {
    println("=== TabloLang Random Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchRandomShuffleInts(70000 * scale);
    benchRandomSampleDistinctInts(45000 * scale);
    benchRandomPseudoBytes16(90000 * scale);

    println("Random stdlib benchmark complete!");
}
