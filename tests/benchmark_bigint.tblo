func main(): void {
    println("=== BigInt TabloLang Benchmarks ===");

    var a256: bigint = 597172686683661947648624710322682408081308528244101066486246236390026386524900n;
    var b256: bigint = 924421037061318583689848888950016439953881134174212538607554218794487963970870n;
    var a512: bigint = 20683933304168370455845888199423184913065902865418847777579583388107446748984301367057531643348161366707210878327722623156679249082293555084675232652653720n;
    var b512: bigint = 73308878442923045059976294952255587999123263358420094990610382528634504583670384642226159738983164471491540131922673939258587560940691215067502770621913422n;
    var a1024: bigint = ;
    var b1024: bigint = ;
    var a2048: bigint = ;
    var b2048: bigint = ;

    benchAdd("256-bit add", 2000000, a256, b256);
    benchSub("256-bit sub", 2000000, a256, b256);
    benchMul("256-bit mul", 200000, a256, b256);
    benchDiv("256-bit div", 400000, a256, b256);
    benchMod("256-bit mod", 400000, a256, b256);

    benchAdd("512-bit add", 1200000, a512, b512);
    benchSub("512-bit sub", 1200000, a512, b512);
    benchMul("512-bit mul", 120000, a512, b512);
    benchDiv("512-bit div", 240000, a512, b512);
    benchMod("512-bit mod", 240000, a512, b512);

    benchAdd("1024-bit add", 800000, a1024, b1024);
    benchSub("1024-bit sub", 800000, a1024, b1024);
    benchMul("1024-bit mul", 80000, a1024, b1024);
    benchDiv("1024-bit div", 200000, a1024, b1024);
    benchMod("1024-bit mod", 200000, a1024, b1024);

    benchAdd("2048-bit add", 400000, a2048, b2048);
    benchSub("2048-bit sub", 400000, a2048, b2048);
    benchMul("2048-bit mul", 40000, a2048, b2048);
    benchDiv("2048-bit div", 100000, a2048, b2048);
    benchMod("2048-bit mod", 100000, a2048, b2048);

    println("Benchmark complete!");
}
