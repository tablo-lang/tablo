func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchAdd(label: string, iters: int, a: bigint, b: bigint): void {
    var res: bigint = 0n;
    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        res = a + b;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        res = a + b;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report(label, iters, start, end);
    if (compareBigInt(res, res) != 0) { println("error"); }
}

func benchSub(label: string, iters: int, a: bigint, b: bigint): void {
    var res: bigint = 0n;
    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        res = a - b;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        res = a - b;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report(label, iters, start, end);
    if (compareBigInt(res, res) != 0) { println("error"); }
}

