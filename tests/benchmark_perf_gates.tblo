func benchSetHeaderGate(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var s_w: set<string> = {"_seed"};
        setRemove(s_w, "_seed");
        var j_w: int = 0;
        while (j_w < len(header_keys)) {
            setAdd(s_w, header_keys[j_w]);
            j_w = j_w + 1;
        }
        if (setHas(s_w, "content-type")) sink = sink + 1;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var s: set<string> = {"_seed"};
        setRemove(s, "_seed");
        var j: int = 0;
        while (j < len(header_keys)) {
            setAdd(s, header_keys[j]);
            j = j + 1;
        }
        if (setHas(s, "content-type")) sink = sink + 1;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf set<string> add+has", iters, start, end);
    if (sink == 0) println("error");
}

