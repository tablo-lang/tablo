func buildHeaderKeys(): array<string> {
    return [
        "host", "user-agent", "accept", "accept-encoding",
        "content-type", "content-length", "authorization", "x-request-id",
        "x-forwarded-for", "x-forwarded-proto", "cache-control", "connection",
        "date", "etag", "if-none-match", "server"
    ];
}

func buildPrefixedKeys(prefix: string, count: int): array<string> {
    var out_keys: array<string> = [];
    var i: int = 0;
    while (i < count) {
        push(out_keys, prefix + str(i));
        i = i + 1;
    }
    return out_keys;
}

func buildHighBitIntKeys(count: int): array<int> {
    var keys_i: array<int> = [];
    var i: int = 0;
    while (i < count) {
        // Keys differ in high 64-bit space to catch low-bit hash truncation.
        push(keys_i, (i * 8589934592) + 17);
        i = i + 1;
    }
    return keys_i;
}

func benchMapHeaderGate(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var h_w: map<string, int> = {};
        var j_w: int = 0;
        while (j_w < len(header_keys)) {
            mapSet(h_w, header_keys[j_w], j_w);
            j_w = j_w + 1;
        }
        var v_w: any = mapGet(h_w, "content-type");
        if (v_w != nil) sink = sink + (v_w as int);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var h: map<string, int> = {};
        var j: int = 0;
        while (j < len(header_keys)) {
            mapSet(h, header_keys[j], j);
            j = j + 1;
        }
        var v: any = mapGet(h, "content-type");
        if (v != nil) sink = sink + (v as int);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map<string,int> build+get", iters, start, end);
    if (sink == 0) println("error");
}

func benchMapHeaderSetHasGetGate(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var h_w: map<string, int> = {};
        var j_w: int = 0;
        while (j_w < len(header_keys)) {
            mapSet(h_w, header_keys[j_w], j_w);
            j_w = j_w + 1;
        }
        if (mapHas(h_w, "content-type")) sink = sink + 1;
        var v_w: any = mapGet(h_w, "content-type");
        if (v_w != nil) sink = sink + (v_w as int);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var h: map<string, int> = {};
        var j: int = 0;
        while (j < len(header_keys)) {
            mapSet(h, header_keys[j], j);
            j = j + 1;
        }
        if (mapHas(h, "content-type")) sink = sink + 1;
        var v: any = mapGet(h, "content-type");
        if (v != nil) sink = sink + (v as int);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map<string,int> set+has+get", iters, start, end);
    if (sink == 0) println("error");
}

