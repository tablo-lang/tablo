func benchMapSetChurnGate(iters: int): void {
    var key_count: int = 512;
    var keys_a: array<string> = buildPrefixedKeys("a", key_count);
    var keys_b: array<string> = buildPrefixedKeys("b", key_count);

    var m: map<string, int> = {};
    var s: set<string> = {"_seed"};
    setRemove(s, "_seed");

    var seed_i: int = 0;
    while (seed_i < key_count) {
        mapSet(m, keys_a[seed_i], seed_i);
        setAdd(s, keys_a[seed_i]);
        seed_i = seed_i + 1;
    }

    var sink: int = 0;
    var phase: int = 0; // 0 => move A->B, 1 => move B->A
    var last_key: string = keys_a[0];

    var warm: int = warmup(iters);
    var warm_cycles: int = warm / key_count;
    if ((warm % key_count) != 0) {
        warm_cycles = warm_cycles + 1;
    }
    warm = warm_cycles * key_count;

    var w: int = 0;
    while (w < warm) {
        var idx_w: int = w % key_count;
        var in_key_w: string = keys_b[idx_w];
        if (phase == 0) {
            mapDelete(m, keys_a[idx_w]);
            setRemove(s, keys_a[idx_w]);
            mapSet(m, keys_b[idx_w], w);
            setAdd(s, keys_b[idx_w]);
        } else {
            in_key_w = keys_a[idx_w];
            mapDelete(m, keys_b[idx_w]);
            setRemove(s, keys_b[idx_w]);
            mapSet(m, keys_a[idx_w], w);
            setAdd(s, keys_a[idx_w]);
        }
        last_key = in_key_w;

        var mv_w: any = mapGet(m, in_key_w);
        if (mv_w != nil) sink = sink + 1;
        if (setHas(s, in_key_w)) sink = sink + 1;

        if (idx_w == key_count - 1) {
            phase = 1 - phase;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var idx: int = i % key_count;
        var in_key: string = keys_b[idx];
        if (phase == 0) {
            mapDelete(m, keys_a[idx]);
            setRemove(s, keys_a[idx]);
            mapSet(m, keys_b[idx], i);
            setAdd(s, keys_b[idx]);
        } else {
            in_key = keys_a[idx];
            mapDelete(m, keys_b[idx]);
            setRemove(s, keys_b[idx]);
            mapSet(m, keys_a[idx], i);
            setAdd(s, keys_a[idx]);
        }
        last_key = in_key;

        var mv: any = mapGet(m, in_key);
        if (mv != nil) sink = sink + 1;
        if (setHas(s, in_key)) sink = sink + 1;

        if (idx == key_count - 1) {
            phase = 1 - phase;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map/set churn del+add+probe", iters, start, end);

    if (mapCount(m) != key_count) panic("map churn count drift");
    if (mapGet(m, last_key) == nil) panic("map churn missing key");
    if (!setHas(s, last_key)) panic("set churn missing key");
    if (sink == 0) println("error");
}

func benchMapSetChurnFastStringGate(iters: int): void {
    var key_count: int = 512;
    var keys_a: array<string> = buildPrefixedKeys("a", key_count);
    var keys_b: array<string> = buildPrefixedKeys("b", key_count);

    var m: map<string, int> = {};
    var s: set<string> = {"_seed"};
    setRemoveString(s, "_seed");

    var seed_i: int = 0;
    while (seed_i < key_count) {
        mapSetString(m, keys_a[seed_i], seed_i);
        setAddString(s, keys_a[seed_i]);
        seed_i = seed_i + 1;
    }

    var sink: int = 0;
    var phase: int = 0; // 0 => move A->B, 1 => move B->A
    var last_key: string = keys_a[0];

    var warm: int = warmup(iters);
    var warm_cycles: int = warm / key_count;
    if ((warm % key_count) != 0) {
        warm_cycles = warm_cycles + 1;
    }
    warm = warm_cycles * key_count;

    var w: int = 0;
    while (w < warm) {
        var idx_w: int = w % key_count;
        var in_key_w: string = keys_b[idx_w];
        if (phase == 0) {
            mapDeleteString(m, keys_a[idx_w]);
            setRemoveString(s, keys_a[idx_w]);
            mapSetString(m, keys_b[idx_w], w);
            setAddString(s, keys_b[idx_w]);
        } else {
            in_key_w = keys_a[idx_w];
            mapDeleteString(m, keys_b[idx_w]);
            setRemoveString(s, keys_b[idx_w]);
            mapSetString(m, keys_a[idx_w], w);
            setAddString(s, keys_a[idx_w]);
        }
        last_key = in_key_w;

        var mv_w: any = mapGetString(m, in_key_w);
        if (mv_w != nil) sink = sink + 1;
        if (setHasString(s, in_key_w)) sink = sink + 1;

        if (idx_w == key_count - 1) {
            phase = 1 - phase;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var idx: int = i % key_count;
        var in_key: string = keys_b[idx];
        if (phase == 0) {
            mapDeleteString(m, keys_a[idx]);
            setRemoveString(s, keys_a[idx]);
            mapSetString(m, keys_b[idx], i);
            setAddString(s, keys_b[idx]);
        } else {
            in_key = keys_a[idx];
            mapDeleteString(m, keys_b[idx]);
            setRemoveString(s, keys_b[idx]);
            mapSetString(m, keys_a[idx], i);
            setAddString(s, keys_a[idx]);
        }
        last_key = in_key;

        var mv: any = mapGetString(m, in_key);
        if (mv != nil) sink = sink + 1;
        if (setHasString(s, in_key)) sink = sink + 1;

        if (idx == key_count - 1) {
            phase = 1 - phase;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map/set churn fast-string del+add+probe", iters, start, end);

    if (mapCount(m) != key_count) panic("map churn fast-string count drift");
    if (mapGetString(m, last_key) == nil) panic("map churn fast-string missing key");
    if (!setHasString(s, last_key)) panic("set churn fast-string missing key");
    if (sink == 0) println("error");
}

func benchMapHighBitIntGate(iters: int): void {
    var key_count: int = 1024;
    var keys_i: array<int> = buildHighBitIntKeys(key_count);
    var m: map<int, int> = {};
    var sink: int = 0;

    var j: int = 0;
    while (j < key_count) {
        mapSet(m, keys_i[j], j);
        j = j + 1;
    }

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var idx_w: int = w % key_count;
        var k_w: int = keys_i[idx_w];
        mapSet(m, k_w, w);
        var v_w: any = mapGet(m, k_w);
        if (v_w != nil) sink = sink + (v_w as int) + 1;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var idx: int = i % key_count;
        var k: int = keys_i[idx];
        mapSet(m, k, i);
        var v: any = mapGet(m, k);
        if (v != nil) sink = sink + (v as int) + 1;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map<int> highbit set+get", iters, start, end);

    if (mapCount(m) != key_count) panic("highbit-int map count drift");
    if (mapGet(m, keys_i[key_count - 1]) == nil) panic("highbit-int map missing key");
    if (sink == 0) println("error");
}

func main(): void {
    println("=== TabloLang Perf Gates ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchJsonParseGate(300000 * scale);
    benchJsonParseScalarGate(450000 * scale);
    benchJsonParseObjectGate(220000 * scale);
    benchJsonStringifyGate(200000 * scale);
    benchJsonStringifyScalarGate(450000 * scale);
    benchJsonStringifyObjectGate(160000 * scale);
    benchMapHeaderGate(220000 * scale);
    benchMapHeaderSetHasGetGate(220000 * scale);
    benchMapHeaderFastStringGate(220000 * scale);
    benchMapHeaderReadGate(1200000 * scale);
    benchMapHeaderFastStringReadGate(1200000 * scale);
    benchSetHeaderGate(220000 * scale);
    benchSetHeaderFastStringGate(220000 * scale);
    benchMapSetChurnGate(260000 * scale);
    benchMapSetChurnFastStringGate(260000 * scale);
    benchMapHighBitIntGate(260000 * scale);

    println("Perf-gate benchmark complete!");
}
