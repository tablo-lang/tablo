func benchMapHeaderFastStringReadGate(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var probe_keys: array<string> = [
        "host", "content-type", "x-request-id", "missing-header",
        "accept", "authorization", "date", "also-missing"
    ];
    var probe_count: int = len(probe_keys);
    var h: map<string, int> = {};
    var j: int = 0;
    while (j < len(header_keys)) {
        mapSetString(h, header_keys[j], j);
        j = j + 1;
    }

    var sink: int = 0;
    var w: int = 0;
    var key_idx_w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var key_w: string = probe_keys[key_idx_w];
        if (mapHasString(h, key_w)) sink = sink + 1;
        var v_w: any = mapGetString(h, key_w);
        if (v_w != nil) sink = sink + (v_w as int);
        key_idx_w = key_idx_w + 1;
        if (key_idx_w == probe_count) {
            key_idx_w = 0;
        }
        w = w + 1;
    }

    var i: int = 0;
    var key_idx: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var key: string = probe_keys[key_idx];
        if (mapHasString(h, key)) sink = sink + 1;
        var v: any = mapGetString(h, key);
        if (v != nil) sink = sink + (v as int);
        key_idx = key_idx + 1;
        if (key_idx == probe_count) {
            key_idx = 0;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf map<string,int> fast-string read-heavy has+get", iters, start, end);
    if (sink == 0) println("error");
}

