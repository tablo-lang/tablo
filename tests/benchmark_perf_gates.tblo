// Performance gate benchmark set.
// Focused on JSON + map/set hot paths used by backend workloads.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_perf_gates.tblo
//   ./build/Release/tablo run tests/benchmark_perf_gates.tblo 2

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchJsonParseGate(iters: int): void {
    var json: string = "{\"user\":\"u123\",\"amount\":42,\"ok\":true,\"tags\":[\"a\",\"b\",\"c\"]}";

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (_, err_w) = jsonParse(json);
        if (err_w != nil) panic("jsonParse warmup failed");
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (_, err) = jsonParse(json);
        if (err != nil) panic("jsonParse failed");
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf jsonParse", iters, start, end);
}

func benchJsonParseScalarGate(iters: int): void {
    var json: string = "\"tablo-fast-path\"";
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (value_w, err_w) = jsonParse(json);
        if (err_w != nil) panic("jsonParse scalar warmup failed");
        sink = sink + len(value_w as string);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (value, err) = jsonParse(json);
        if (err != nil) panic("jsonParse scalar failed");
        sink = sink + len(value as string);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf jsonParse scalar", iters, start, end);
    if (sink == 0) println("error");
}

func benchJsonParseObjectGate(iters: int): void {
    var json: string = "{\"ok\":true,\"count\":42,\"name\":\"tablo\",\"tags\":[\"a\",\"b\",\"c\"],\"nums\":[1,2,3,4],\"flags\":[true,false,true]}";
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (obj_w, err_w) = jsonParse(json);
        if (err_w != nil) panic("jsonParse object warmup failed");
        var m_w: map<string, any> = obj_w as map<string, any>;
        sink = sink + (mapGet(m_w, "count") as int);
        var tags_w: array<any> = mapGet(m_w, "tags") as array<any>;
        sink = sink + len(tags_w[0] as string);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (obj, err) = jsonParse(json);
        if (err != nil) panic("jsonParse object failed");
        var m: map<string, any> = obj as map<string, any>;
        sink = sink + (mapGet(m, "count") as int);
        var tags: array<any> = mapGet(m, "tags") as array<any>;
        sink = sink + len(tags[0] as string);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf jsonParse object", iters, start, end);
    if (sink == 0) println("error");
}

func makePayload(): map<string, any> {
    var m: map<string, any> = {};
    mapSet(m, "ok", true);
    mapSet(m, "message", "hello");
    mapSet(m, "user", "u123");
    mapSet(m, "count", 42);
    mapSet(m, "values", [1, 2, 3, 4, 5]);
    return m;
}

func makeObjectPayload(): map<string, any> {
    var m: map<string, any> = {};
    mapSet(m, "ok", true);
    mapSet(m, "count", 42);
    mapSet(m, "name", "tablo");
    mapSet(m, "tags", ["a", "b", "c"]);
    mapSet(m, "nums", [1, 2, 3, 4]);
    mapSet(m, "flags", [true, false, true]);
    return m;
}

func benchJsonStringifyGate(iters: int): void {
    var payload: map<string, any> = makePayload();
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (s_w, err_w) = jsonStringify(payload);
        if (err_w != nil) panic("jsonStringify warmup failed");
        sink = sink + len(s_w);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (s, err) = jsonStringify(payload);
        if (err != nil) panic("jsonStringify failed");
        sink = sink + len(s);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf jsonStringify", iters, start, end);
    if (sink == 0) println("error");
}

