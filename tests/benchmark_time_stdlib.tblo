// Time stdlib micro-benchmark.
//
// Run:
//   ./build/Release/tablo run tests/benchmark_time_stdlib.tblo
//   ./build/Release/tablo run tests/benchmark_time_stdlib.tblo 2

import "native_integration_tests/fixtures/time.tblo";

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchTimeParseDuration(iters: int): void {
    var input: string = "2h5m10s25ms";
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var r_w = timeParseDuration(input);
        if (r_w.1 != nil) panic("timeParseDuration warmup failed: " + r_w.1.message);
        sink = sink + r_w.0;
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var r = timeParseDuration(input);
        if (r.1 != nil) panic("timeParseDuration failed: " + r.1.message);
        sink = sink + r.0;
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf timeParseDuration", iters, start, end);
    if (sink == 0) println("error");
}

func benchTimeFormatDuration(iters: int): void {
    var value: int = 7510025;
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var out_w: string = timeFormatDuration(value);
        sink = sink + len(out_w);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var out: string = timeFormatDuration(value);
        sink = sink + len(out);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf timeFormatDuration", iters, start, end);
    if (sink == 0) println("error");
}

func benchTimeDeadlineRemaining(iters: int): void {
    var deadline: int = timeMonotonicMillis() + 600000;
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        sink = sink + timeDeadlineRemaining(deadline);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        sink = sink + timeDeadlineRemaining(deadline);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("perf timeDeadlineRemaining", iters, start, end);
    if (sink == 0) println("error");
}

func main(): void {
    println("=== TabloLang Time Stdlib Benchmark ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchTimeParseDuration(220000 * scale);
    benchTimeFormatDuration(240000 * scale);
    benchTimeDeadlineRemaining(280000 * scale);

    println("Time stdlib benchmark complete!");
}
