func benchHeaderMapSetChurn(iters: int): void {
    var key_count: int = 1024;
    var keys_a: array<string> = buildPrefixedKeys("a", key_count);
    var keys_b: array<string> = buildPrefixedKeys("b", key_count);

    var h: map<string, string> = {};
    var s: set<string> = {"_seed"};
    setRemove(s, "_seed");

    var seed_i: int = 0;
    while (seed_i < key_count) {
        mapSet(h, keys_a[seed_i], "v" + str(seed_i));
        setAdd(s, keys_a[seed_i]);
        seed_i = seed_i + 1;
    }

    var sink: int = 0;
    var phase: int = 0; // 0 => move A->B, 1 => move B->A
    var last_key: string = keys_a[0];

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var idx_w: int = w % key_count;
        var in_key_w: string = keys_b[idx_w];
        if (phase == 0) {
            mapDelete(h, keys_a[idx_w]);
            setRemove(s, keys_a[idx_w]);
            mapSet(h, keys_b[idx_w], "v" + str(w));
            setAdd(s, keys_b[idx_w]);
        } else {
            in_key_w = keys_a[idx_w];
            mapDelete(h, keys_b[idx_w]);
            setRemove(s, keys_b[idx_w]);
            mapSet(h, keys_a[idx_w], "v" + str(w));
            setAdd(s, keys_a[idx_w]);
        }
        last_key = in_key_w;

        var hv_w: any = mapGet(h, in_key_w);
        if (hv_w != nil) {
            sink = sink + len(hv_w as string);
        }
        if (setHas(s, in_key_w)) {
            sink = sink + 1;
        }

        if (idx_w == key_count - 1) {
            phase = 1 - phase;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var idx: int = i % key_count;
        var in_key: string = keys_b[idx];
        if (phase == 0) {
            mapDelete(h, keys_a[idx]);
            setRemove(s, keys_a[idx]);
            mapSet(h, keys_b[idx], "v" + str(i));
            setAdd(s, keys_b[idx]);
        } else {
            in_key = keys_a[idx];
            mapDelete(h, keys_b[idx]);
            setRemove(s, keys_b[idx]);
            mapSet(h, keys_a[idx], "v" + str(i));
            setAdd(s, keys_a[idx]);
        }
        last_key = in_key;

        var hv: any = mapGet(h, in_key);
        if (hv != nil) {
            sink = sink + len(hv as string);
        }
        if (setHas(s, in_key)) {
            sink = sink + 1;
        }

        if (idx == key_count - 1) {
            phase = 1 - phase;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("map/set header churn del+add+probe", iters, start, end);

    if (mapCount(h) != key_count) panic("map/set churn count drift");
    if (mapGet(h, last_key) == nil) panic("map/set churn map missing key");
    if (!setHas(s, last_key)) panic("map/set churn set missing key");
    if (sink == 0) { println("error"); }
}

func benchHeaderMapSetChurnFastString(iters: int): void {
    var key_count: int = 1024;
    var keys_a: array<string> = buildPrefixedKeys("a", key_count);
    var keys_b: array<string> = buildPrefixedKeys("b", key_count);

    var h: map<string, string> = {};
    var s: set<string> = {"_seed"};
    setRemoveString(s, "_seed");

    var seed_i: int = 0;
    while (seed_i < key_count) {
        mapSetString(h, keys_a[seed_i], "v" + str(seed_i));
        setAddString(s, keys_a[seed_i]);
        seed_i = seed_i + 1;
    }

    var sink: int = 0;
    var phase: int = 0; // 0 => move A->B, 1 => move B->A
    var last_key: string = keys_a[0];

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var idx_w: int = w % key_count;
        var in_key_w: string = keys_b[idx_w];
        if (phase == 0) {
            mapDeleteString(h, keys_a[idx_w]);
            setRemoveString(s, keys_a[idx_w]);
            mapSetString(h, keys_b[idx_w], "v" + str(w));
            setAddString(s, keys_b[idx_w]);
        } else {
            in_key_w = keys_a[idx_w];
            mapDeleteString(h, keys_b[idx_w]);
            setRemoveString(s, keys_b[idx_w]);
            mapSetString(h, keys_a[idx_w], "v" + str(w));
            setAddString(s, keys_a[idx_w]);
        }
        last_key = in_key_w;

        var hv_w: any = mapGetString(h, in_key_w);
        if (hv_w != nil) {
            sink = sink + len(hv_w as string);
        }
        if (setHasString(s, in_key_w)) {
            sink = sink + 1;
        }

        if (idx_w == key_count - 1) {
            phase = 1 - phase;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var idx: int = i % key_count;
        var in_key: string = keys_b[idx];
        if (phase == 0) {
            mapDeleteString(h, keys_a[idx]);
            setRemoveString(s, keys_a[idx]);
            mapSetString(h, keys_b[idx], "v" + str(i));
            setAddString(s, keys_b[idx]);
        } else {
            in_key = keys_a[idx];
            mapDeleteString(h, keys_b[idx]);
            setRemoveString(s, keys_b[idx]);
            mapSetString(h, keys_a[idx], "v" + str(i));
            setAddString(s, keys_a[idx]);
        }
        last_key = in_key;

        var hv: any = mapGetString(h, in_key);
        if (hv != nil) {
            sink = sink + len(hv as string);
        }
        if (setHasString(s, in_key)) {
            sink = sink + 1;
        }

        if (idx == key_count - 1) {
            phase = 1 - phase;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("map/set header fast-string churn del+add+probe", iters, start, end);

    if (mapCount(h) != key_count) panic("map/set fast-string churn count drift");
    if (mapGetString(h, last_key) == nil) panic("map/set fast-string churn map missing key");
    if (!setHasString(s, last_key)) panic("map/set fast-string churn set missing key");
    if (sink == 0) { println("error"); }
}

func benchByteIo(size_bytes: int, repeats: int): void {
    var path: string = "bench_tmp_bytes.bin";

    var (buf, err) = bytesWithSize(size_bytes, 0);
    if (err != nil) {
        println("bytesWithSize failed: " + err.message);
        return;
    }

    var start_w: int = timeMonotonicMillis();
    var w: int = 0;
    while (w < repeats) {
        var (_, werr) = writeBytes(path, buf);
        if (werr != nil) {
            println("writeBytes failed: " + werr.message);
            return;
        }
        w = w + 1;
    }
    var end_w: int = timeMonotonicMillis();
    reportBytes("writeBytes (bytes)", size_bytes * repeats, start_w, end_w);

    var start_r: int = timeMonotonicMillis();
    var total_read: int = 0;
    var r: int = 0;
    while (r < repeats) {
        var (read_bytes, rerr) = readBytes(path);
        if (rerr != nil) {
            println("readBytes failed: " + rerr.message);
            return;
        }
        total_read = total_read + len(read_bytes);
        r = r + 1;
    }
    var end_r: int = timeMonotonicMillis();
    reportBytes("readBytes (bytes)", total_read, start_r, end_r);

    var (_, derr) = delete(path);
    if (derr != nil) {
        println("delete failed: " + derr.message);
    }
}

func main(): void {
    println("=== TabloLang Workload Benchmarks ===");

    var scale: int = 1;
    if (len(argv) > 0) {
        scale = toInt(argv[0]);
    }
    if (scale < 1) {
        scale = 1;
    }

    benchJsonParseOnly(800000 * scale);
    benchJsonParseAccess(400000 * scale);
    benchJsonParseScalarString(900000 * scale);
    benchJsonParseFlatObject(450000 * scale);
    benchJsonStringifyStatic(500000 * scale);
    benchJsonStringifyScalarString(900000 * scale);
    benchJsonStringifyFlatObject(450000 * scale);
    benchJsonBuildAndStringify(200000 * scale);
    benchHeaderMapBuildGet(350000 * scale);
    benchHeaderSetAddHas(350000 * scale);
    benchHeaderSetAddHasFastString(350000 * scale);
    benchHeaderMapSetChurn(420000 * scale);
    benchHeaderMapSetChurnFastString(420000 * scale);

    // Default VM limit is max_array_size=1,048,576 (also applies to bytes).
    benchByteIo(1024 * 1024, 12);

    println("Benchmark complete!");
}
