// TabloLang Workload Benchmarks (data/CLI + backend-ish workloads)
//
// Run:
//   ./build/Release/tablo run tests/benchmark_workloads.tblo
//   ./build/Release/tablo run tests/benchmark_workloads.tblo 2   // scale
//
// This suite focuses on:
// - JSON parse / access / stringify
// - Small map workloads (HTTP-like header maps)
// - Byte I/O using readBytes/writeBytes (bytes)

func report(label: string, iters: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var ops_per_sec: int = (iters * 1000) / elapsed;
    println(label + ": " + str(iters) + " ops in " + str(elapsed) + " ms (" + str(ops_per_sec) + " ops/s)");
}

func reportBytes(label: string, byte_count: int, start_ms: int, end_ms: int): void {
    var elapsed: int = end_ms - start_ms;
    if (elapsed <= 0) {
        elapsed = 1;
    }
    var mb_per_sec: int = ((byte_count / 1024) * 1000) / (elapsed * 1024);
    println(label + ": " + str(byte_count) + " bytes in " + str(elapsed) + " ms (" + str(mb_per_sec) + " MiB/s)");
}

func warmup(iters: int): int {
    var w: int = iters / 20;
    if (w < 1000) {
        w = 1000;
    }
    return w;
}

func benchJsonParseOnly(iters: int): void {
    var json: string = "{\"user\":\"u123\",\"amount\":42,\"ok\":true,\"tags\":[\"a\",\"b\",\"c\"]}";

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (_, err_w) = jsonParse(json);
        if (err_w != nil) {
            panic("jsonParse warmup failed");
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (_, err) = jsonParse(json);
        if (err != nil) {
            panic("jsonParse failed");
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonParse (parse-only)", iters, start, end);
}

func benchJsonParseAccess(iters: int): void {
    var json: string = "{\"user\":\"u123\",\"amount\":42,\"ok\":true,\"tags\":[\"a\",\"b\",\"c\"]}";
    var sum: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (obj_w, err_w) = jsonParse(json);
        if (err_w != nil) {
            panic("jsonParse warmup failed");
        }
        var m_w: map<string, any> = obj_w as map<string, any>;
        var amt_w: any = mapGet(m_w, "amount");
        if (amt_w != nil) {
            sum = sum + (amt_w as int);
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (obj, err) = jsonParse(json);
        if (err != nil) {
            panic("jsonParse failed");
        }
        var m: map<string, any> = obj as map<string, any>;
        var amt: any = mapGet(m, "amount");
        if (amt != nil) {
            sum = sum + (amt as int);
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonParse (parse+mapGet)", iters, start, end);
    if (sum == 0) { println("error"); }
}

func benchJsonParseScalarString(iters: int): void {
    var json: string = "\"tablo-fast-path\"";
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (value_w, err_w) = jsonParse(json);
        if (err_w != nil) {
            panic("jsonParse scalar warmup failed");
        }
        sink = sink + len(value_w as string);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (value, err) = jsonParse(json);
        if (err != nil) {
            panic("jsonParse scalar failed");
        }
        sink = sink + len(value as string);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonParse (scalar string)", iters, start, end);
    if (sink == 0) { println("error"); }
}

func benchJsonParseFlatObject(iters: int): void {
    var json: string = "{\"ok\":true,\"count\":42,\"name\":\"tablo\",\"tags\":[\"a\",\"b\",\"c\"],\"nums\":[1,2,3,4],\"flags\":[true,false,true]}";
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (obj_w, err_w) = jsonParse(json);
        if (err_w != nil) {
            panic("jsonParse flat-object warmup failed");
        }
        var m_w: map<string, any> = obj_w as map<string, any>;
        sink = sink + (mapGet(m_w, "count") as int);
        var tags_w: array<any> = mapGet(m_w, "tags") as array<any>;
        sink = sink + len(tags_w[0] as string);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (obj, err) = jsonParse(json);
        if (err != nil) {
            panic("jsonParse flat-object failed");
        }
        var m: map<string, any> = obj as map<string, any>;
        sink = sink + (mapGet(m, "count") as int);
        var tags: array<any> = mapGet(m, "tags") as array<any>;
        sink = sink + len(tags[0] as string);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonParse (flat object)", iters, start, end);
    if (sink == 0) { println("error"); }
}

