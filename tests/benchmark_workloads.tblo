func makeResponsePayload(): map<string, any> {
    var m: map<string, any> = {};
    mapSet(m, "ok", true);
    mapSet(m, "message", "hello");
    mapSet(m, "user", "u123");
    mapSet(m, "count", 42);
    mapSet(m, "values", [1, 2, 3, 4, 5]);
    return m;
}

func benchJsonStringifyStatic(iters: int): void {
    var payload: map<string, any> = makeResponsePayload();
    var total_len: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var (s_w, err_w) = jsonStringify(payload);
        if (err_w != nil) {
            panic("jsonStringify warmup failed");
        }
        total_len = total_len + len(s_w);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var (s, err) = jsonStringify(payload);
        if (err != nil) {
            panic("jsonStringify failed");
        }
        total_len = total_len + len(s);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonStringify (static map)", iters, start, end);
    if (total_len == 0) { println("error"); }
}

func benchJsonBuildAndStringify(iters: int): void {
    var total_len: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var payload_w: map<string, any> = makeResponsePayload();
        var (s_w, err_w) = jsonStringify(payload_w);
        if (err_w != nil) {
            panic("jsonStringify warmup failed");
        }
        total_len = total_len + len(s_w);
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var payload: map<string, any> = makeResponsePayload();
        var (s, err) = jsonStringify(payload);
        if (err != nil) {
            panic("jsonStringify failed");
        }
        total_len = total_len + len(s);
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("jsonStringify (build+stringify)", iters, start, end);
    if (total_len == 0) { println("error"); }
}

func buildHeaderKeys(): array<string> {
    return [
        "host", "user-agent", "accept", "accept-encoding",
        "content-type", "content-length", "authorization", "x-request-id",
        "x-forwarded-for", "x-forwarded-proto", "cache-control", "connection",
        "date", "etag", "if-none-match", "server"
    ];
}

func buildPrefixedKeys(prefix: string, count: int): array<string> {
    var out_keys: array<string> = [];
    var i: int = 0;
    while (i < count) {
        push(out_keys, prefix + str(i));
        i = i + 1;
    }
    return out_keys;
}

func benchHeaderMapBuildGet(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var header_values: array<string> = [
        "example.com", "tablo/0", "*/*", "gzip",
        "application/json", "123", "Bearer token", "req-123",
        "127.0.0.1", "https", "no-cache", "keep-alive",
        "Thu, 01 Jan 1970 00:00:00 GMT", "\"abc\"", "\"abc\"", "tablo"
    ];

    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var h_w: map<string, string> = {};
        var j_w: int = 0;
        while (j_w < len(header_keys)) {
            mapSet(h_w, header_keys[j_w], header_values[j_w]);
            j_w = j_w + 1;
        }
        var v_w: any = mapGet(h_w, "content-type");
        if (v_w != nil) {
            sink = sink + len(v_w as string);
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var h: map<string, string> = {};
        var j: int = 0;
        while (j < len(header_keys)) {
            mapSet(h, header_keys[j], header_values[j]);
            j = j + 1;
        }
        var v: any = mapGet(h, "content-type");
        if (v != nil) {
            sink = sink + len(v as string);
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("map<string,string> header build+get", iters, start, end);
    if (sink == 0) { println("error"); }
}

func benchHeaderSetAddHas(iters: int): void {
    var header_keys: array<string> = buildHeaderKeys();
    var sink: int = 0;

    var w: int = 0;
    var warm: int = warmup(iters);
    while (w < warm) {
        var s_w: set<string> = {"_seed"};
        setRemove(s_w, "_seed");
        var j_w: int = 0;
        while (j_w < len(header_keys)) {
            setAdd(s_w, header_keys[j_w]);
            j_w = j_w + 1;
        }
        if (setHas(s_w, "content-type")) {
            sink = sink + 1;
        }
        w = w + 1;
    }

    var i: int = 0;
    var start: int = timeMonotonicMillis();
    while (i < iters) {
        var s: set<string> = {"_seed"};
        setRemove(s, "_seed");
        var j: int = 0;
        while (j < len(header_keys)) {
            setAdd(s, header_keys[j]);
            j = j + 1;
        }
        if (setHas(s, "content-type")) {
            sink = sink + 1;
        }
        i = i + 1;
    }
    var end: int = timeMonotonicMillis();
    report("set<string> header add+has", iters, start, end);
    if (sink == 0) { println("error"); }
}

