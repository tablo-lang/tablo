func invokeDynamic2(fn: any, a: int, b: int): int {
    return fn(a, b);
}

func invokeDynamicBool2(fn: any, a: int, b: int): bool {
    return fn(a, b);
}

func invokeDynamicBool1(fn: any, n: int): bool {
    return fn(n);
}

func guardedAdd2(a: int, b: int): int {
    if (a < 0) {
        return a;
    }
    return a + b;
