func warmCaller(limit: int): int {
    var total: int = 0;
    var i: int = 0;
    while (i < limit) {
        total = total + hotLeaf(i);
        total = total + hotFallback(i);
        total = total + hotStub(i);
        total = total + hotSub(i);
        total = total + hotDiv(i);
        total = total + hotMod(i);
        total = total + hotAnd(i);
        total = total + hotOr(i);
        total = total + hotXor(i);
        total = total + invokeDynamic(hotDynamic, i);
        total = total + invokeDynamic2(hotAdd2, i, 1);
        total = total + invokeDynamic2(hotSub2, i, 1);
        total = total + invokeDynamic2(hotMul2, i, 2);
        total = total + invokeDynamic2(hotAnd2, i, 3);
        total = total + invokeDynamic2(hotOr2, i, 1);
        total = total + invokeDynamic2(hotXor2, i, 1);
        total = total + invokeDynamic2(hotDynamic2, i, 2);
        invokeDynamicBool2(hotLt2, i, 2);
        invokeDynamicBool2(hotLe2, i, 1);
        invokeDynamicBool2(hotEq2, i, 1);
        invokeDynamicBool2(hotNe2, i, 1);
        invokeDynamicBool2(hotGt2, i, 1);
        invokeDynamicBool2(hotGe2, i, 2);
        if (invokeDynamicBool1(hotLtConst, i)) { total = total + 1; }
        if (invokeDynamicBool1(hotLeConst, i)) { total = total + 1; }
        if (invokeDynamicBool1(hotEqConst, i)) { total = total + 1; }
        if (invokeDynamicBool1(hotNeConst, i)) { total = total + 1; }
        if (invokeDynamicBool1(hotGtConst, i)) { total = total + 1; }
        if (invokeDynamicBool1(hotGeConst, i)) { total = total + 1; }
        total = total + hotMinConst(i);
        total = total + hotMaxConst(i);
        total = total + guardedMinConst(i);
        total = total + guardedMaxConst(i);
        invokeDynamicBool2(guardedLtBool2, i, 2);
        invokeDynamicBool2(guardedLeBool2, i, 2);
        invokeDynamicBool2(guardedEqBool2, i, 1);
        invokeDynamicBool2(guardedNeBool2, i, 1);
        invokeDynamicBool2(guardedGtBool2, i, 1);
        invokeDynamicBool2(guardedGeBool2, i, 2);
        total = total + invokeDynamic2(hotMinLt2, i, 2);
        total = total + invokeDynamic2(hotMaxLt2, i, 2);
        total = total + invokeDynamic2(hotMinLe2, i, 1);
        total = total + invokeDynamic2(hotMaxGt2, i, 1);
        total = total + invokeDynamic2(hotMaxGe2, i, 2);
        total = total + invokeDynamic2(guardedMinLt2, i, 2);
        total = total + invokeDynamic2(guardedMaxLt2, i, 2);
        total = total + invokeDynamic2(guardedMinLe2, i, 1);
        total = total + invokeDynamic2(guardedMaxGt2, i, 1);
        total = total + invokeDynamic2(guardedMaxGe2, i, 2);
        total = total + invokeDynamic2(guardedAdd2, i, 1);
        total = total + invokeDynamic2(guardedSub2, i, 1);
        total = total + invokeDynamic2(guardedMul2, i, 2);
        total = total + invokeDynamic2(guardedAnd2, i, 3);
        total = total + invokeDynamic2(guardedOr2, i, 1);
        total = total + invokeDynamic2(guardedXor2, i, 1);
        i = i + 1;
    }
    return total;
}

async func asyncLeaf(): int {
    return 7;
}

func main(): void {
    println(warmCaller(3));
    var guardedBoolScore: int = 0;
    if (guardedLtBool2(-1, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    if (guardedLeBool2(-1, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    if (guardedEqBool2(-1, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    if (guardedNeBool2(-1, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    if (guardedGtBool2(3, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    if (guardedGeBool2(-1, 2)) { guardedBoolScore = guardedBoolScore + 1; }
    println(guardedBoolScore);
    var first: Future[int] = asyncLeaf();
    var second: Future[int] = asyncLeaf();
    println(futureGet(first));
    println(futureGet(second));
}
