func hotLeaf(n: int): int {
    if (n < 0) {
        return n;
    }
    return n + 1;
}

func hotFallback(n: int): int {
    if (n < 0) {
        return n;
    }
    return n * 2;
}

func hotStub(n: int): int {
    if (n < 0) {
        return n;
    }
    return ~n;
}

func hotSub(n: int): int {
    if (n < 0) {
        return n;
    }
    return n - 1;
}

func hotDiv(n: int): int {
    if (n < 0) {
        return n;
    }
    return n / 2;
}

func hotMod(n: int): int {
    if (n < 0) {
        return n;
    }
    return n % 2;
}

func hotAnd(n: int): int {
    if (n < 0) {
        return n;
    }
    return n & 3;
}

func hotOr(n: int): int {
    if (n < 0) {
        return n;
    }
    return n | 1;
}

func hotXor(n: int): int {
    if (n < 0) {
        return n;
    }
    return n ^ 1;
}

func hotDynamic(n: int): int {
    if (n < 0) {
        return n;
    }
    return n & 7;
}

func invokeDynamic(fn: any, n: int): int {
    return fn(n);
}

