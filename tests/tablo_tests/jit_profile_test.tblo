func guardedMinConst(n: int): int {
    if (n < 0) {
        return n;
    }
    if (n < 2) {
        return n;
    }
    return 2;
}

func guardedMaxConst(n: int): int {
    if (n < 0) {
        return n;
    }
    if (n < 2) {
        return 2;
    }
    return n;
}

